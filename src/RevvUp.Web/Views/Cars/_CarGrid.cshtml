@model RevvUp.Web.Models.BrowseViewModel

@foreach (var car in Model.Cars)
{
<div class="car-card opacity-0 group" x-data="{
    id: '@car.Id',
    get liked() {
        return JSON.parse(localStorage.getItem('likedCars') || '[]').includes(this.id);
    },
    toggleLike() {
        @if (User.Identity?.IsAuthenticated != true)
        {
            <text>
            window.location.href = '/Account/Login';
            return;
            </text>
        }
        else
        {
            <text>
            fetch(`/Cars/ToggleFavorite/${this.id}`, { method: 'POST' })
                .then(res => {
                    if (res.status === 401) {
                        window.location.href = '/Account/Login';
                        return;
                    }
                    return res.json();
                })
                .then(data => {
                    if (data && typeof data.favorited !== 'undefined') {
                        let list = JSON.parse(localStorage.getItem('likedCars') || '[]');
                        if (data.favorited) {
                            if (!list.includes(this.id)) list.push(this.id);
                        } else {
                            list = list.filter(item => item !== this.id);
                        }
                        localStorage.setItem('likedCars', JSON.stringify(list));
                        window.dispatchEvent(new Event('storage'));
                    }
                })
                .catch(err => console.error(err));
            </text>
        }
    }
}">
    <div class="card-interactive overflow-hidden">
        @* ── Image Container ── *@
        <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id"
           class="block relative h-52 overflow-hidden bg-surface-850">
            <img src="@car.PrimaryImageUrl" alt="@car.FullName" loading="lazy"
                 class="w-full h-full object-cover transition-transform duration-700 ease-out
                        group-hover:scale-105" />
            @* Gradient overlay *@
            <div class="absolute inset-0 bg-gradient-to-t from-surface-950/80 via-transparent to-transparent"></div>

            @* Featured badge *@
            @if (car.IsFeatured)
            {
                <div class="absolute top-3 left-3 bg-primary-600 text-white text-[10px] px-2 py-0.5 rounded font-bold uppercase tracking-wider">
                    Featured
                </div>
            }

            @* Time ago *@
            <div class="absolute top-3 right-3 px-2 py-1 rounded bg-surface-950/60 backdrop-blur-sm text-[10px] text-surface-300 font-medium">
                @car.TimeAgo
            </div>

            @* Price overlay *@
            <div class="absolute bottom-3 left-3">
                <p class="text-xl font-display font-bold text-white drop-shadow-md">@car.FormattedPrice</p>
            </div>

            @* Body type pill *@
            <div class="absolute bottom-3 right-3 px-2 py-1 rounded bg-white/10 backdrop-blur-sm text-[10px] text-white font-medium">
                @car.BodyType
            </div>
        </a>

        @* ── Card Body ── *@
        <div class="p-5">
            <div class="flex items-start justify-between gap-2 mb-2">
                <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id"
                   class="text-base font-display font-bold text-white truncate
                          group-hover:text-primary-400 transition-colors">
                     @car.FullName
                </a>
                @* ── Heart Wishlist Button ── *@
                <button x-on:click.stop.prevent="toggleLike()"
                        class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center transition-colors bg-surface-850 text-surface-500 hover:text-pink-500"
                        x-bind:class="liked ? 'text-pink-500 bg-pink-500/10' : ''">
                    <svg class="w-4 h-4"
                         x-bind:fill="liked ? 'currentColor' : 'none'"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                    </svg>
                </button>
            </div>

            @* ── Specs Row ── *@
            <div class="flex items-center gap-1.5 text-[11px] text-surface-400 mb-3">
                <span>@car.FormattedMileage</span>
                <span>•</span>
                <span>@car.FuelType</span>
                <span>•</span>
                <span>@car.Transmission</span>
            </div>

            @* ── Location ── *@
            <div class="flex items-center justify-between">
                <span class="flex items-center gap-1 text-[11px] text-surface-500">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0 1 15 0Z" />
                    </svg>
                    Curated Inventory
                </span>
                <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id"
                   class="text-xs font-medium text-primary-400 hover:text-primary-300 transition-colors
                          opacity-0 group-hover:opacity-100 translate-x-2 group-hover:translate-x-0
                          transition-all duration-200 flex items-center gap-1">
                    View Specs
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                </a>
            </div>
        </div>
    </div>
</div>
}
