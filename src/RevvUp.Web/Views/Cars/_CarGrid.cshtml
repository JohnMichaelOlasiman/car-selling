@model RevvUp.Web.Models.BrowseViewModel

@foreach (var car in Model.Cars)
{
    var isOwner = User.FindFirstValue(ClaimTypes.NameIdentifier) == car.SellerId;
<div class="car-card opacity-0 group" x-data="{
    faved: @car.IsFavoritedByCurrentUser.ToString().ToLower(),
    id: '@car.Id',
    inCompare: false,
    init() {
        let ids = JSON.parse(localStorage.getItem('compareCars') || '[]');
        this.inCompare = ids.includes(this.id);
    },
    addToCompare() {
        let ids = JSON.parse(localStorage.getItem('compareCars') || '[]');
        if (ids.includes(this.id)) {
            // Already in compare — redirect directly
            window.location.href = '/Cars/Compare?ids=' + ids.join(',');
            return;
        }
        if (ids.length >= 4) {
            window.showToast('Maximum 4 vehicles for comparison.', 'error');
            return;
        }
        ids.push(this.id);
        localStorage.setItem('compareCars', JSON.stringify(ids));
        window.dispatchEvent(new Event('storage'));
        this.inCompare = true;
        window.showToast('Added to Compare!', 'success');
        // Redirect to compare page
        setTimeout(() => {
            window.location.href = '/Cars/Compare?ids=' + ids.join(',');
        }, 400);
    },
    async toggleFavorite() {
        @if (User.Identity?.IsAuthenticated != true)
        {
            <text>
            window.location.href = '/Account/Register';
            return;
            </text>
        }
        else
        {
            <text>
            // Optimistic UI toggle
            this.faved = !this.faved;
            
            // Dispatch toast immediately
            const msg = this.faved ? 'Added to Saved Cars' : 'Removed from Saved Cars';
            window.showToast(msg, 'success');

            // Sync with localStorage for dashboard/other pages sync
            let list = JSON.parse(localStorage.getItem('likedCars') || '[]');
            if (this.faved) {
                if (!list.includes(this.id)) list.push(this.id);
            } else {
                list = list.filter(item => item !== this.id);
            }
            localStorage.setItem('likedCars', JSON.stringify(list));
            window.dispatchEvent(new Event('storage'));

            try {
                const token = document.querySelector('input[name=__RequestVerificationToken]')?.value;
                const response = await fetch(`/Cars/ToggleFavorite/${this.id}`, { 
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token || '' }
                });
                if (response.status === 401) {
                    // Revert state
                    this.faved = !this.faved;
                    window.showToast('Please log in to save cars.', 'error');
                    
                    // Revert localStorage
                    let currentList = JSON.parse(localStorage.getItem('likedCars') || '[]');
                    currentList = currentList.filter(item => item !== this.id);
                    localStorage.setItem('likedCars', JSON.stringify(currentList));
                    window.dispatchEvent(new Event('storage'));

                    setTimeout(() => {
                        window.location.href = '/Account/Register';
                    }, 1000);
                } else if (!response.ok) {
                    // Revert state
                    this.faved = !this.faved;
                    window.showToast('Failed to save. Please try again.', 'error');

                    // Revert localStorage
                    let currentList = JSON.parse(localStorage.getItem('likedCars') || '[]');
                    if (this.faved) {
                        if (!currentList.includes(this.id)) currentList.push(this.id);
                    } else {
                        currentList = currentList.filter(item => item !== this.id);
                    }
                    localStorage.setItem('likedCars', JSON.stringify(currentList));
                    window.dispatchEvent(new Event('storage'));
                }
            } catch (err) {
                // Revert state
                this.faved = !this.faved;
                window.showToast('A network error occurred.', 'error');

                // Revert localStorage
                let currentList = JSON.parse(localStorage.getItem('likedCars') || '[]');
                if (this.faved) {
                    if (!currentList.includes(this.id)) currentList.push(this.id);
                } else {
                    currentList = currentList.filter(item => item !== this.id);
                }
                localStorage.setItem('likedCars', JSON.stringify(currentList));
                window.dispatchEvent(new Event('storage'));
            }
            </text>
        }
    }
}">
    <div class="card-interactive overflow-hidden">
        @* ── Image Container ── *@
        <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id"
           class="block relative h-52 overflow-hidden bg-surface-850">
            <img src="@car.PrimaryImageUrl" alt="@car.FullName" loading="lazy"
                 onerror="this.onerror=null;this.src='https://placehold.co/800x600/1a1f2e/3b82f6?text=No+Image'"
                 class="w-full h-full object-cover transition-transform duration-700 ease-out
                        group-hover:scale-105" />
            @* Gradient overlay *@
            <div class="absolute inset-0 bg-gradient-to-t from-surface-950/80 via-transparent to-transparent"></div>

            @if (car.IsSold)
            {
                <div class="absolute inset-0 bg-black/60 rounded-xl flex items-center justify-center z-10">
                    <span class="bg-red-600 text-white text-lg font-black px-6 py-2 rounded-full uppercase tracking-widest rotate-[-15deg]">
                        SOLD
                    </span>
                </div>
            }

            @if (isOwner)
            {
                <div class="absolute top-2 left-2 bg-blue-600 text-white text-xs font-bold px-2 py-1 rounded-full uppercase tracking-wide z-10">
                    Your Listing
                </div>
            }

            @* Featured badge *@
            @if (car.IsFeatured)
            {
                <div class="absolute @(isOwner ? "top-10" : "top-3") left-3 bg-primary-600 text-white text-[10px] px-2 py-0.5 rounded font-bold uppercase tracking-wider">
                    Featured
                </div>
            }

            @* Time ago *@
            <div class="absolute top-3 right-3 px-2 py-1 rounded bg-surface-950/60 backdrop-blur-sm text-[10px] text-surface-300 font-medium">
                @car.TimeAgo
            </div>

            @* Price overlay *@
            <div class="absolute bottom-3 left-3">
                <p class="text-xl font-display font-bold text-white drop-shadow-md">@car.FormattedPrice</p>
            </div>

            @* Body type pill *@
            <div class="absolute bottom-3 right-3 px-2 py-1 rounded bg-white/10 backdrop-blur-sm text-[10px] text-white font-medium">
                @car.BodyType
            </div>
        </a>

        @* ── Card Body ── *@
        <div class="p-5">
            <div class="flex items-start justify-between gap-2 mb-2">
                <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id"
                   class="text-base font-display font-bold text-white truncate
                          group-hover:text-primary-400 transition-colors">
                     @car.FullName
                </a>
                @if (!isOwner)
                {
                    @* ── Heart Wishlist Button ── *@
                    <button x-on:click.stop.prevent="toggleFavorite()"
                            class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center transition-colors bg-surface-850 hover:text-red-500"
                            x-bind:class="faved ? 'bg-red-500/10' : ''">
                        <svg class="w-4 h-4 transition-all duration-300"
                             x-bind:class="faved ? 'fill-red-500 text-red-500' : 'fill-none text-gray-400'"
                             viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                        </svg>
                    </button>
                }
            </div>

            @* ── Specs Row ── *@
            <div class="flex items-center gap-1.5 text-[11px] text-surface-400 mb-3">
                <span>@car.FormattedMileage</span>
                <span>•</span>
                <span>@car.FuelType</span>
                <span>•</span>
                <span>@car.Transmission</span>
            </div>

            @* ── Location & Compare ── *@
            <div class="flex items-center justify-between">
                <span class="flex items-center gap-1 text-[11px] text-surface-500">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0 1 15 0Z" />
                    </svg>
                    Curated Inventory
                </span>
                <div class="flex items-center gap-2">
                    @* ── Add to Compare Button ── *@
                    <button x-on:click.stop.prevent="addToCompare()"
                            class="text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-lg transition-all duration-200 flex items-center gap-1"
                            x-bind:class="inCompare
                                ? 'bg-accent-500/15 text-accent-400 border border-accent-500/30'
                                : 'bg-surface-800/80 text-surface-400 border border-surface-700/50 hover:border-accent-500/30 hover:text-accent-400'">
                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                        </svg>
                        <span x-text="inCompare ? 'In Compare' : 'Compare'"></span>
                    </button>
                    <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id"
                       class="text-xs font-medium text-primary-400 hover:text-primary-300 transition-colors
                              opacity-0 group-hover:opacity-100 translate-x-2 group-hover:translate-x-0
                              transition-all duration-200 flex items-center gap-1">
                        View Specs
                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
}
