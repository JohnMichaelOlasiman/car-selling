@model RevvUp.Web.Models.BrowseViewModel
@{
    ViewData["Title"] = "Browse Cars";
    int totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
    int currentPage = Model.Page;
    int maxDisplayedPages = 5;
    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, startPage + maxDisplayedPages - 1);
    if (endPage - startPage + 1 < maxDisplayedPages)
    {
        startPage = Math.Max(1, endPage - maxDisplayedPages + 1);
    }
}

<div class="pt-20 min-h-screen" x-data="revvBrowse()">
    @* ── Hero Search Bar ── *@
    <div class="relative bg-gradient-to-b from-surface-900 to-surface-950 border-b border-surface-800/50 py-12 overflow-hidden">
        <div class="absolute inset-0 pointer-events-none">
            <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl"></div>
            <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-accent-500/5 rounded-full blur-3xl"></div>
        </div>
        <div class="premium-container relative z-10">
            <div class="text-center mb-8 animate-fade-in-down">
                <h1 class="text-4xl sm:text-5xl font-display font-bold text-white mb-3">
                    Find Your <span class="text-gradient">Dream Ride</span>
                </h1>
                <p class="text-surface-400 text-lg">@Model.TotalCount incredible cars waiting for you</p>
            </div>

            @* ── Search Input with Autocomplete ── *@
            <div class="max-w-2xl mx-auto relative animate-fade-in-up delay-200 opacity-0" x-data="searchAutocomplete()">
                <div class="relative">
                    <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-surface-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                    </svg>
                    <input type="text" id="car-search" x-model="query" x-on:input.debounce.300ms="fetchSuggestions()"
                           x-on:focus="showSuggestions = query.length >= 2"
                           x-on:keydown.escape="showSuggestions = false"
                           class="w-full pl-12 pr-32 py-4 rounded-2xl bg-surface-800/80 border border-surface-700/50
                                  text-white text-lg placeholder-surface-500 backdrop-blur-xl
                                  focus:border-primary-500/50 focus:shadow-glow-sm transition-all duration-300"
                           placeholder="Search Tesla, BMW, Supra..." />
                    <button x-on:click="submitSearch()" class="absolute right-2 top-1/2 -translate-y-1/2 btn-primary btn-sm">
                        Search
                    </button>
                </div>

                @* ── Autocomplete Dropdown ── *@
                <div x-show="showSuggestions && suggestions.length > 0" x-cloak
                     x-on:click.away="showSuggestions = false"
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 -translate-y-2"
                     x-transition:enter-end="opacity-100 translate-y-0"
                     class="absolute top-full mt-2 left-0 right-0 card-glass p-2 z-50">
                    <template x-for="(s, i) in suggestions" :key="i">
                        <a x-bind:href="'/Cars/Details/' + s.id"
                           class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-white/5 transition-all duration-300 group">
                            <img x-bind:src="s.image" class="w-12 h-8 rounded-lg object-cover bg-surface-800" />
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-white truncate" x-text="s.name"></p>
                                <p class="text-xs text-surface-500" x-text="s.bodyType"></p>
                            </div>
                            <span class="text-sm font-display font-bold text-primary-400" x-text="s.price"></span>
                        </a>
                    </template>
                </div>
            </div>

            @* ── Quick Filter Pills ── *@
            <div class="flex flex-wrap items-center justify-center gap-2 mt-6 animate-fade-in-up delay-300 opacity-0">
                @foreach (var bt in Model.AvailableBodyTypes)
                {
                    var isActive = Model.BodyType == bt;
                    <button type="button"
                            onclick="toggleBodyTypePill('@bt')"
                            data-body-type="@bt"
                            class="body-type-pill px-4 py-2 rounded-full text-sm font-medium transition-all duration-300 hover:border-primary-500/30 hover:text-white
                                   @(isActive ? "bg-primary-500 text-white shadow-glow-sm" : "bg-surface-800/80 text-surface-400 border border-surface-700/50")">
                        @bt
                    </button>
                }
            </div>
        </div>
    </div>

    @* ── Compare Mode Banner ── *@
    <div x-data="{
        fromCompare: new URLSearchParams(window.location.search).get('fromCompare') === 'true',
        slotsUsed: 0,
        dismissed: false,
        init() {
            if (this.fromCompare) {
                let ids = JSON.parse(localStorage.getItem('compareCars') || '[]');
                this.slotsUsed = ids.length;
            }
        }
    }">
        <div x-show="fromCompare && !dismissed" x-cloak
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0 -translate-y-2"
             x-transition:enter-end="opacity-100 translate-y-0"
             class="premium-container py-0 mt-2">
            <div class="bg-accent-500/10 border border-accent-500/30 rounded-2xl px-5 py-3 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 backdrop-blur-sm">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-xl bg-accent-500/20 flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-white">Comparison Mode</p>
                        <p class="text-xs text-surface-400">Click the <span class="text-accent-400 font-semibold">Compare</span> button on any card to add it. <span class="text-white font-semibold" x-text="(4 - slotsUsed) + ' slots remaining'"></span></p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <a x-bind:href="'/Cars/Compare?ids=' + JSON.parse(localStorage.getItem('compareCars') || '[]').join(',')"
                       class="btn-primary btn-sm text-xs">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                        </svg>
                        Go to Compare
                    </a>
                    <button x-on:click="dismissed = true" class="text-surface-400 hover:text-white transition-colors p-1" title="Dismiss">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="premium-container py-8">
        <div class="flex gap-8">
            @* ── Filter Sidebar (Desktop) ── *@
            <aside class="hidden lg:block w-72 flex-shrink-0">
                <div class="sticky top-24">
                    <form asp-action="Browse" method="get" class="card p-5 space-y-5" id="filter-form"
                          hx-get="@Url.Action("Browse")"
                          hx-target="#browse-results-container"
                          hx-select="#browse-results-container"
                          hx-swap="innerHTML"
                          hx-push-url="true"
                          hx-trigger="submit">
                        <input type="hidden" name="search" value="@Model.Search" />
                        <input type="hidden" name="sortBy" id="filter-sortBy" value="@Model.SortBy" />

                        <div class="flex items-center justify-between">
                            <h3 class="text-lg font-display font-bold text-white flex items-center gap-2">
                                <svg class="w-5 h-5 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75" />
                                </svg>
                                Filters
                            </h3>
                            <a href="@Url.Action("Browse")"
                               hx-get="@Url.Action("Browse")"
                               hx-target="#browse-results-container"
                               hx-select="#browse-results-container"
                               hx-swap="innerHTML"
                               hx-push-url="true"
                               onclick="const form = document.getElementById('filter-form'); if (form) { form.reset(); form.querySelectorAll('select').forEach(s => s.value = ''); form.querySelectorAll('input[type=number]').forEach(i => i.value = ''); const hs = form.querySelector('input[name=search]'); if (hs) hs.value = ''; const sby = document.getElementById('filter-sortBy'); if (sby) sby.value = 'newest'; } const cs = document.getElementById('car-search'); if (cs) { cs.value = ''; cs.dispatchEvent(new Event('input')); }"
                               class="text-xs text-primary-400 hover:text-primary-300 transition-colors">
                                Clear all
                            </a>
                        </div>

                        <div class="divider"></div>

                        @* ── Brand ── *@
                        <div>
                            <label class="block text-sm font-medium text-surface-300 mb-2">Brand</label>
                            <select name="brand" class="input text-sm">
                                <option value="">All Brands</option>
                                @foreach (var m in Model.AvailableBrands)
                                {
                                    <option value="@m" selected="@(Model.Brand == m)">@m</option>
                                }
                            </select>
                        </div>

                        @* ── Body Type ── *@
                        <div>
                            <label class="block text-sm font-medium text-surface-300 mb-2">Body Type</label>
                            <select name="bodyType" class="input text-sm">
                                <option value="">All Types</option>
                                @foreach (var b in Model.AvailableBodyTypes)
                                {
                                    <option value="@b" selected="@(Model.BodyType == b)">@b</option>
                                }
                            </select>
                        </div>

                        @* ── Fuel Type ── *@
                        <div>
                            <label class="block text-sm font-medium text-surface-300 mb-2">Fuel Type</label>
                            <select name="fuelType" class="input text-sm">
                                <option value="">All Fuel Types</option>
                                @foreach (var f in Model.AvailableFuelTypes)
                                {
                                    <option value="@f" selected="@(Model.FuelType == f)">@f</option>
                                }
                            </select>
                        </div>

                        @* ── Transmission ── *@
                        <div>
                            <label class="block text-sm font-medium text-surface-300 mb-2">Transmission</label>
                            <select name="transmission" class="input text-sm">
                                <option value="">All</option>
                                @foreach (var t in Model.AvailableTransmissions)
                                {
                                    <option value="@t" selected="@(Model.Transmission == t)">@t</option>
                                }
                            </select>
                        </div>

                        @* ── Price Range ── *@
                        <div>
                            <label class="block text-sm font-medium text-surface-300 mb-2">Price Range</label>
                            <div class="grid grid-cols-2 gap-2">
                                <input type="number" name="minPrice" value="@Model.MinPrice" class="input text-sm" placeholder="Min" />
                                <input type="number" name="maxPrice" value="@Model.MaxPrice" class="input text-sm" placeholder="Max" />
                            </div>
                        </div>

                        @* ── Year ── *@
                        <div>
                            <label class="block text-sm font-medium text-surface-300 mb-2">Year</label>
                            <div class="grid grid-cols-2 gap-2">
                                <input type="number" name="minYear" value="@Model.MinYear" class="input text-sm" placeholder="From" />
                                <input type="number" name="maxYear" value="@Model.MaxYear" class="input text-sm" placeholder="To" />
                            </div>
                        </div>

                        @* ── Mileage ── *@
                        <div>
                            <label class="block text-sm font-medium text-surface-300 mb-2">Max Mileage</label>
                            <input type="number" name="maxMileage" value="@Model.MaxMileage" class="input text-sm" placeholder="e.g. 50000" />
                        </div>

                        <div class="divider"></div>
                        <button type="submit" class="btn-primary w-full btn-sm">Apply Filters</button>
                    </form>
                </div>
            </aside>

            @* ── Mobile Filter Toggle ── *@
            <button x-on:click="filtersOpen = !filtersOpen"
                    class="lg:hidden fixed bottom-6 left-6 z-40 flex items-center gap-2 px-4 py-3 rounded-2xl
                           bg-primary-600 text-white shadow-glow text-sm font-medium
                           hover:bg-primary-500 active:scale-95 transition-all duration-300">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75" />
                </svg>
                Filters
            </button>

            @* ── Main Content ── *@
            <div class="flex-1 min-w-0" id="browse-results-container">
                @* ── Results Header ── *@
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
                    <div>
                        <p class="text-surface-400 text-sm">
                            Showing <span class="text-white font-semibold">@Model.Cars.Count</span>
                            of <span class="text-white font-semibold">@Model.TotalCount</span> cars
                        </p>
                    </div>
                    <div class="flex items-center gap-3">
                        <label class="text-xs text-surface-500">Sort:</label>
                        <select id="sort-select" class="input text-sm py-2 pr-8 w-44"
                                onchange="changeSort(this.value)">
                            <option value="newest" selected="@(Model.SortBy == "newest")">Newest</option>
                            <option value="price-low" selected="@(Model.SortBy == "price-low")">Price: Low</option>
                            <option value="price-high" selected="@(Model.SortBy == "price-high")">Price: High</option>
                            <option value="year-new" selected="@(Model.SortBy == "year-new")">Year: Newest</option>
                            <option value="mileage-low" selected="@(Model.SortBy == "mileage-low")">Mileage: Low</option>
                            <option value="mileage-high" selected="@(Model.SortBy == "mileage-high")">Mileage: High</option>
                        </select>
                    </div>
                </div>

                @* ── Car Grid ── *@
                <div id="car-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
                    @await Html.PartialAsync("_CarGrid", Model)
                </div>

                @* ── Premium Pagination ── *@
                @if (totalPages > 1)
                {
                    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mt-12 pt-6 border-t border-surface-800/50 animate-fade-in-up">
                        @* Pagination Info *@
                        <p class="text-sm text-surface-400">
                            Showing Page <span class="text-white font-semibold">@currentPage</span> of <span class="text-white font-semibold">@totalPages</span>
                        </p>

                        @* Pagination Links *@
                        <nav class="flex items-center gap-1.5" aria-label="Pagination">
                            @* First Page / Prev Page *@
                            @if (currentPage > 1)
                            {
                                <a href="@Url.Action("Browse", new { page = 1, search = Model.Search, brand = Model.Brand, bodyType = Model.BodyType, fuelType = Model.FuelType, transmission = Model.Transmission, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, maxMileage = Model.MaxMileage, sortBy = Model.SortBy })"
                                   hx-get="@Url.Action("Browse", new { page = 1, search = Model.Search, brand = Model.Brand, bodyType = Model.BodyType, fuelType = Model.FuelType, transmission = Model.Transmission, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, maxMileage = Model.MaxMileage, sortBy = Model.SortBy })"
                                   hx-target="#browse-results-container"
                                   hx-select="#browse-results-container"
                                   hx-swap="innerHTML"
                                   hx-push-url="true"
                                   class="w-10 h-10 rounded-xl bg-surface-800/80 text-surface-400 border border-surface-700/50 flex items-center justify-center transition-all duration-300 hover:border-primary-500/30 hover:text-white hover:bg-primary-500/5"
                                   title="First Page">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m18.75 5.25-7.5 7.5 7.5 7.5m-6-15-7.5 7.5 7.5 7.5" />
                                    </svg>
                                </a>
                                <a href="@Url.Action("Browse", new { page = currentPage - 1, search = Model.Search, brand = Model.Brand, bodyType = Model.BodyType, fuelType = Model.FuelType, transmission = Model.Transmission, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, maxMileage = Model.MaxMileage, sortBy = Model.SortBy })"
                                   hx-get="@Url.Action("Browse", new { page = currentPage - 1, search = Model.Search, brand = Model.Brand, bodyType = Model.BodyType, fuelType = Model.FuelType, transmission = Model.Transmission, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, maxMileage = Model.MaxMileage, sortBy = Model.SortBy })"
                                   hx-target="#browse-results-container"
                                   hx-select="#browse-results-container"
                                   hx-swap="innerHTML"
                                   hx-push-url="true"
                                   class="w-10 h-10 rounded-xl bg-surface-800/80 text-surface-400 border border-surface-700/50 flex items-center justify-center transition-all duration-300 hover:border-primary-500/30 hover:text-white hover:bg-primary-500/5"
                                   title="Previous Page">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                                    </svg>
                                </a>
                            }
                            else
                            {
                                <span class="w-10 h-10 rounded-xl bg-surface-850 text-surface-600 border border-surface-800/30 flex items-center justify-center cursor-not-allowed">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                                    </svg>
                                </span>
                            }

                            @* Ellipsis before startPage *@
                            @if (startPage > 1)
                            {
                                <span class="w-8 text-center text-surface-500">...</span>
                            }

                            @* Page Number Pills *@
                            @for (int p = startPage; p <= endPage; p++)
                            {
                                var isCurrent = (p == currentPage);
                                <a href="@Url.Action("Browse", new { page = p, search = Model.Search, brand = Model.Brand, bodyType = Model.BodyType, fuelType = Model.FuelType, transmission = Model.Transmission, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, maxMileage = Model.MaxMileage, sortBy = Model.SortBy })"
                                   hx-get="@Url.Action("Browse", new { page = p, search = Model.Search, brand = Model.Brand, bodyType = Model.BodyType, fuelType = Model.FuelType, transmission = Model.Transmission, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, maxMileage = Model.MaxMileage, sortBy = Model.SortBy })"
                                   hx-target="#browse-results-container"
                                   hx-select="#browse-results-container"
                                   hx-swap="innerHTML"
                                   hx-push-url="true"
                                   class="w-10 h-10 rounded-xl flex items-center justify-center font-display font-medium text-sm transition-all duration-300
                                          @(isCurrent ? "bg-primary-500 text-white shadow-glow-sm border border-primary-500" : "bg-surface-800/80 text-surface-400 border border-surface-700/50 hover:border-primary-500/30 hover:text-white hover:bg-primary-500/5")">
                                    @p
                                </a>
                            }

                            @* Ellipsis after endPage *@
                            @if (endPage < totalPages)
                            {
                                <span class="w-8 text-center text-surface-500">...</span>
                            }

                            @* Next Page / Last Page *@
                            @if (currentPage < totalPages)
                            {
                                <a href="@Url.Action("Browse", new { page = currentPage + 1, search = Model.Search, brand = Model.Brand, bodyType = Model.BodyType, fuelType = Model.FuelType, transmission = Model.Transmission, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, maxMileage = Model.MaxMileage, sortBy = Model.SortBy })"
                                   hx-get="@Url.Action("Browse", new { page = currentPage + 1, search = Model.Search, brand = Model.Brand, bodyType = Model.BodyType, fuelType = Model.FuelType, transmission = Model.Transmission, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, maxMileage = Model.MaxMileage, sortBy = Model.SortBy })"
                                   hx-target="#browse-results-container"
                                   hx-select="#browse-results-container"
                                   hx-swap="innerHTML"
                                   hx-push-url="true"
                                   class="w-10 h-10 rounded-xl bg-surface-800/80 text-surface-400 border border-surface-700/50 flex items-center justify-center transition-all duration-300 hover:border-primary-500/30 hover:text-white hover:bg-primary-500/5"
                                   title="Next Page">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                                    </svg>
                                </a>
                                <a href="@Url.Action("Browse", new { page = totalPages, search = Model.Search, brand = Model.Brand, bodyType = Model.BodyType, fuelType = Model.FuelType, transmission = Model.Transmission, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, maxMileage = Model.MaxMileage, sortBy = Model.SortBy })"
                                   hx-get="@Url.Action("Browse", new { page = totalPages, search = Model.Search, brand = Model.Brand, bodyType = Model.BodyType, fuelType = Model.FuelType, transmission = Model.Transmission, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, maxMileage = Model.MaxMileage, sortBy = Model.SortBy })"
                                   hx-target="#browse-results-container"
                                   hx-select="#browse-results-container"
                                   hx-swap="innerHTML"
                                   hx-push-url="true"
                                   class="w-10 h-10 rounded-xl bg-surface-800/80 text-surface-400 border border-surface-700/50 flex items-center justify-center transition-all duration-300 hover:border-primary-500/30 hover:text-white hover:bg-primary-500/5"
                                   title="Last Page">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m5.25 5.25 7.5 7.5-7.5 7.5m6-15 7.5 7.5-7.5 7.5" />
                                    </svg>
                                </a>
                            }
                            else
                            {
                                <span class="w-10 h-10 rounded-xl bg-surface-850 text-surface-600 border border-surface-800/30 flex items-center justify-center cursor-not-allowed">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                                    </svg>
                                </span>
                            }
                        </nav>
                    </div>
                }

                @* ── No Results ── *@
                @if (Model.Cars.Count == 0)
                {
                    <div class="text-center py-16 animate-fade-in-up">
                        <div class="flex justify-center mb-6">
                            <div class="w-16 h-16 rounded-full bg-surface-800 border border-surface-700/50 flex items-center justify-center text-primary-400">
                                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                                </svg>
                            </div>
                        </div>
                        <h3 class="text-2xl font-display font-bold text-white mb-2">No rides found</h3>
                        <p class="text-surface-400 mb-6">Try adjusting your filters or search for something different.</p>
                        <a href="@Url.Action("Browse")" class="btn-primary">Clear Filters & Browse All</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ── Search Autocomplete ──
function searchAutocomplete() {
    return {
        query: '@(Model.Search ?? "")',
        suggestions: [],
        showSuggestions: false,
        async fetchSuggestions() {
            if (this.query.length < 2) { this.suggestions = []; this.showSuggestions = false; return; }
            try {
                const res = await fetch(`/Cars/SearchSuggestions?q=${encodeURIComponent(this.query)}`);
                this.suggestions = await res.json();
                const input = document.getElementById('car-search');
                this.showSuggestions = this.suggestions.length > 0 && document.activeElement === input;
            } catch(e) { this.suggestions = []; }
        },
        submitSearch() {
            const hiddenSearch = document.querySelector('#filter-form input[name="search"]');
            if (hiddenSearch) {
                hiddenSearch.value = this.query;
                htmx.trigger(hiddenSearch.form, 'submit');
            } else {
                window.location.href = `/Cars/Browse?search=${encodeURIComponent(this.query)}`;
            }
        }
    };
}

// ── Browse page state ──
function revvBrowse() {
    return { filtersOpen: false };
}

// ── Sort helper ──
function changeSort(val) {
    const hiddenSort = document.getElementById('filter-sortBy');
    if (hiddenSort) {
        hiddenSort.value = val;
        htmx.trigger(hiddenSort.form, 'submit');
    } else {
        window.location.href = updateQueryParam('sortBy', val);
    }
}

function updateQueryParam(key, value) {
    const url = new URL(window.location.href);
    url.searchParams.set(key, value);
    url.searchParams.delete('page');
    return url.toString();
}

// ── Body Type Pill Toggle Helper ──
function toggleBodyTypePill(bt) {
    const form = document.getElementById('filter-form');
    if (!form) return;
    const bodyTypeSelect = form.querySelector('select[name="bodyType"]');
    if (!bodyTypeSelect) return;
    
    if (bodyTypeSelect.value === bt) {
        bodyTypeSelect.value = '';
    } else {
        bodyTypeSelect.value = bt;
    }
    
    htmx.trigger(form, 'submit');
}

// ── Sidebar Form State Sync from URL ──
function syncSidebarFromUrl() {
    const form = document.getElementById('filter-form');
    if (!form) return;
    const urlParams = new URLSearchParams(window.location.search);
    
    const fields = ['brand', 'bodyType', 'fuelType', 'transmission', 'minPrice', 'maxPrice', 'minYear', 'maxYear', 'maxMileage'];
    fields.forEach(field => {
        const input = form.querySelector(`[name="${field}"]`);
        if (input) {
            input.value = urlParams.get(field) || '';
        }
    });
    
    const searchInput = form.querySelector('input[name="search"]');
    if (searchInput) {
        searchInput.value = urlParams.get('search') || '';
    }
    
    const sortByInput = document.getElementById('filter-sortBy');
    if (sortByInput) {
        sortByInput.value = urlParams.get('sortBy') || 'newest';
    }
    
    const carSearch = document.getElementById('car-search');
    if (carSearch) {
        carSearch.value = urlParams.get('search') || '';
        carSearch.dispatchEvent(new Event('input'));
    }

    const sortSelect = document.getElementById('sort-select');
    if (sortSelect) {
        sortSelect.value = urlParams.get('sortBy') || 'newest';
    }

    // ── Sync Quick Filter Pills Highlight ──
    const bodyType = urlParams.get('bodyType') || '';
    document.querySelectorAll('.body-type-pill').forEach(pill => {
        const bt = pill.getAttribute('data-body-type');
        if (bt === bodyType) {
            pill.classList.remove('bg-surface-800/80', 'text-surface-400', 'border', 'border-surface-700/50');
            pill.classList.add('bg-primary-500', 'text-white', 'shadow-glow-sm');
        } else {
            pill.classList.remove('bg-primary-500', 'text-white', 'shadow-glow-sm');
            pill.classList.add('bg-surface-800/80', 'text-surface-400', 'border', 'border-surface-700/50');
        }
    });
}

// ── Intersection Observer for scroll reveal ──
document.addEventListener('DOMContentLoaded', () => {
    syncSidebarFromUrl();
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry, i) => {
            if (entry.isIntersecting) {
                entry.target.style.animationDelay = `${i * 80}ms`;
                entry.target.classList.add('animate-fade-in-up');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.car-card').forEach(card => observer.observe(card));
});

// ── Re-observe and Sync after HTMX Swap ──
document.body.addEventListener('htmx:afterSwap', function() {
    syncSidebarFromUrl();
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry, i) => {
            if (entry.isIntersecting) {
                entry.target.style.animationDelay = `${i * 80}ms`;
                entry.target.classList.add('animate-fade-in-up');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.car-card:not(.animate-fade-in-up)').forEach(card => observer.observe(card));
});

window.addEventListener('popstate', syncSidebarFromUrl);
</script>
}
