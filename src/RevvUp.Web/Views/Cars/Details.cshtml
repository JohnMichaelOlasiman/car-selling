@using RevvUp.Web.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<RevvUp.Core.Entities.ApplicationUser> UserManager
@model RevvUp.Web.Models.CarCardViewModel
@{
    ViewData["Title"] = Model.FullName;
    var currentUser = User.Identity?.IsAuthenticated == true ? await UserManager.GetUserAsync(User) : null;
    var currentUserName = currentUser?.DisplayName ?? "";
    var currentUserEmail = currentUser?.Email ?? "";
    var currentUserPhone = currentUser?.PhoneNumber ?? "";
}

<div class="pt-20 min-h-screen bg-surface-950 text-surface-200" x-data="revvDetails('@Model.Price', '@Model.Id')">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-8">
        @* ── Breadcrumb ── *@
        <nav class="flex items-center gap-2 text-xs text-surface-500 mb-6 uppercase tracking-wider font-semibold">
            <a href="/" class="hover:text-white transition-colors">Home</a>
            <svg class="w-3 h-3 text-surface-700" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" stroke-width="2"/></svg>
            <a asp-controller="Cars" asp-action="Browse" class="hover:text-white transition-colors">Browse</a>
            <svg class="w-3 h-3 text-surface-700" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" stroke-width="2"/></svg>
            <span class="text-white font-medium">@Model.FullName</span>
        </nav>

        @* ── Title & Price Header ── *@
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8 border-b border-surface-850 pb-8">
            <div>
                <div class="flex items-center gap-3">
                    <h1 class="text-3xl sm:text-5xl font-display font-black text-white tracking-tight">@Model.FullName</h1>
                    @if (Model.Status == "Sold")
                    {
                        <span class="px-3 py-1 rounded bg-red-500 text-white text-xs font-black tracking-wider shadow-glow-sm">SOLD</span>
                    }
                </div>
                <div class="flex flex-wrap items-center gap-3 mt-3 text-xs uppercase tracking-wider font-bold">
                    <span class="badge-primary">@Model.Year</span>
                    <span class="badge-accent">@Model.BodyType</span>
                    <span class="flex items-center gap-1 text-surface-400 font-semibold">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0 1 15 0Z"/></svg>
                        Curated Inventory
                    </span>
                </div>
            </div>
            <div class="text-left md:text-right">
                <p class="text-[10px] text-surface-500 font-bold uppercase tracking-widest">Premium Collection Price</p>
                <p class="text-3xl sm:text-4xl font-display font-black text-gradient mt-1">@Model.FormattedPrice</p>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            @* ── Column 1 & 2: Interactive Media Center ── *@
            <div class="lg:col-span-2 space-y-8">
                @* Media Showcase Card *@
                <div class="card overflow-hidden">
                    <div class="px-6 py-4 border-b border-surface-850 bg-surface-900/50 flex items-center justify-between">
                        <h3 class="text-xs font-bold uppercase tracking-wider text-white">
                            High-Res Vehicle Gallery
                        </h3>
                    </div>

                    @* Gallery View *@
                    <div class="relative aspect-video bg-surface-950">
                        <img x-bind:src="activeGalleryImage" alt="Car Showcase"
                             class="w-full h-full object-cover transition-all duration-300 animate-fade-in" />
                        <div class="absolute inset-0 bg-gradient-to-t from-surface-950/80 via-transparent to-transparent pointer-events-none"></div>

                        @* Thumbnail Strips *@
                        <div class="absolute bottom-4 left-4 right-4 flex gap-2 overflow-x-auto pb-2 scrollbar-none">
                            <template x-for="(img, index) in galleryImages" :key="index">
                                <button x-on:click="activeGalleryImage = img"
                                        class="w-20 h-14 rounded overflow-hidden border-2 flex-shrink-0 transition-all duration-200"
                                        x-bind:class="activeGalleryImage === img ? 'border-primary-500 scale-105 shadow-md' : 'border-surface-850 opacity-60 hover:opacity-100'">
                                    <img x-bind:src="img" class="w-full h-full object-cover" />
                                </button>
                            </template>
                        </div>
                    </div>
                </div>

                @* ── Tabbed Information Details Section ── *@
                <div class="card p-6">
                    <div class="flex border-b border-surface-850 gap-2 mb-6">
                        <template x-for="tab in infoTabs" :key="tab.id">
                            <button x-on:click="activeInfoTab = tab.id"
                                    class="px-4 py-3 text-xs font-bold uppercase tracking-wider transition-all duration-200 border-b-2"
                                    x-bind:class="activeInfoTab === tab.id ? 'text-primary-400 border-primary-500 bg-primary-500/5' : 'text-surface-400 border-transparent hover:text-white'">
                                <span x-text="tab.name"></span>
                            </button>
                        </template>
                    </div>

                    @* Tab Content: Overview *@
                    <div x-show="activeInfoTab === 'overview'" x-transition class="space-y-4">
                        <h3 class="text-base font-bold text-white uppercase tracking-wider">Vehicle Profile</h3>
                        <p class="text-surface-400 text-sm leading-relaxed whitespace-pre-line">@Model.Description</p>
                        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 pt-4">
                            <div class="p-4 rounded bg-surface-900 border border-surface-850">
                                <p class="text-[10px] text-surface-500 font-bold uppercase tracking-wider">Date Curated</p>
                                <p class="text-sm font-semibold text-white mt-1">@Model.DateAdded.ToString("MMMM dd, yyyy")</p>
                            </div>
                            <div class="p-4 rounded bg-surface-900 border border-surface-850">
                                <p class="text-[10px] text-surface-500 font-bold uppercase tracking-wider">Condition Grade</p>
                                <p class="text-sm font-semibold text-white mt-1">@Model.Condition</p>
                            </div>
                            <div class="p-4 rounded bg-surface-900 border border-surface-850">
                                <p class="text-[10px] text-surface-500 font-bold uppercase tracking-wider">Availability</p>
                                <p class="text-sm font-semibold text-white mt-1">@Model.Status</p>
                            </div>
                        </div>
                    </div>

                    @* Tab Content: Specifications *@
                    <div x-show="activeInfoTab === 'specs'" x-transition class="space-y-4">
                        <h3 class="text-base font-bold text-white uppercase tracking-wider">Technical Specifications</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3">
                            <div class="flex items-center justify-between py-2 border-b border-surface-850 text-sm">
                                <span class="text-surface-500 font-medium">Brand</span>
                                <span class="text-white font-semibold">@Model.Brand</span>
                            </div>
                            <div class="flex items-center justify-between py-2 border-b border-surface-850 text-sm">
                                <span class="text-surface-500 font-medium">Model</span>
                                <span class="text-white font-semibold">@Model.Model</span>
                            </div>
                            <div class="flex items-center justify-between py-2 border-b border-surface-850 text-sm">
                                <span class="text-surface-500 font-medium">Year</span>
                                <span class="text-white font-semibold">@Model.Year</span>
                            </div>
                            <div class="flex items-center justify-between py-2 border-b border-surface-850 text-sm">
                                <span class="text-surface-500 font-medium">Price</span>
                                <span class="text-white font-semibold">@Model.FormattedPrice</span>
                            </div>
                            <div class="flex items-center justify-between py-2 border-b border-surface-850 text-sm">
                                <span class="text-surface-500 font-medium">Mileage</span>
                                <span class="text-white font-semibold">@Model.FormattedMileage</span>
                            </div>
                            <div class="flex items-center justify-between py-2 border-b border-surface-850 text-sm">
                                <span class="text-surface-500 font-medium">Fuel Type</span>
                                <span class="text-white font-semibold">@Model.FuelType</span>
                            </div>
                            <div class="flex items-center justify-between py-2 border-b border-surface-850 text-sm">
                                <span class="text-surface-500 font-medium">Transmission</span>
                                <span class="text-white font-semibold">@Model.Transmission</span>
                            </div>
                            <div class="flex items-center justify-between py-2 border-b border-surface-850 text-sm">
                                <span class="text-surface-500 font-medium">Color</span>
                                <span class="text-white font-semibold">@Model.Color</span>
                            </div>
                        </div>
                    </div>

                    @* Tab Content: Features *@
                    <div x-show="activeInfoTab === 'features'" x-transition class="space-y-4">
                        <h3 class="text-base font-bold text-white uppercase tracking-wider">Premium Features</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm text-surface-300">
                            @if (!string.IsNullOrEmpty(Model.Features))
                            {
                                foreach (var feature in Model.Features.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <div class="flex items-center gap-2 font-medium">
                                        <svg class="w-4 h-4 text-primary-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                                        <span>@feature.Trim()</span>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-surface-500 italic">No features listed.</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* ── Column 3: Actions Console & EMI Calculator ── *@
            <div class="space-y-8">
                @* Actions Console Card *@
                <div class="card p-6 space-y-4">
                    <h3 class="text-base font-bold text-white uppercase tracking-wider flex items-center gap-2">
                        <svg class="w-5 h-5 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
                        </svg>
                        Inquiry Desk
                    </h3>
                    <div class="space-y-3">
                        @* ── Send Inquiry Button ── *@
                        <button x-on:click="contactModalOpen = true"
                                class="btn-primary w-full justify-center py-3 font-semibold text-sm transition-transform active:scale-95 duration-200"
                                id="details-contact-btn">
                            Send Inquiry
                        </button>

                        @* ── Save Favorites Button ── *@
                        <button x-on:click="toggleWishlist()"
                                class="w-full justify-center transition-all duration-200 py-2.5 text-xs flex items-center gap-2 font-bold uppercase tracking-wider"
                                x-bind:class="isLiked ? 'btn bg-pink-500/10 text-pink-400 border border-pink-500/20' : 'btn-outline border-surface-800 hover:border-surface-700 text-surface-400 hover:text-white'">
                            <svg class="w-4 h-4" x-bind:class="isLiked ? 'fill-current text-pink-400' : 'text-surface-400 group-hover:text-white'" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                            </svg>
                            <span x-text="isLiked ? 'Saved' : 'Save to Favorites'"></span>
                        </button>

                        @* ── Compare Button ── *@
                        <button x-on:click="toggleComparison()"
                                class="w-full btn-outline justify-center transition-all duration-200 py-2.5 text-xs flex items-center gap-2 font-bold uppercase tracking-wider"
                                x-bind:class="isInComparison ? 'border-primary-500 text-primary-400 bg-primary-500/5' : 'border-surface-800 hover:border-surface-700 text-surface-400 hover:text-white'"
                                id="details-compare-btn">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                            </svg>
                            <span x-text="isInComparison ? 'Added to Compare' : 'Compare Specifications'"></span>
                        </button>
                    </div>
                </div>

                @* Animated EMI Calculator *@
                <div class="card p-6 space-y-5 relative overflow-hidden">
                    <h3 class="text-base font-bold text-white uppercase tracking-wider">Financial Estimator</h3>

                    @* Down Payment Slider *@
                    <div class="space-y-2">
                        <div class="flex justify-between text-xs font-semibold text-surface-400">
                            <span>Down Payment</span>
                            <span class="text-white font-mono" x-text="formattedDownPayment"></span>
                        </div>
                        <input type="range" x-model="downPaymentPercentage" min="10" max="80" step="5"
                               class="w-full h-1 bg-surface-800 rounded-lg appearance-none cursor-pointer accent-primary-500"
                               x-on:input="calculateEMI()" />
                        <div class="flex justify-between text-[10px] text-surface-500 font-semibold">
                            <span>10% (Min)</span>
                            <span>80% (Max)</span>
                        </div>
                    </div>

                    @* Tenure Dropdown *@
                    <div class="space-y-2">
                        <label class="block text-xs font-semibold text-surface-400">Loan Tenure</label>
                        <select x-model="loanTenureMonths" x-on:change="calculateEMI()" class="input text-xs py-2.5 text-white bg-surface-900 border-surface-850">
                            <option value="12">12 Months (1 Year)</option>
                            <option value="24">24 Months (2 Years)</option>
                            <option value="36">36 Months (3 Years)</option>
                            <option value="48">48 Months (4 Years)</option>
                            <option value="60">60 Months (5 Years)</option>
                        </select>
                    </div>

                    @* Interest Rate Slider *@
                    <div class="space-y-2">
                        <div class="flex justify-between text-xs font-semibold text-surface-400">
                            <span>Interest Rate</span>
                            <span class="text-white font-mono" x-text="interestRate + '%'"></span>
                        </div>
                        <input type="range" x-model="interestRate" min="4.5" max="15.0" step="0.1"
                               class="w-full h-1 bg-surface-800 rounded-lg appearance-none cursor-pointer accent-primary-500"
                               x-on:input="calculateEMI()" />
                    </div>

                    <div class="divider border-surface-850 my-4"></div>

                    @* Computed Results *@
                    <div class="p-4 rounded bg-surface-950 border border-surface-850 text-center space-y-1">
                        <p class="text-[10px] text-surface-500 font-bold uppercase tracking-wider">Estimated Monthly Payment</p>
                        <p class="text-2xl font-display font-black text-primary-400 mt-1" x-text="monthlyEMI"></p>
                        <p class="text-[9px] text-surface-500 uppercase font-semibold"><span x-text="loanAmount"></span> Loan Principal</p>
                    </div>
                </div>
            </div>
        </div>

        @* ── Similar Cars Section ── *@
        @if (ViewBag.SimilarCars != null && ((List<CarCardViewModel>)ViewBag.SimilarCars).Count > 0)
        {
            <div class="mt-20 border-t border-surface-850 pt-16">
                <h3 class="text-xl font-display font-bold text-white mb-8">Similar Curated Vehicles</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    @foreach (var car in (List<CarCardViewModel>)ViewBag.SimilarCars)
                    {
                        <div class="card overflow-hidden hover:shadow-card-hover hover:-translate-y-1 hover:border-primary-500/30 transition-all duration-300 ease-out group relative"
                             x-data="{ 
                                id: '@car.Id',
                                get liked() {
                                    return JSON.parse(localStorage.getItem('likedCars') || '[]').includes(this.id);
                                },
                                toggleLike() {
                                    @if (User.Identity?.IsAuthenticated != true)
                                    {
                                        <text>
                                        window.location.href = '/Account/Login';
                                        return;
                                        </text>
                                    }
                                    else
                                    {
                                        <text>
                                        fetch(`/Cars/ToggleFavorite/${this.id}`, { method: 'POST' })
                                            .then(res => res.json())
                                            .then(data => {
                                                if (data && typeof data.favorited !== 'undefined') {
                                                    let list = JSON.parse(localStorage.getItem('likedCars') || '[]');
                                                    if (data.favorited) {
                                                        if (!list.includes(this.id)) list.push(this.id);
                                                    } else {
                                                        list = list.filter(item => item !== this.id);
                                                    }
                                                    localStorage.setItem('likedCars', JSON.stringify(list));
                                                    window.dispatchEvent(new Event('storage'));
                                                }
                                            });
                                        </text>
                                    }
                                }
                             }">
                            <a href="/Cars/Details/@car.Id" class="block relative h-48 overflow-hidden bg-surface-850">
                                <img src="@car.PrimaryImageUrl" alt="@car.FullName" loading="lazy" class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" />
                                <div class="absolute inset-0 bg-gradient-to-t from-surface-950/80 via-transparent to-transparent"></div>
                                <div class="absolute bottom-3 left-3">
                                    <p class="text-base font-display font-bold text-white drop-shadow-md">@car.FormattedPrice</p>
                                </div>
                            </a>
                            <div class="p-5">
                                <div class="flex items-start justify-between gap-2 mb-2">
                                    <a href="/Cars/Details/@car.Id" class="text-sm font-display font-bold text-white truncate group-hover:text-primary-400 transition-colors">@car.FullName</a>
                                    <button x-on:click="toggleLike()" class="text-surface-500 hover:text-pink-500 transition-colors">
                                        <svg class="w-5 h-5" x-bind:class="liked ? 'fill-current text-pink-500' : 'stroke-current text-surface-500'" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                                        </svg>
                                    </button>
                                </div>
                                <div class="flex items-center gap-1.5 text-[11px] text-surface-400">
                                    <span>@car.FormattedMileage</span>
                                    <span>•</span>
                                    <span>@car.Transmission</span>
                                    <span>•</span>
                                    <span>@car.FuelType</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @* ── Send Inquiry Modal ── *@
    <div x-show="contactModalOpen" x-cloak
         class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-surface-950/80 backdrop-blur-sm"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">
        <div class="card max-w-md w-full p-6 space-y-4 relative border-surface-800"
             x-on:click.away="contactModalOpen = false"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0 translate-y-4 scale-95"
             x-transition:enter-end="opacity-100 translate-y-0 scale-100">
            
            <button x-on:click="contactModalOpen = false" class="absolute top-4 right-4 text-surface-500 hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" stroke-width="2"/></svg>
            </button>

            <h3 class="text-lg font-bold text-white uppercase tracking-wider">Submit Inquiry</h3>
            <p class="text-xs text-surface-400 leading-relaxed">Request private viewing or purchase details about the <span class="text-white font-semibold">@Model.FullName</span> priced at <span class="text-primary-400 font-semibold font-mono">@Model.FormattedPrice</span>.</p>

            <div x-show="inquirySubmitted" class="p-4 rounded bg-emerald-500/10 border border-emerald-500/20 text-center space-y-2 animate-fade-in">
                <p class="text-sm font-bold text-emerald-400">Inquiry Dispatched Successfully</p>
                <p class="text-xs text-surface-400">Your message has been sent to our dealership. You can review your sent inquiries on your buyer dashboard inbox.</p>
                <button x-on:click="contactModalOpen = false; inquirySubmitted = false" class="btn bg-surface-850 hover:bg-surface-800 text-white w-full btn-sm font-bold uppercase tracking-wider mt-2">Close Console</button>
            </div>

            <div x-show="inquiryError.length > 0" class="p-3 rounded bg-red-500/10 border border-red-500/20 text-center text-xs text-red-400 font-semibold animate-fade-in" x-text="inquiryError"></div>

            <form x-show="!inquirySubmitted" x-on:submit.prevent="submitMessage()" class="space-y-4">
                @Html.AntiForgeryToken()
                <div>
                    <label class="block text-[10px] font-bold uppercase tracking-wider text-surface-400 mb-1">Full Name</label>
                    <input type="text" x-model="buyerName" class="input text-xs py-2 bg-surface-900 border-surface-850 text-white focus:border-primary-500" placeholder="John Doe" required />
                </div>
                <div>
                    <label class="block text-[10px] font-bold uppercase tracking-wider text-surface-400 mb-1">Email Address</label>
                    <input type="email" x-model="buyerEmail" class="input text-xs py-2 bg-surface-900 border-surface-850 text-white focus:border-primary-500" placeholder="john@example.com" required />
                </div>
                <div>
                    <label class="block text-[10px] font-bold uppercase tracking-wider text-surface-400 mb-1">Phone Number</label>
                    <input type="tel" x-model="buyerPhone" class="input text-xs py-2 bg-surface-900 border-surface-850 text-white focus:border-primary-500" placeholder="+1 (555) 000-0000" required />
                </div>
                <div>
                    <label class="block text-[10px] font-bold uppercase tracking-wider text-surface-400 mb-1">Message Detail</label>
                    <textarea x-model="messageText" class="input text-xs h-24 py-2 bg-surface-900 border-surface-850 text-white focus:border-primary-500" placeholder="Hello, I am interested in this vehicle. Is it still available?" required></textarea>
                </div>
                <button type="submit" class="btn-primary w-full justify-center py-2.5 flex items-center gap-2 font-bold uppercase tracking-wider" x-bind:disabled="sendingInquiry">
                    <span x-show="sendingInquiry" class="animate-spin inline-block w-4 h-4 border-2 border-white border-t-transparent rounded-full"></span>
                    <span x-text="sendingInquiry ? 'Sending...' : 'Dispatch Inquiry'"></span>
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function revvDetails(carPriceStr, carId) {
    const rawPrice = parseFloat(carPriceStr.replace(/[^0-9.-]+/g, '')) || 0;

    return {
        activeGalleryImage: '@Model.PrimaryImageUrl',
        galleryImages: [
            @Html.Raw(string.Join(",", Model.ImageUrls.Split(';', StringSplitOptions.RemoveEmptyEntries).Select(img => $"'{img}'")))
        ],
        infoTabs: [
            { id: 'overview', name: 'Overview' },
            { id: 'specs', name: 'Specifications' },
            { id: 'features', name: 'Features' }
        ],
        activeInfoTab: 'overview',
        contactModalOpen: false,
        inquirySubmitted: false,
        sendingInquiry: false,
        inquiryError: '',

        // ── Form Model Bindings ──
        buyerName: '@currentUserName',
        buyerEmail: '@currentUserEmail',
        buyerPhone: '@currentUserPhone',
        messageText: 'Hello, I am interested in this vehicle. Is it still available?',

        // ── Wishlist State ──
        isLiked: false,

        // ── Compare List State ──
        isInComparison: false,

        // ── EMI State ──
        downPaymentPercentage: 20,
        loanTenureMonths: 36,
        interestRate: 7.5,
        monthlyEMI: '$0',
        loanAmount: '0',

        init() {
            this.calculateEMI();
            this.checkWishlist();
            this.checkComparison();
        },

        // ── Wishlist Operations ──
        checkWishlist() {
            let likedIds = JSON.parse(localStorage.getItem('likedCars') || '[]');
            this.isLiked = likedIds.includes(carId);
        },
        toggleWishlist() {
            @if (User.Identity?.IsAuthenticated != true)
            {
                <text>
                window.location.href = '/Account/Login';
                return;
                </text>
            }
            else
            {
                <text>
                fetch(`/Cars/ToggleFavorite/${carId}`, { method: 'POST' })
                    .then(res => {
                        if (res.status === 401) {
                            window.location.href = '/Account/Login';
                            return;
                        }
                        return res.json();
                    })
                    .then(data => {
                        if (data && typeof data.favorited !== 'undefined') {
                            let likedIds = JSON.parse(localStorage.getItem('likedCars') || '[]');
                            if (data.favorited) {
                                if (!likedIds.includes(carId)) likedIds.push(carId);
                                this.isLiked = true;
                            } else {
                                likedIds = likedIds.filter(id => id !== carId);
                                this.isLiked = false;
                            }
                            localStorage.setItem('likedCars', JSON.stringify(likedIds));
                            window.dispatchEvent(new Event('storage'));
                        }
                    })
                    .catch(err => console.error(err));
                </text>
            }
        },

        // ── Comparison Operations ──
        checkComparison() {
            let compareIds = JSON.parse(localStorage.getItem('compareCars') || '[]');
            this.isInComparison = compareIds.includes(carId);
        },
        toggleComparison() {
            let compareIds = JSON.parse(localStorage.getItem('compareCars') || '[]');
            if (compareIds.includes(carId)) {
                compareIds = compareIds.filter(id => id !== carId);
                this.isInComparison = false;
            } else {
                if (compareIds.length >= 4) {
                    alert('Maximum of 4 vehicles can be selected for comparison.');
                    return;
                }
                compareIds.push(carId);
                this.isInComparison = true;
            }
            localStorage.setItem('compareCars', JSON.stringify(compareIds));
            window.dispatchEvent(new Event('storage'));
        },

        // ── EMI Calculator math ──
        calculateEMI() {
            const principal = rawPrice * (1 - this.downPaymentPercentage / 100);
            const ratePerMonth = (this.interestRate / 12) / 100;
            const tenure = parseInt(this.loanTenureMonths);

            const emi = (principal * ratePerMonth * Math.pow(1 + ratePerMonth, tenure)) / (Math.pow(1 + ratePerMonth, tenure) - 1);

            this.loanAmount = '$' + Math.round(principal).toLocaleString();
            this.monthlyEMI = isNaN(emi) ? '$0' : '$' + Math.round(emi).toLocaleString();
        },

        get formattedDownPayment() {
            const value = rawPrice * (this.downPaymentPercentage / 100);
            return '$' + Math.round(value).toLocaleString() + ' (' + this.downPaymentPercentage + '%)';
        },

        // ── Contact Dealer AJAX Submit ──
        async submitMessage() {
            if (!this.buyerName.trim() || !this.buyerEmail.trim() || !this.buyerPhone.trim() || !this.messageText.trim()) {
                this.inquiryError = "Please fill out all fields.";
                return;
            }

            this.sendingInquiry = true;
            this.inquiryError = "";

            try {
                const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
                const headers = {
                    'Content-Type': 'application/json'
                };
                if (tokenElement) {
                    headers['RequestVerificationToken'] = tokenElement.value;
                }

                const response = await fetch('/Cars/ContactSeller', {
                    method: 'POST',
                    headers: headers,
                    body: JSON.stringify({
                        carId: carId,
                        buyerName: this.buyerName,
                        buyerEmail: this.buyerEmail,
                        phone: this.buyerPhone,
                        message: this.messageText
                    })
                });

                if (response.ok) {
                    this.inquirySubmitted = true;
                    this.messageText = "Hello, I am interested in this vehicle. Is it still available?";
                } else {
                    const text = await response.text();
                    this.inquiryError = text || "An error occurred while sending your inquiry.";
                }
            } catch (err) {
                console.error(err);
                this.inquiryError = "A network error occurred. Please try again.";
            } finally {
                this.sendingInquiry = false;
            }
        }
    };
}
</script>
}
