@{
    ViewData["Title"] = "Selling Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="animate-fade-in-up">
    <div class="mb-8">
        <h1 class="text-3xl font-display font-bold text-white mb-2">Selling Dashboard 💰</h1>
        <p class="text-surface-400">Track your sales performance and earnings</p>
    </div>

    @* ── Revenue Stats ── *@
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="card p-6 text-center group hover:border-green-500/30 transition-all duration-500">
            <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-green-500/20 flex items-center justify-center
                        group-hover:scale-110 transition-transform duration-500">
                <svg class="w-6 h-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
            </div>
            <div class="text-3xl font-display font-bold text-white mb-1">₱12.5M</div>
            <div class="text-sm text-surface-500">Total Revenue</div>
        </div>

        <div class="card p-6 text-center group hover:border-primary-500/30 transition-all duration-500">
            <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-primary-500/20 flex items-center justify-center
                        group-hover:scale-110 transition-transform duration-500">
                <svg class="w-6 h-6 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
                </svg>
            </div>
            <div class="text-3xl font-display font-bold text-white mb-1">1</div>
            <div class="text-sm text-surface-500">Cars Sold</div>
        </div>

        <div class="card p-6 text-center group hover:border-accent-500/30 transition-all duration-500">
            <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-accent-500/20 flex items-center justify-center
                        group-hover:scale-110 transition-transform duration-500">
                <svg class="w-6 h-6 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
            </div>
            <div class="text-3xl font-display font-bold text-white mb-1">3 days</div>
            <div class="text-sm text-surface-500">Avg. Sell Time</div>
        </div>
    </div>

    @* ── Sales Tips ── *@
    <div class="card p-6">
        <h3 class="text-lg font-display font-bold text-white mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
                </svg>
            Pro Tips to Sell Faster
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="p-4 rounded-xl bg-surface-800/50 border border-surface-700/30">
                <span class="text-2xl mb-2 block">📸</span>
                <h4 class="text-sm font-bold text-white mb-1">Great Photos</h4>
                <p class="text-xs text-surface-500">Listings with 10+ photos sell 3x faster</p>
            </div>
            <div class="p-4 rounded-xl bg-surface-800/50 border border-surface-700/30">
                <span class="text-2xl mb-2 block">💲</span>
                <h4 class="text-sm font-bold text-white mb-1">Fair Pricing</h4>
                <p class="text-xs text-surface-500">Competitive pricing attracts more serious buyers</p>
            </div>
            <div class="p-4 rounded-xl bg-surface-800/50 border border-surface-700/30">
                <span class="text-2xl mb-2 block">⚡</span>
                <h4 class="text-sm font-bold text-white mb-1">Quick Replies</h4>
                <p class="text-xs text-surface-500">Respond within 1 hour for best results</p>
            </div>
        </div>
    </div>
</div>
