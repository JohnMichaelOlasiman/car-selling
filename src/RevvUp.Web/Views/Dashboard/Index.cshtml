@using RevvUp.Web.Controllers
@{
    ViewData["Title"] = "Buyer Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var userName = ViewData["UserName"]?.ToString() ?? "Valued Buyer";
    var recentActivities = ViewBag.RecentActivities as List<DashboardActivity> ?? new List<DashboardActivity>();
}

<div class="animate-fade-in-up">
    @* ── Welcome Header ── *@
    <div class="mb-8">
        <h1 class="text-3xl font-display font-bold text-white mb-2">
            Welcome, @userName!
        </h1>
        <p class="text-surface-400">Manage your premium curated car discoveries and active dealership inquiries.</p>
    </div>

    @* ── Stats Grid (Buyer Curation Only) ── *@
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
        @* Saved Vehicles (Favorites) *@
        <div class="card p-6 group hover:border-pink-500/30 transition-all duration-500 relative overflow-hidden bg-gradient-to-br from-surface-900/40 via-surface-900/20 to-pink-950/10">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 rounded-xl bg-pink-500/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-500 border border-pink-500/20">
                    <svg class="w-6 h-6 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                    </svg>
                </div>
                <a href="/Dashboard/SavedCars" class="text-xs font-bold text-pink-400 hover:text-pink-300 uppercase tracking-wider transition-colors">View Wishlist</a>
            </div>
            <div class="text-4xl font-display font-black text-white tracking-tight">@ViewBag.FavoritesCount</div>
            <div class="text-sm font-semibold text-surface-300 mt-2">Saved Vehicles</div>
            <p class="text-xs text-surface-500 mt-1">High-end models saved for future evaluation.</p>
        </div>

        @* Sent Inquiries *@
        <div class="card p-6 group hover:border-primary-500/30 transition-all duration-500 relative overflow-hidden bg-gradient-to-br from-surface-900/40 via-surface-900/20 to-primary-950/10">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 rounded-xl bg-primary-500/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-500 border border-primary-500/20">
                    <svg class="w-6 h-6 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
                    </svg>
                </div>
                <a href="/Dashboard/Messages" class="text-xs font-bold text-primary-400 hover:text-primary-300 uppercase tracking-wider transition-colors">Open Inbox</a>
            </div>
            <div class="text-4xl font-display font-black text-white tracking-tight">@ViewBag.InquiriesCount</div>
            <div class="text-sm font-semibold text-surface-300 mt-2">Active Inquiries</div>
            <p class="text-xs text-surface-500 mt-1">Direct communication channels with the dealership desk.</p>
        </div>
    </div>

    @* ── Quick Actions ── *@
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <a href="/Cars/Browse" class="card-interactive p-6 flex items-center gap-4 hover:border-primary-500/20 bg-gradient-to-r from-surface-900/40 to-surface-900/10">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary-500/15 to-primary-600/5
                        border border-primary-500/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-7 h-7 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-display font-bold text-white mb-1">Browse Premium Inventory</h3>
                <p class="text-sm text-surface-400">Discover 50+ professionally curated sports and luxury vehicles</p>
            </div>
            <svg class="w-5 h-5 text-surface-500 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
        </a>

        <a href="/Cars/Compare" class="card-interactive p-6 flex items-center gap-4 hover:border-accent-500/20 bg-gradient-to-r from-surface-900/40 to-surface-900/10">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-accent-500/15 to-accent-600/5
                        border border-accent-500/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-7 h-7 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-display font-bold text-white mb-1">Spec Comparison Tool</h3>
                <p class="text-sm text-surface-400">Evaluate up to 4 models side-by-side on technical specs</p>
            </div>
            <svg class="w-5 h-5 text-surface-500 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
        </a>
    </div>

    @* ── Recent Activity Feed ── *@
    <div class="card p-6">
        <h3 class="text-lg font-display font-bold text-white mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            Timeline Activity Feed
        </h3>
        <div class="space-y-4">
            @if (!recentActivities.Any())
            {
                <div class="text-center py-12 text-surface-500 text-sm italic">
                    No recent activity recorded yet. Browse the inventory to save favorites or submit inquiries!
                </div>
            }
            else
            {
                @foreach (var activity in recentActivities)
                {
                    var colorClass = "bg-primary-500 shadow-primary-500/20";
                    if (activity.Color == "green") colorClass = "bg-green-500 shadow-green-500/20";
                    else if (activity.Color == "pink") colorClass = "bg-pink-500 shadow-pink-500/20";
                    else if (activity.Color == "accent") colorClass = "bg-accent-500 shadow-accent-500/20";
                    else if (activity.Color == "purple") colorClass = "bg-purple-500 shadow-purple-500/20";

                    <a href="@activity.Link" class="flex items-center gap-4 p-4 rounded-xl hover:bg-white/5 border border-transparent hover:border-surface-800 transition-all duration-300">
                        <div class="w-3 h-3 rounded-full flex-shrink-0 @colorClass shadow-glow-sm"></div>
                        <div class="flex-1">
                            <p class="text-sm font-semibold text-white">@activity.Title</p>
                            <p class="text-xs text-surface-400 mt-1 leading-relaxed">@activity.Description</p>
                        </div>
                        <div class="text-[10px] text-surface-500 font-mono whitespace-nowrap font-semibold uppercase tracking-wider pl-4">
                            @activity.Timestamp.ToLocalTime().ToString("MMM dd, h:mm tt")
                        </div>
                    </a>
                }
            }
        </div>
    </div>
</div>

