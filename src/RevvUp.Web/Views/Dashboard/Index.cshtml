@* ============================================================
   RevvUp — Dashboard Overview
   Welcome page with stat cards and quick actions
   ============================================================ *@
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var userName = ViewData["UserName"]?.ToString() ?? "Racer";
}

<div class="animate-fade-in-up">
    @* ── Welcome Header ── *@
    <div class="mb-8">
        <h1 class="text-3xl font-display font-bold text-white mb-2">
            Hey, @userName! 🏁
        </h1>
        <p class="text-surface-400">Here's what's happening with your cars today.</p>
    </div>

    @* ── Stats Grid ── *@
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        @* Active Listings *@
        <div class="card p-5 group hover:border-primary-500/30 transition-all duration-500">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 rounded-xl bg-primary-500/20 flex items-center justify-center
                            group-hover:scale-110 transition-transform duration-500">
                    <svg class="w-5 h-5 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
                    </svg>
                </div>
                <span class="text-xs text-green-400 font-medium">+2 new</span>
            </div>
            <div class="text-2xl font-display font-bold text-white">3</div>
            <div class="text-sm text-surface-500">Active Listings</div>
        </div>

        @* Views *@
        <div class="card p-5 group hover:border-accent-500/30 transition-all duration-500">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 rounded-xl bg-accent-500/20 flex items-center justify-center
                            group-hover:scale-110 transition-transform duration-500">
                    <svg class="w-5 h-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                </div>
                <span class="text-xs text-green-400 font-medium">↑ 24%</span>
            </div>
            <div class="text-2xl font-display font-bold text-white">1,247</div>
            <div class="text-sm text-surface-500">Total Views</div>
        </div>

        @* Saved *@
        <div class="card p-5 group hover:border-pink-500/30 transition-all duration-500">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 rounded-xl bg-pink-500/20 flex items-center justify-center
                            group-hover:scale-110 transition-transform duration-500">
                    <svg class="w-5 h-5 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                    </svg>
                </div>
            </div>
            <div class="text-2xl font-display font-bold text-white">7</div>
            <div class="text-sm text-surface-500">Saved Cars</div>
        </div>

        @* Messages *@
        <div class="card p-5 group hover:border-green-500/30 transition-all duration-500">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center
                            group-hover:scale-110 transition-transform duration-500">
                    <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
                    </svg>
                </div>
                <span class="w-5 h-5 rounded-full bg-green-500 flex items-center justify-center text-xs text-white font-bold">2</span>
            </div>
            <div class="text-2xl font-display font-bold text-white">5</div>
            <div class="text-sm text-surface-500">Messages</div>
        </div>
    </div>

    @* ── Quick Actions ── *@
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="card-interactive p-6 flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary-500/20 to-primary-600/20
                        border border-primary-500/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-7 h-7 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-display font-bold text-white mb-1">List a New Car</h3>
                <p class="text-sm text-surface-400">Showcase your ride to thousands of buyers</p>
            </div>
            <svg class="w-5 h-5 text-surface-500 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
        </div>

        <div class="card-interactive p-6 flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-accent-500/20 to-accent-600/20
                        border border-accent-500/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-7 h-7 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-display font-bold text-white mb-1">Browse Marketplace</h3>
                <p class="text-sm text-surface-400">Discover amazing deals waiting for you</p>
            </div>
            <svg class="w-5 h-5 text-surface-500 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
        </div>
    </div>

    @* ── Recent Activity (Placeholder) ── *@
    <div class="card p-6">
        <h3 class="text-lg font-display font-bold text-white mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            Recent Activity
        </h3>
        <div class="space-y-3">
            <div class="flex items-center gap-4 p-3 rounded-xl hover:bg-white/5 transition-colors duration-300">
                <div class="w-2 h-2 rounded-full bg-green-400"></div>
                <div class="flex-1">
                    <p class="text-sm text-white">Your <span class="font-semibold">Tesla Model S</span> listing got 12 new views</p>
                    <p class="text-xs text-surface-500">2 hours ago</p>
                </div>
            </div>
            <div class="flex items-center gap-4 p-3 rounded-xl hover:bg-white/5 transition-colors duration-300">
                <div class="w-2 h-2 rounded-full bg-primary-400"></div>
                <div class="flex-1">
                    <p class="text-sm text-white">Someone saved your <span class="font-semibold">BMW M4</span> to favorites</p>
                    <p class="text-xs text-surface-500">5 hours ago</p>
                </div>
            </div>
            <div class="flex items-center gap-4 p-3 rounded-xl hover:bg-white/5 transition-colors duration-300">
                <div class="w-2 h-2 rounded-full bg-accent-400"></div>
                <div class="flex-1">
                    <p class="text-sm text-white">New message from a potential buyer 💬</p>
                    <p class="text-xs text-surface-500">1 day ago</p>
                </div>
            </div>
        </div>
    </div>
</div>
