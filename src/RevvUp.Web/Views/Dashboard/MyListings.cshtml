@model List<RevvUp.Core.Entities.Car>
@{
    ViewData["Title"] = "My Listings";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="animate-fade-in-up">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-display font-bold text-white mb-2">My Listings 🚗</h1>
            <p class="text-surface-400">Manage your active marketplace listings, mark as sold, or remove them.</p>
        </div>
        <a href="/Dashboard/CreateListing" class="btn-primary group" id="mylistings-add-btn">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Add New Car
        </a>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="card p-12 text-center max-w-lg mx-auto">
            <span class="text-5xl block mb-4">🏁</span>
            <h3 class="text-lg font-display font-bold text-white mb-2">You haven't listed any cars yet</h3>
            <p class="text-xs text-surface-500 mb-6">Launch your sports car listing today and get premium buyers instantly.</p>
            <a href="/Dashboard/CreateListing" class="btn-primary">Sell Your Car</a>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var car in Model)
            {
                var isSold = car.Description?.StartsWith("[SOLD]", StringComparison.OrdinalIgnoreCase) == true;
                var cleanDesc = isSold ? car.Description.Substring(7) : car.Description;
                var displayPrice = $"₱{car.Price:N0}";

                <div class="card p-5 flex flex-col sm:flex-row gap-4 group hover:border-primary-500/30 transition-all duration-500 @(isSold ? "opacity-60 hover:opacity-100" : "")">
                    @* Image / Icon Frame *@
                    <div class="w-full sm:w-44 h-28 rounded-xl bg-surface-800 overflow-hidden flex-shrink-0 relative">
                        <img src="@car.ImageUrl" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                        @if (isSold)
                        {
                            <div class="absolute inset-0 bg-surface-950/70 backdrop-blur-sm rounded-xl flex items-center justify-center">
                                <span class="text-sm font-black text-green-400 tracking-wider">SOLD ✓</span>
                            </div>
                        }
                    </div>

                    @* Listing Metadata *@
                    <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-2 mb-1">
                            <h3 class="text-lg font-display font-bold text-white truncate">@car.Year @car.Make @car.Model</h3>
                            @if (isSold)
                            {
                                <span class="badge bg-surface-800 text-surface-400 border border-surface-700/50">Sold</span>
                            }
                            else
                            {
                                <span class="badge bg-green-500/20 text-green-400 border border-green-500/30 animate-pulse">Active</span>
                            }
                        </div>
                        <p class="text-xl font-display font-bold text-gradient mb-2">@displayPrice</p>
                        <p class="text-xs text-surface-500 truncate">
                            @($"{car.Mileage:N0} km") • @car.Transmission • @car.FuelType • @car.BodyType • @car.Location
                        </p>
                    </div>

                    @* Deletion & State Action Form Controls *@
                    <div class="flex sm:flex-col justify-end gap-2 flex-shrink-0">
                        @if (!isSold)
                        {
                            <form action="/Dashboard/MarkSold" method="POST" class="inline">
                                <input type="hidden" name="id" value="@car.Id" />
                                <button type="submit" class="btn-outline btn-sm text-green-400 border-green-500/20 hover:bg-green-500/10 w-full justify-center">
                                    Mark Sold
                                </button>
                            </form>
                        }
                        <form action="/Dashboard/DeleteListing" method="POST" class="inline">
                            <input type="hidden" name="id" value="@car.Id" />
                            <button type="submit" class="btn-ghost btn-sm text-red-400 hover:bg-red-500/10 w-full justify-center">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>
