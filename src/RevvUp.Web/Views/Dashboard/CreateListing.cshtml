@{
    ViewData["Title"] = "Create New Listing";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="animate-fade-in-up" x-data="sellWizard()">
    @* ── Header & Progress Tracker ── *@
    <div class="mb-8">
        <h1 class="text-3xl font-display font-bold text-white mb-2">Sell Your Vehicle 🏎️</h1>
        <p class="text-surface-400">Complete the quick 3-step wizard to showcase your car beautifully.</p>

        @* Step Dots & Progress bar *@
        <div class="relative mt-6 max-w-xl">
            <div class="absolute inset-0 top-1/2 -translate-y-1/2 h-1 bg-surface-800 rounded-full"></div>
            <div class="absolute inset-0 top-1/2 -translate-y-1/2 h-1 bg-primary-500 rounded-full transition-all duration-500"
                 x-bind:style="'width: ' + (step === 1 ? '0%' : step === 2 ? '50%' : '100%')"></div>

            <div class="relative flex justify-between">
                <template x-for="s in [1, 2, 3]">
                    <div class="flex flex-col items-center">
                        <div class="w-8 h-8 rounded-full flex items-center justify-center font-bold text-sm border-2 transition-all duration-500"
                             x-bind:class="step >= s
                                ? 'bg-primary-500 text-white border-primary-500 shadow-glow-sm scale-110'
                                : 'bg-surface-900 text-surface-500 border-surface-700'">
                            <span x-text="s"></span>
                        </div>
                    </div>
                </template>
            </div>
        </div>
    </div>

    @* ── Multi-step Form Frame ── *@
    <form action="/Dashboard/CreateListing" method="POST" class="card max-w-2xl p-8 space-y-6">
        @* ── Step 1: Base Spec ── *@
        <div x-show="step === 1" x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0 translate-x-12"
             x-transition:enter-end="opacity-100 translate-x-0" class="space-y-4">
            <h3 class="text-lg font-display font-bold text-white mb-4">Step 1: Vehicle Identity</h3>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-surface-400 mb-1.5">Brand / Make</label>
                    <input type="text" name="make" required class="input" placeholder="e.g. Porsche" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-surface-400 mb-1.5">Model</label>
                    <input type="text" name="model" required class="input" placeholder="e.g. 911 Carrera" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-surface-400 mb-1.5">Year</label>
                    <input type="number" name="year" required class="input" placeholder="e.g. 2024" min="1900" max="2026" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-surface-400 mb-1.5">Body Type</label>
                    <select name="bodyType" required class="input">
                        <option value="Coupe">Coupe</option>
                        <option value="Sedan">Sedan</option>
                        <option value="SUV">SUV</option>
                        <option value="Hatchback">Hatchback</option>
                        <option value="Convertible">Convertible</option>
                    </select>
                </div>
            </div>
        </div>

        @* ── Step 2: Details & Pricing ── *@
        <div x-show="step === 2" x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0 translate-x-12"
             x-transition:enter-end="opacity-100 translate-x-0" class="space-y-4">
            <h3 class="text-lg font-display font-bold text-white mb-4">Step 2: Specifications & Market Placement</h3>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-surface-400 mb-1.5">Price (PHP)</label>
                    <input type="number" name="price" required class="input" placeholder="e.g. 15800000" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-surface-400 mb-1.5">Mileage (km)</label>
                    <input type="number" name="mileage" required class="input" placeholder="e.g. 4500" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-surface-400 mb-1.5">Transmission</label>
                    <select name="transmission" required class="input">
                        <option value="Auto">Automatic</option>
                        <option value="Manual">Manual</option>
                        <option value="PDK">PDK</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-surface-400 mb-1.5">Fuel Type</label>
                    <select name="fuelType" required class="input">
                        <option value="Gasoline">Gasoline</option>
                        <option value="Diesel">Diesel</option>
                        <option value="Electric">Electric</option>
                        <option value="Hybrid">Hybrid</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-surface-400 mb-1.5">Color</label>
                    <input type="text" name="color" required class="input" placeholder="e.g. Crayon Gray" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-surface-400 mb-1.5">Location</label>
                    <input type="text" name="location" required class="input" placeholder="e.g. Bonifacio Global City" />
                </div>
            </div>
        </div>

        @* ── Step 3: Photos & Visuals ── *@
        <div x-show="step === 3" x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0 translate-x-12"
             x-transition:enter-end="opacity-100 translate-x-0" class="space-y-4">
            <h3 class="text-lg font-display font-bold text-white mb-4">Step 3: Description & Media</h3>

            <div>
                <label class="block text-xs font-semibold text-surface-400 mb-1.5">Description</label>
                <textarea name="description" required class="input h-24" placeholder="Briefly describe what makes your vehicle a masterpiece..."></textarea>
            </div>

            @* Visual drag-and-drop placeholder *@
            <div class="space-y-3">
                <label class="block text-xs font-semibold text-surface-400">Exterior Photography</label>
                <div class="border-2 border-dashed border-surface-800 hover:border-primary-500/50 rounded-2xl p-6 text-center cursor-pointer transition-all duration-300 bg-surface-900/50">
                    <span class="text-3xl mb-2 block">📸</span>
                    <p class="text-xs text-surface-400 font-medium">Drag & drop high-res sports photos here, or click to upload</p>
                    <p class="text-[10px] text-surface-600 mt-1">PNG, JPG up to 10MB each</p>
                </div>
            </div>

            <div>
                <label class="block text-xs font-semibold text-surface-400 mb-1.5">Mock Image URL</label>
                <input type="url" name="imageUrl" class="input" x-model="imageUrl" placeholder="Paste high-res Unsplash image or leave blank for preset" />
                <div class="mt-3 aspect-video rounded-xl overflow-hidden bg-surface-950 border border-surface-800" x-show="imageUrl.length > 0">
                    <img x-bind:src="imageUrl" class="w-full h-full object-cover" />
                </div>
            </div>
        </div>

        <div class="divider"></div>

        @* Wizard Controls *@
        <div class="flex items-center justify-between">
            <button type="button" x-on:click="prev()" x-show="step > 1" class="btn-outline">
                Back
            </button>
            <div x-show="step === 1"></div> @* spacer *@
            
            <button type="button" x-on:click="next()" x-show="step < 3" class="btn-primary">
                Next Step
            </button>
            <button type="submit" x-show="step === 3" class="btn-primary">
                Launch Listing 🚀
            </button>
        </div>
    </form>
</div>

@section Scripts {
<script>
function sellWizard() {
    return {
        step: 1,
        imageUrl: '',
        next() {
            if (this.step < 3) this.step++;
        },
        prev() {
            if (this.step > 1) this.step--;
        }
    };
}
</script>
}
