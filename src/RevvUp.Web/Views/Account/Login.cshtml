@* ============================================================
   RevvUp — Login Page
   Beautiful, modern auth form with playful touches
   ============================================================ *@
@model RevvUp.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Welcome Back";
}

<section class="min-h-screen flex items-center justify-center px-4 pt-20 pb-12">
    @* ── Background Effects ── *@
    <div class="fixed inset-0 z-0 pointer-events-none">
        <div class="absolute top-1/3 -left-32 w-96 h-96 bg-primary-500/8 rounded-full blur-3xl animate-float"></div>
        <div class="absolute bottom-1/4 -right-32 w-80 h-80 bg-accent-500/6 rounded-full blur-3xl animate-float delay-300"></div>
    </div>

    <div class="relative z-10 w-full max-w-md">
        @* ── Logo ── *@
        <div class="text-center mb-8 animate-fade-in-down">
            <a href="/" class="inline-flex items-center gap-3 group mb-4">
                <div class="w-12 h-12 rounded-xl bg-surface-900/50 border border-surface-800/40 p-2
                            flex items-center justify-center shadow-glow-sm
                            group-hover:shadow-glow transition-all duration-500 group-hover:scale-110">
                    <img src="~/images/logo.png" class="w-full h-full object-contain" alt="RevvUp Logo" asp-append-version="true" />
                </div>
                <span class="text-2xl font-display font-bold text-white">Revv<span class="text-gradient">Up</span></span>
            </a>
            <h1 class="text-3xl sm:text-4xl font-display font-bold text-white mb-2">
                Welcome back!
            </h1>
            <p class="text-surface-400">
                Ready to get back behind the wheel? Let's go!
            </p>
        </div>

        @* ── Login Card ── *@
        <div class="card-glass p-8 animate-fade-in-up delay-200 opacity-0">
            @* ── Validation Errors ── *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mb-4 flex items-center gap-3 p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 text-sm"
                     x-data="{ show: true }" x-show="show" x-transition>
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                    </svg>
                    <div class="flex-1">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <p class="text-xs">@error.ErrorMessage</p>
                        }
                    </div>
                    <button x-on:click="show = false" class="ml-auto text-red-500 hover:text-red-300">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            }

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post"
                  x-data="{ loading: false, showPassword: false }"
                  x-on:submit="loading = true">

                @* ── Email ── *@
                <div class="mb-5">
                    <label for="Email" class="block text-sm font-medium text-surface-300 mb-2">
                        Email Address
                    </label>
                    <input asp-for="Email" type="email" id="login-email"
                           class="input" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-red-400 text-xs mt-1"></span>
                </div>

                @* ── Password ── *@
                <div class="mb-5">
                    <label for="Password" class="block text-sm font-medium text-surface-300 mb-2">
                        Password
                    </label>
                    <div class="relative">
                        <input asp-for="Password" id="login-password"
                               x-bind:type="showPassword ? 'text' : 'password'"
                               class="input pr-12" placeholder="••••••••" autocomplete="current-password" />
                        <button type="button" x-on:click="showPassword = !showPassword"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-surface-500 hover:text-white transition-colors p-1">
                            <svg x-show="!showPassword" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                            </svg>
                            <svg x-show="showPassword" x-cloak class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-red-400 text-xs mt-1"></span>
                </div>

                @* ── Remember + Forgot ── *@
                <div class="flex items-center justify-between mb-6">
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <input asp-for="RememberMe" type="checkbox" id="login-remember"
                               class="w-4 h-4 rounded border-surface-600 bg-surface-800 text-primary-500
                                      focus:ring-primary-500/50 focus:ring-offset-0 cursor-pointer" />
                        <span class="text-sm text-surface-400 group-hover:text-surface-300 transition-colors">
                            Remember me
                        </span>
                    </label>
                    <a href="#" class="text-sm text-primary-400 hover:text-primary-300 transition-colors">
                        Forgot password?
                    </a>
                </div>

                @* ── Submit ── *@
                <button type="submit" id="login-submit"
                        class="btn-primary w-full btn-lg group"
                        x-bind:disabled="loading">
                    <template x-if="!loading">
                        <span class="flex items-center justify-center gap-2">
                            Sign In
                            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                            </svg>
                        </span>
                    </template>
                    <template x-if="loading">
                        <span class="flex items-center justify-center gap-2">
                            <svg class="w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none">
                                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="30 70" />
                            </svg>
                            Revving up...
                        </span>
                    </template>
                </button>
            </form>

        </div>

        @* ── Register Link ── *@
        <p class="text-center mt-6 text-surface-400 text-sm animate-fade-in-up delay-400 opacity-0">
            New to RevvUp?
            <a asp-action="Register" class="text-primary-400 font-semibold hover:text-primary-300 transition-colors">
                Create an account →
            </a>
        </p>
    </div>
</section>
