@* ============================================================
   RevvUp — Profile Page
   Edit user profile with elegant form
   ============================================================ *@
@model RevvUp.Web.Models.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@* ── Success Toast ── *@
@if (TempData["SuccessMessage"] != null)
{
    <div x-data="{ show: true }"
         x-show="show"
         x-init="setTimeout(() => show = false, 4000)"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="fixed top-24 right-6 z-50 flex items-center gap-3 px-5 py-3 rounded-xl
                bg-green-500/20 border border-green-500/30 text-green-400 shadow-elevated backdrop-blur-xl">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <span class="text-sm font-medium">@TempData["SuccessMessage"]</span>
    </div>
}

<div class="animate-fade-in-up">
    @* ── Header ── *@
    <div class="mb-8">
        <h1 class="text-3xl font-display font-bold text-white mb-2">My Profile</h1>
        <p class="text-surface-400">Customize your RevvUp identity</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        @* ── Profile Card (Left) ── *@
        <div class="lg:col-span-1">
            <div class="card p-6 text-center">
                @* ── Avatar ── *@
                <div class="relative inline-block mb-4 group cursor-pointer"
                     x-data="{ 
                         avatarUrl: '@Model.AvatarUrl',
                         displayName: '@Model.DisplayName',
                         uploadAvatar(event) {
                             const file = event.target.files[0];
                             if (!file) return;
                             
                             const formData = new FormData();
                             formData.append('avatarFile', file);
                             
                             fetch('/Account/UploadAvatar', {
                                 method: 'POST',
                                 body: formData,
                                 headers: {
                                     'RequestVerificationToken': document.querySelector('input[name=__RequestVerificationToken]').value
                                 }
                             })
                             .then(response => {
                                 if (response.ok) return response.json();
                                 return response.text().then(text => { throw new Error(text) });
                             })
                             .then(data => {
                                 this.avatarUrl = data.avatarUrl;
                                 window.location.reload();
                             })
                             .catch(error => {
                                 alert('Upload failed: ' + error.message);
                             });
                         },
                         deleteAvatar() {
                             if (!confirm('Are you sure you want to delete your profile picture?')) return;
                             
                             fetch('/Account/DeleteAvatar', {
                                 method: 'POST',
                                 headers: {
                                     'RequestVerificationToken': document.querySelector('input[name=__RequestVerificationToken]').value
                                 }
                             })
                             .then(response => {
                                 if (response.ok) {
                                     this.avatarUrl = '';
                                     window.location.reload();
                                 } else {
                                     alert('Delete failed.');
                                 }
                             });
                         }
                     }">
                    
                    <input type="file" id="avatarFileInput" accept="image/jpeg,image/png,image/jpg" class="hidden" x-on:change="uploadAvatar" />
                    
                    <div x-on:click="document.getElementById('avatarFileInput').click()"
                         class="w-24 h-24 rounded-full overflow-hidden border-4 border-surface-800 bg-surface-900 shadow-glow-sm flex items-center justify-center relative">
                        
                        <template x-if="avatarUrl">
                            <img :src="avatarUrl" alt="Avatar" class="w-full h-full object-cover" />
                        </template>
                        
                        <template x-if="!avatarUrl">
                            <div class="w-full h-full bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center text-3xl font-display font-bold text-white">
                                @(Model.DisplayName.Length > 0 ? Model.DisplayName[0].ToString().ToUpper() : "R")
                            </div>
                        </template>

                        <!-- Hover overlay -->
                        <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center text-white text-[10px] font-semibold">
                            <svg class="w-5 h-5 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
                            </svg>
                            Update Photo
                        </div>
                    </div>

                    <!-- Active Indicator Dot -->
                    <div class="absolute bottom-0 right-0 w-6 h-6 rounded-full bg-green-500 border-2 border-surface-900 flex items-center justify-center shadow-glow-sm pointer-events-none">
                        <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                    </div>
                </div>

                <div x-show="Model.AvatarUrl != null && Model.AvatarUrl != ''" class="mb-4" x-cloak>
                    <button type="button" onclick="document.getElementById('avatarFileInput').dispatchEvent(new CustomEvent('delete-avatar-trigger'))"
                            x-on:click="deleteAvatar"
                            class="text-xs font-semibold text-red-400 hover:text-red-300 transition-colors flex items-center justify-center gap-1.5 mx-auto py-1 px-3 bg-red-500/10 hover:bg-red-500/20 border border-red-500/20 rounded-lg">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                        </svg>
                        Remove Photo
                    </button>
                </div>

                <h3 class="text-xl font-display font-bold text-white mb-1">@Model.DisplayName</h3>
                <p class="text-surface-400 text-sm mb-4">@Model.Email</p>

                <span class="badge-primary mb-4">Buyer Profile</span>

                <div class="divider my-4"></div>

                @* ── Stats ── *@
                <div class="grid grid-cols-2 gap-4">
                    <div class="text-center">
                        <div class="text-2xl font-display font-bold text-white">@(ViewBag.FavoritesCount ?? 0)</div>
                        <div class="text-xs text-surface-500">Saved Vehicles</div>
                    </div>
                    <div class="text-center">
                        <div class="text-2xl font-display font-bold text-white">@(ViewBag.InquiriesCount ?? 0)</div>
                        <div class="text-xs text-surface-500">Inquiries Sent</div>
                    </div>
                </div>

                <div class="divider my-4"></div>
                <p class="text-xs text-surface-500">
                    Member since @Model.JoinedAt.ToString("MMMM yyyy")
                </p>
            </div>
        </div>

        @* ── Edit Form (Right) ── *@
        <div class="lg:col-span-2">
            <div class="card p-8">
                <h3 class="text-lg font-display font-bold text-white mb-6 flex items-center gap-2">
                    <svg class="w-5 h-5 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                    </svg>
                    Edit Profile
                </h3>

                <form asp-action="Profile" method="post" x-data="{ loading: false }" x-on:submit="loading = true">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
                        <div>
                            <label class="block text-sm font-medium text-surface-300 mb-2">Display Name</label>
                            <input asp-for="DisplayName" class="input" />
                            <span asp-validation-for="DisplayName" class="text-red-400 text-xs mt-1"></span>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-surface-300 mb-2">Email</label>
                            <input asp-for="Email" class="input opacity-60 cursor-not-allowed" readonly />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
                        <div>
                            <label class="block text-sm font-medium text-surface-300 mb-2">Location</label>
                            <input asp-for="Location" class="input" placeholder="Metro Manila" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-surface-300 mb-2">Phone</label>
                            <input asp-for="PhoneNumber" class="input" placeholder="+63 912 345 6789" />
                        </div>
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium text-surface-300 mb-2">Bio</label>
                        <textarea asp-for="Bio" rows="3" class="input resize-none"
                                  placeholder="Tell the world about your love for cars..."></textarea>
                        <span asp-validation-for="Bio" class="text-red-400 text-xs mt-1"></span>
                    </div>

                    <div class="flex items-center justify-end gap-3">
                        <a asp-controller="Dashboard" asp-action="Index" class="btn-ghost">Cancel</a>
                        <button type="submit" class="btn-primary group" x-bind:disabled="loading">
                            <template x-if="!loading">
                                <span class="flex items-center gap-2">
                                    Save Changes
                                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                                    </svg>
                                </span>
                            </template>
                            <template x-if="loading">
                                <span class="flex items-center gap-2">
                                    <svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none">
                                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="30 70" />
                                    </svg>
                                    Saving...
                                </span>
                            </template>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
