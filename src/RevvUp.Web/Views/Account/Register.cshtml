@* ============================================================
   RevvUp — Register Page
   Fun, modern registration with playful copy
   ============================================================ *@
@model RevvUp.Web.Models.RegisterViewModel
@{
    ViewData["Title"] = "Join the Ride";
}

<section class="min-h-screen flex items-center justify-center px-4 pt-20 pb-12">
    @* ── Background Effects ── *@
    <div class="fixed inset-0 z-0 pointer-events-none">
        <div class="absolute top-1/4 -right-32 w-96 h-96 bg-accent-500/8 rounded-full blur-3xl animate-float"></div>
        <div class="absolute bottom-1/3 -left-32 w-80 h-80 bg-primary-500/6 rounded-full blur-3xl animate-float delay-300"></div>
    </div>

    <div class="relative z-10 w-full max-w-md">
        @* ── Logo ── *@
        <div class="text-center mb-8 animate-fade-in-down">
            <a href="/" class="inline-flex items-center gap-3 group mb-4">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary-500 to-primary-700
                            flex items-center justify-center shadow-glow-sm
                            group-hover:shadow-glow transition-all duration-500 group-hover:scale-110">
                    <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
                <span class="text-2xl font-display font-bold text-white">Revv<span class="text-gradient">Up</span></span>
            </a>
            <h1 class="text-3xl sm:text-4xl font-display font-bold text-white mb-2">
                Join the ride! 🚀
            </h1>
            <p class="text-surface-400">
                Create your account and start your automotive adventure.
            </p>
        </div>

        @* ── Register Card ── *@
        <div class="card-glass p-8 animate-fade-in-up delay-200 opacity-0">
            @* ── Validation Errors ── *@
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div class="mb-4 p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 text-sm"
                     x-data="{ show: true }" x-show="show" x-transition>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                        </svg>
                        <div>
                            <div asp-validation-summary="All"></div>
                        </div>
                        <button x-on:click="show = false" class="ml-auto text-red-500 hover:text-red-300 flex-shrink-0">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                </div>
            }

            <form asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post"
                  x-data="{ loading: false, showPassword: false, isDealer: false }"
                  x-on:submit="loading = true">

                @* ── Display Name ── *@
                <div class="mb-5">
                    <label for="DisplayName" class="block text-sm font-medium text-surface-300 mb-2">
                        😎 Your Name
                    </label>
                    <input asp-for="DisplayName" type="text" id="register-name"
                           class="input" placeholder="Speed Racer" autocomplete="name" />
                    <span asp-validation-for="DisplayName" class="text-red-400 text-xs mt-1"></span>
                </div>

                @* ── Email ── *@
                <div class="mb-5">
                    <label for="Email" class="block text-sm font-medium text-surface-300 mb-2">
                        📧 Email Address
                    </label>
                    <input asp-for="Email" type="email" id="register-email"
                           class="input" placeholder="speed@revvup.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-red-400 text-xs mt-1"></span>
                </div>

                @* ── Password ── *@
                <div class="mb-5">
                    <label for="Password" class="block text-sm font-medium text-surface-300 mb-2">
                        🔒 Password
                    </label>
                    <div class="relative">
                        <input asp-for="Password" id="register-password"
                               x-bind:type="showPassword ? 'text' : 'password'"
                               class="input pr-12" placeholder="Min 8 characters" autocomplete="new-password" />
                        <button type="button" x-on:click="showPassword = !showPassword"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-surface-500 hover:text-white transition-colors p-1">
                            <svg x-show="!showPassword" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                            </svg>
                            <svg x-show="showPassword" x-cloak class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-red-400 text-xs mt-1"></span>
                </div>

                @* ── Confirm Password ── *@
                <div class="mb-5">
                    <label for="ConfirmPassword" class="block text-sm font-medium text-surface-300 mb-2">
                        🔒 Confirm Password
                    </label>
                    <input asp-for="ConfirmPassword" type="password" id="register-confirm"
                           class="input" placeholder="••••••••" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-red-400 text-xs mt-1"></span>
                </div>

                @* ── Dealer Toggle ── *@
                <div class="mb-6 p-4 rounded-xl border transition-all duration-300 cursor-pointer"
                     x-bind:class="isDealer
                        ? 'bg-accent-500/10 border-accent-500/30'
                        : 'bg-surface-800/50 border-surface-700/30 hover:border-surface-600'"
                     x-on:click="isDealer = !isDealer">
                    <label class="flex items-center gap-3 cursor-pointer">
                        <input asp-for="IsDealer" type="checkbox" x-model="isDealer" id="register-dealer"
                               class="sr-only" />
                        <div class="w-10 h-6 rounded-full transition-all duration-300 relative"
                             x-bind:class="isDealer ? 'bg-accent-500' : 'bg-surface-600'">
                            <div class="w-4 h-4 rounded-full bg-white absolute top-1 transition-all duration-300"
                                 x-bind:class="isDealer ? 'left-5' : 'left-1'"></div>
                        </div>
                        <div>
                            <span class="text-sm font-medium text-white">I'm a dealer 🏪</span>
                            <p class="text-xs text-surface-500 mt-0.5">Get access to dealer tools & bulk listing features</p>
                        </div>
                    </label>
                </div>

                @* ── Submit ── *@
                <button type="submit" id="register-submit"
                        class="btn-accent w-full btn-lg group"
                        x-bind:disabled="loading">
                    <template x-if="!loading">
                        <span class="flex items-center justify-center gap-2">
                            Create Account
                            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z" />
                            </svg>
                        </span>
                    </template>
                    <template x-if="loading">
                        <span class="flex items-center justify-center gap-2">
                            <svg class="w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none">
                                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="30 70" />
                            </svg>
                            Starting your engine...
                        </span>
                    </template>
                </button>
            </form>
        </div>

        @* ── Login Link ── *@
        <p class="text-center mt-6 text-surface-400 text-sm animate-fade-in-up delay-400 opacity-0">
            Already have an account?
            <a asp-action="Login" class="text-primary-400 font-semibold hover:text-primary-300 transition-colors">
                Sign in →
            </a>
        </p>
    </div>
</section>
