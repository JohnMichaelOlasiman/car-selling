@* ============================================================
   RevvUp — Main Layout
   Premium dark-mode automotive platform
   Uses: Tailwind CSS 3, Alpine.js, HTMX
   ============================================================ *@
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="RevvUp — The most exciting way to buy and sell cars. Premium automotive marketplace with stunning visuals and delightful experience." />
    <meta name="theme-color" content="#020617" />
    <title>@ViewData["Title"] — RevvUp</title>

    <!-- Fonts: Inter (body) + Outfit (display) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Tailwind CSS (compiled output) -->
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- Alpine.js — lightweight reactivity -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <!-- HTMX — HTML over the wire -->
    <script src="https://unpkg.com/htmx.org@1.9.12" integrity="sha384-ujb1lZYygJmzgSwvvUDxLNsIJMxPqntJtGJSVCshbEDdFmeU3tPqalSDlXGYxN5K" crossorigin="anonymous"></script>
</head>

<body class="min-h-screen flex flex-col overflow-x-hidden bg-surface-950 text-surface-200"
      x-data="{ mobileMenuOpen: false, compareCount: 0, compareLink: '/Cars/Compare', favoritesCount: 0, updateCompare() { const ids = JSON.parse(localStorage.getItem('compareCars') || '[]'); this.compareCount = ids.length; this.compareLink = ids.length > 0 ? '/Cars/Compare?ids=' + ids.join(',') : '/Cars/Compare'; }, updateFavorites() { this.favoritesCount = JSON.parse(localStorage.getItem('likedCars') || '[]').length; } }"
      x-init="updateCompare(); updateFavorites(); window.addEventListener('storage', () => { updateCompare(); updateFavorites(); }); setInterval(() => { updateCompare(); updateFavorites(); }, 1000);"
      x-on:keydown.escape="mobileMenuOpen = false">

    @* ── NAVBAR ── *@
    <header class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
            x-data="{ scrolled: false }"
            x-on:scroll.window="scrolled = (window.scrollY > 50)"
            x-bind:class="scrolled
                ? 'bg-surface-950/90 backdrop-blur-xl border-b border-surface-800/50 shadow-elevated'
                : 'bg-transparent'">

        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-18">

                @* ── Logo ── *@
                <a href="/" class="flex items-center gap-3 group" id="nav-logo">
                    <div class="relative">
                        <!-- Logo icon — stylized speedometer/steering wheel -->
                        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary-500 to-primary-700
                                    flex items-center justify-center
                                    shadow-glow-sm group-hover:shadow-glow
                                    transition-all duration-500 group-hover:scale-110 group-hover:rotate-6">
                            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M13 10V3L4 14h7v7l9-11h-7z" />
                            </svg>
                        </div>
                        <!-- Glow ring -->
                        <div class="absolute -inset-1 rounded-xl bg-primary-500/20 blur-sm
                                    opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    </div>
                    <span class="text-2xl font-display font-bold text-white tracking-tight">
                        Revv<span class="text-gradient">Up</span>
                    </span>
                </a>

                @* ── Desktop Navigation ── *@
                <div class="hidden md:flex items-center gap-1" id="nav-desktop-menu">
                    <a href="/" class="nav-link">Home</a>
                    <a href="/Cars/Browse" class="nav-link">Browse Cars</a>
                    <a href="/Dashboard/MyListings" class="nav-link">Sell Your Car</a>
                    <a href="#" class="nav-link">How It Works</a>
                    <a href="#" class="nav-link">About</a>
                </div>

                @* ── Desktop Actions ── *@
                <div class="hidden md:flex items-center gap-3" id="nav-actions">
                    @* ── Global Compare Link ── *@
                    <a x-bind:href="compareLink"
                       class="btn-ghost btn-sm relative"
                       title="Compare Vehicles">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                        </svg>
                        <span x-show="compareCount > 0" x-text="compareCount"
                              class="absolute -top-1 -right-1 w-4 h-4 rounded-full bg-accent-500 text-white text-[10px] font-bold flex items-center justify-center animate-pulse"></span>
                    </a>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @* ── Favorites Button ── *@
                        <a asp-controller="Dashboard" asp-action="SavedCars"
                           class="btn-ghost btn-sm relative">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                            </svg>
                            <span x-show="favoritesCount > 0" x-text="favoritesCount"
                                  class="absolute -top-1 -right-1 w-4 h-4 rounded-full bg-primary-500 text-white text-[10px] font-bold flex items-center justify-center"></span>
                        </a>

                        @* ── Notifications Dropdown ── *@
                        <div class="relative" x-data="{ notificationsOpen: false, notifications: [
                            { id: 1, title: '🏎️ Welcome to RevvUp!', body: 'Post your first listing today and rev up your sell speed!' },
                            { id: 2, title: '🔒 Access Granted', body: 'You are now an authorized racer in the community.' }
                        ] }" x-on:click.away="notificationsOpen = false">
                            <button x-on:click="notificationsOpen = !notificationsOpen"
                                    class="btn-ghost btn-sm relative"
                                    title="Notifications">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a9.04 9.04 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0M3.124 7.5A8.969 8.969 0 0 1 5.292 3m13.416 0a8.969 8.969 0 0 1 2.168 4.5M21 12a9 9 0 1 1-18 0c0-1.79.482-3.47 1.328-4.921M21 12H3m0 0a9 9 0 0 1 9-9" />
                                </svg>
                                <span x-show="notifications.length > 0" x-text="notifications.length"
                                      class="absolute -top-1 -right-1 w-4 h-4 rounded-full bg-accent-500 text-white text-[10px] font-bold flex items-center justify-center animate-pulse"></span>
                            </button>

                            @* Dropdown Panel *@
                            <div x-show="notificationsOpen" x-cloak
                                 x-transition:enter="transition ease-out duration-200"
                                 x-transition:enter-start="opacity-0 scale-95 -translate-y-2"
                                 x-transition:enter-end="opacity-100 scale-100 translate-y-0"
                                 x-transition:leave="transition ease-in duration-150"
                                 x-transition:leave-start="opacity-100 scale-100"
                                 x-transition:leave-end="opacity-0 scale-95"
                                 class="absolute right-0 mt-2 w-80 bg-surface-900 border border-surface-800 rounded-2xl shadow-elevated p-3 z-50 space-y-2">
                                <div class="flex items-center justify-between px-2 pb-2 border-b border-surface-800/80">
                                    <h4 class="text-sm font-semibold text-white">Notifications</h4>
                                    <button x-on:click="notifications = []" class="text-xs text-primary-400 hover:underline">Clear all</button>
                                </div>
                                <div class="max-h-60 overflow-y-auto space-y-2 pr-1">
                                    <template x-for="item in notifications" :key="item.id">
                                        <div class="p-2.5 rounded-xl bg-surface-950/50 hover:bg-white/5 transition-colors border border-surface-800/40">
                                            <p class="text-xs font-semibold text-white" x-text="item.title"></p>
                                            <p class="text-[10px] text-surface-400 mt-1" x-text="item.body"></p>
                                        </div>
                                    </template>
                                    <div x-show="notifications.length === 0" class="text-center py-6 text-xs text-surface-500 italic">
                                        All caught up! 🏁
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* ── Profile Dropdown ── *@
                        <div class="relative" x-data="{ profileOpen: false }"
                             x-on:click.away="profileOpen = false">
                            <button x-on:click="profileOpen = !profileOpen"
                                    class="flex items-center gap-2 px-2 py-1.5 rounded-xl
                                           hover:bg-white/5 transition-all duration-300"
                                    id="nav-profile-btn">
                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-primary-500 to-accent-500
                                            flex items-center justify-center text-xs font-bold text-white
                                            ring-2 ring-surface-700 hover:ring-primary-500/50 transition-all duration-300">
                                    @(User.Identity.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "R")
                                </div>
                                <svg class="w-4 h-4 text-surface-400 transition-transform duration-300"
                                     x-bind:class="profileOpen ? 'rotate-180' : ''"
                                     fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                                </svg>
                            </button>

                            @* ── Dropdown Panel ── *@
                            <div x-show="profileOpen" x-cloak
                                 x-transition:enter="transition ease-out duration-200"
                                 x-transition:enter-start="opacity-0 scale-95 -translate-y-2"
                                 x-transition:enter-end="opacity-100 scale-100 translate-y-0"
                                 x-transition:leave="transition ease-in duration-150"
                                 x-transition:leave-start="opacity-100 scale-100"
                                 x-transition:leave-end="opacity-0 scale-95 -translate-y-2"
                                 class="absolute right-0 top-full mt-2 w-64 card-glass p-2 z-50"
                                 id="nav-profile-dropdown">

                                @* ── User Info ── *@
                                <div class="px-3 py-3 mb-1">
                                    <p class="text-sm font-semibold text-white truncate">@User.Identity.Name</p>
                                    <p class="text-xs text-surface-500">Car Enthusiast 🏎️</p>
                                </div>
                                <div class="h-px bg-surface-700/50 mx-2 mb-1"></div>

                                @* ── Links ── *@
                                <a asp-controller="Dashboard" asp-action="Index"
                                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-surface-300
                                          hover:text-white hover:bg-white/5 transition-all duration-300">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z" />
                                    </svg>
                                    Dashboard
                                </a>
                                <a asp-controller="Dashboard" asp-action="MyListings"
                                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-surface-300
                                          hover:text-white hover:bg-white/5 transition-all duration-300">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
                                    </svg>
                                    My Listings
                                </a>
                                <a asp-controller="Account" asp-action="Profile"
                                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-surface-300
                                          hover:text-white hover:bg-white/5 transition-all duration-300">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                                    </svg>
                                    Profile
                                </a>

                                <div class="h-px bg-surface-700/50 mx-2 my-1"></div>

                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit"
                                            class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm w-full
                                                   text-red-400 hover:text-red-300 hover:bg-red-500/10 transition-all duration-300">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                                        </svg>
                                        Sign Out
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <button class="btn-ghost btn-sm">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                            </svg>
                        </button>
                        <a asp-controller="Account" asp-action="Login" class="btn-primary btn-sm" id="nav-signin-btn">
                            Sign In
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                            </svg>
                        </a>
                    }
                </div>

                @* ── Mobile Menu Button ── *@
                <button class="md:hidden relative w-10 h-10 flex items-center justify-center
                               rounded-xl hover:bg-white/10 transition-colors duration-300"
                        x-on:click="mobileMenuOpen = !mobileMenuOpen"
                        id="nav-mobile-toggle"
                        aria-label="Toggle mobile menu">
                    <div class="w-6 flex flex-col gap-1.5">
                        <span class="block h-0.5 bg-white rounded-full transition-all duration-500 origin-center"
                              x-bind:class="mobileMenuOpen ? 'rotate-45 translate-y-2' : ''"></span>
                        <span class="block h-0.5 bg-white rounded-full transition-all duration-300"
                              x-bind:class="mobileMenuOpen ? 'opacity-0 scale-x-0' : ''"></span>
                        <span class="block h-0.5 bg-white rounded-full transition-all duration-500 origin-center"
                              x-bind:class="mobileMenuOpen ? '-rotate-45 -translate-y-2' : ''"></span>
                    </div>
                </button>
            </div>
        </nav>

        @* ── Mobile Menu Panel ── *@
        <div class="md:hidden overflow-hidden transition-all duration-500 ease-out"
             x-show="mobileMenuOpen"
             x-transition:enter="transition ease-out duration-400"
             x-transition:enter-start="opacity-0 -translate-y-4"
             x-transition:enter-end="opacity-100 translate-y-0"
             x-transition:leave="transition ease-in duration-300"
             x-transition:leave-start="opacity-100 translate-y-0"
             x-transition:leave-end="opacity-0 -translate-y-4"
             x-cloak
             id="nav-mobile-menu">

            <div class="bg-surface-950/98 backdrop-blur-2xl border-t border-surface-800/50 px-4 pb-6 pt-2">
                <div class="space-y-1">
                    <a href="/" class="block px-4 py-3 rounded-xl text-white font-medium bg-white/5
                                      transition-all duration-300 hover:bg-white/10 hover:pl-6">
                        🏠 Home
                    </a>
                    <a href="/Cars/Browse" class="block px-4 py-3 rounded-xl text-surface-300 font-medium
                                      transition-all duration-300 hover:bg-white/5 hover:text-white hover:pl-6">
                        🚗 Browse Cars
                    </a>
                    <a x-bind:href="compareLink" class="block px-4 py-3 rounded-xl text-surface-300 font-medium
                                      transition-all duration-300 hover:bg-white/5 hover:text-white hover:pl-6 flex items-center justify-between">
                        <span>⚖️ Compare Vehicles</span>
                        <span x-show="compareCount > 0" x-text="compareCount" class="px-2 py-0.5 rounded-full bg-accent-500 text-white text-[10px] font-bold"></span>
                    </a>
                    <a href="/Dashboard/MyListings" class="block px-4 py-3 rounded-xl text-surface-300 font-medium
                                      transition-all duration-300 hover:bg-white/5 hover:text-white hover:pl-6">
                        💰 Sell Your Car
                    </a>
                    <a href="#" class="block px-4 py-3 rounded-xl text-surface-300 font-medium
                                      transition-all duration-300 hover:bg-white/5 hover:text-white hover:pl-6">
                        ✨ How It Works
                    </a>
                    <a href="#" class="block px-4 py-3 rounded-xl text-surface-300 font-medium
                                      transition-all duration-300 hover:bg-white/5 hover:text-white hover:pl-6">
                        ℹ️ About
                    </a>
                </div>
                <div class="divider my-4"></div>
                <div class="flex gap-3">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Dashboard" asp-action="Index" class="btn-primary flex-1 justify-center">Dashboard</a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="flex-1">
                            <button type="submit" class="btn-outline w-full justify-center">Sign Out</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn-outline flex-1 justify-center">Sign In</a>
                        <a asp-controller="Account" asp-action="Register" class="btn-primary flex-1 justify-center">Join Free</a>
                    }
                </div>
            </div>
        </div>
    </header>

    @* ── MAIN CONTENT ── *@
    <main class="flex-1">
        @RenderBody()
    </main>

    @* ── FOOTER ── *@
    <footer class="relative mt-auto border-t border-surface-800/50 bg-surface-950">
        <!-- Gradient line at top -->
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-500/50 to-transparent"></div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">

                @* ── Brand Column ── *@
                <div class="lg:col-span-1">
                    <a href="/" class="inline-flex items-center gap-3 group mb-6">
                        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary-500 to-primary-700
                                    flex items-center justify-center shadow-glow-sm
                                    group-hover:shadow-glow transition-all duration-500">
                            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                            </svg>
                        </div>
                        <span class="text-xl font-display font-bold text-white">
                            Revv<span class="text-gradient">Up</span>
                        </span>
                    </a>
                    <p class="text-surface-400 text-sm leading-relaxed mb-6">
                        The most exciting way to buy and sell cars.
                        Premium experience, zero hassle, pure automotive joy.
                    </p>
                    <div class="flex gap-3">
                        <!-- Social icons -->
                        <a href="#" class="w-10 h-10 rounded-xl bg-surface-800/80 flex items-center justify-center
                                         text-surface-400 hover:text-white hover:bg-primary-600
                                         transition-all duration-300 hover:-translate-y-1" aria-label="Twitter">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                        </a>
                        <a href="#" class="w-10 h-10 rounded-xl bg-surface-800/80 flex items-center justify-center
                                         text-surface-400 hover:text-white hover:bg-primary-600
                                         transition-all duration-300 hover:-translate-y-1" aria-label="Instagram">
