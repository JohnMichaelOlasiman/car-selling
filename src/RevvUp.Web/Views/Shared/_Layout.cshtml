@* ============================================================
   RevvUp — Main Layout
   Premium dark-mode automotive platform
   Uses: Tailwind CSS 3, Alpine.js, HTMX
   ============================================================ *@
@inject Microsoft.AspNetCore.Identity.UserManager<RevvUp.Core.Entities.ApplicationUser> UserManager
@{
    RevvUp.Core.Entities.ApplicationUser? currentUser = null;
    if (User.Identity?.IsAuthenticated == true)
    {
        currentUser = await UserManager.GetUserAsync(User);
    }
    
    string currentPath = Context.Request.Path.Value ?? "/";
    bool isHomeActive = currentPath == "/" || currentPath.Equals("/Home", StringComparison.OrdinalIgnoreCase) || currentPath.Equals("/Home/Index", StringComparison.OrdinalIgnoreCase);
    bool isBrowseActive = currentPath.StartsWith("/Cars", StringComparison.OrdinalIgnoreCase)
                       && !currentPath.StartsWith("/Cars/Compare", StringComparison.OrdinalIgnoreCase);
    bool isAboutActive = currentPath.StartsWith("/Home/About", StringComparison.OrdinalIgnoreCase);
    bool isLoginActive = currentPath.StartsWith("/Account/Login", StringComparison.OrdinalIgnoreCase);
    bool isRegisterActive = currentPath.StartsWith("/Account/Register", StringComparison.OrdinalIgnoreCase);

    var homeMobileClass = isHomeActive
        ? "block px-4 py-3 rounded-xl text-white font-medium bg-white/5 transition-all duration-300 hover:bg-white/10 hover:pl-6"
        : "block px-4 py-3 rounded-xl text-surface-300 font-medium transition-all duration-300 hover:bg-white/5 hover:text-white hover:pl-6";

    var browseMobileClass = isBrowseActive
        ? "block px-4 py-3 rounded-xl text-white font-medium bg-white/5 transition-all duration-300 hover:bg-white/10 hover:pl-6"
        : "block px-4 py-3 rounded-xl text-surface-300 font-medium transition-all duration-300 hover:bg-white/5 hover:text-white hover:pl-6";

    var aboutMobileClass = isAboutActive
        ? "block px-4 py-3 rounded-xl text-white font-medium bg-white/5 transition-all duration-300 hover:bg-white/10 hover:pl-6"
        : "block px-4 py-3 rounded-xl text-surface-300 font-medium transition-all duration-300 hover:bg-white/5 hover:text-white hover:pl-6";
}
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="RevvUp — The most exciting way to buy and sell cars. Premium automotive marketplace with stunning visuals and delightful experience." />
    <meta name="theme-color" content="#020617" />
    <title>@ViewData["Title"] — RevvUp</title>

    <!-- Fonts: Inter (body) + Outfit (display) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Tailwind CSS (compiled output) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- SignalR client library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

    <!-- Alpine.js — lightweight reactivity -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <!-- HTMX — HTML over the wire -->
    <script defer src="https://cdn.jsdelivr.net/npm/htmx.org@1.9.12/dist/htmx.min.js"></script>
</head>

<body class="@(ViewData["FitToScreen"] as bool? == true ? "lg:h-screen lg:overflow-hidden min-h-screen overflow-x-hidden" : "min-h-screen overflow-x-hidden") flex flex-col bg-surface-950 text-surface-200"
      x-data="{ mobileMenuOpen: false, compareCount: 0, compareLink: '/Cars/Compare', favoritesCount: 0, updateCompare() { const ids = JSON.parse(localStorage.getItem('compareCars') || '[]'); this.compareCount = ids.length; this.compareLink = ids.length > 0 ? '/Cars/Compare?ids=' + ids.join(',') : '/Cars/Compare'; }, updateFavorites() { this.favoritesCount = JSON.parse(localStorage.getItem('likedCars') || '[]').length; } }"
      x-init="updateCompare(); updateFavorites(); window.addEventListener('storage', () => { updateCompare(); updateFavorites(); }); setInterval(() => { updateCompare(); updateFavorites(); }, 1000);"
      x-on:keydown.escape="mobileMenuOpen = false">

    @if (User.Identity?.IsAuthenticated == true)
    {
        var currentUserId = UserManager.GetUserId(User);
        var favoriteService = Context.RequestServices.GetService<RevvUp.Application.Interfaces.ICarService>();
        if (favoriteService != null && !string.IsNullOrEmpty(currentUserId))
        {
            var favList = await favoriteService.GetFavoritesByUserIdAsync(currentUserId);
            var favIds = favList.Select(f => f.CarId.ToString().ToLower()).ToList();
            var favIdsJson = System.Text.Json.JsonSerializer.Serialize(favIds);
            <script>
                localStorage.setItem('likedCars', '@Html.Raw(favIdsJson)');
            </script>
        }
    }

    @* ── NAVBAR ── *@
    <header class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
            x-data="{ scrolled: false }"
            x-on:scroll.window="scrolled = (window.scrollY > 50)"
            x-bind:class="scrolled
                ? 'bg-surface-950/90 backdrop-blur-xl border-b border-surface-800/50 shadow-elevated'
                : 'bg-transparent'">

        <nav class="premium-container">
            <div class="flex items-center justify-between h-18">

                @* ── Logo ── *@
                <a href="/" class="flex items-center gap-3 group" id="nav-logo">
                    <div class="relative">
                        <!-- New Logo image -->
                        <div class="w-10 h-10 rounded-xl bg-surface-900/50 border border-surface-800/40 p-1.5
                                    flex items-center justify-center
                                    shadow-glow-sm group-hover:shadow-glow
                                    transition-all duration-500 group-hover:scale-110 group-hover:rotate-6">
                            <img src="~/images/logo.png" class="w-full h-full object-contain" alt="RevvUp Logo" asp-append-version="true" />
                        </div>
                        <!-- Glow ring -->
                        <div class="absolute -inset-1 rounded-xl bg-primary-500/20 blur-sm
                                    opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    </div>
                    <span class="text-2xl font-display font-bold text-white tracking-tight">
                        Revv<span class="text-gradient">Up</span>
                    </span>
                </a>

                @* ── Desktop Navigation ── *@
                <div class="hidden md:flex items-center gap-5" id="nav-desktop-menu">
                    <a href="/" class="nav-link font-bold text-[17px] tracking-wide @(isHomeActive ? "nav-link-active" : "")">Home</a>
                    <a href="/Cars/Browse" class="nav-link font-bold text-[17px] tracking-wide @(isBrowseActive ? "nav-link-active" : "")">Browse Cars</a>
                    <a href="/Home/About" class="nav-link font-bold text-[17px] tracking-wide @(isAboutActive ? "nav-link-active" : "")">About</a>
                </div>

                @* ── Desktop Actions ── *@
                <div class="hidden md:flex items-center gap-3" id="nav-actions">
                    @* ── Global Compare Link ── *@
                    <a x-bind:href="compareLink"
                       class="btn-ghost btn-sm relative"
                       title="Compare Vehicles">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                        </svg>
                        <span x-show="compareCount > 0" x-text="compareCount"
                              class="absolute -top-1 -right-1 w-4 h-4 rounded-full bg-accent-500 text-white text-[10px] font-bold flex items-center justify-center animate-pulse"></span>
                    </a>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @* ── Notifications Dropdown ── *@
                        <div class="relative" x-data="notifDropdown()" x-init="init()" x-on:click.away="open = false">
                            <button x-on:click="toggle()"
                                    class="btn-ghost btn-sm relative"
                                    title="Notifications">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a9.04 9.04 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0M10.5 8.625a3 3 0 1 1 3 0M19.5 12a7.5 7.5 0 0 0-15 0c0 1.972-.573 3.812-1.563 5.378m18.126-5.378A8.967 8.967 0 0 1 21 18H3m0 0a8.967 8.967 0 0 0 1.563-5.378m18.126 5.378A8.967 8.967 0 0 0 21 12" />
                                </svg>
                                <span x-show="unreadCount > 0" x-text="unreadCount"
                                      class="absolute -top-1 -right-1 w-4 h-4 rounded-full bg-accent-500 text-white text-[10px] font-bold flex items-center justify-center animate-pulse"></span>
                            </button>

                            @* Dropdown Panel *@
                            <div x-show="open" x-cloak
                                 x-transition:enter="transition ease-out duration-200"
                                 x-transition:enter-start="opacity-0 scale-95 -translate-y-2"
                                 x-transition:enter-end="opacity-100 scale-100 translate-y-0"
                                 x-transition:leave="transition ease-in duration-150"
                                 x-transition:leave-start="opacity-100 scale-100"
                                 x-transition:leave-end="opacity-0 scale-95"
                                 class="absolute right-0 mt-2 w-96 min-w-[380px] bg-surface-900 border border-surface-800 rounded-2xl shadow-elevated p-4 z-50">
                                <div class="flex items-center justify-between px-4 py-3 border-b border-surface-800/80">
                                    <h4 class="text-sm font-semibold text-white">Notifications</h4>
                                    <button x-on:click="markAllRead()" 
                                            x-show="unreadCount > 0"
                                            class="text-xs text-primary-400 hover:text-primary-300 font-semibold transition-colors whitespace-nowrap">
                                        Mark all as read
                                    </button>
                                </div>
                                <div class="max-h-[400px] overflow-y-auto space-y-1.5 pr-1 mt-2 custom-scrollbar">
                                    <template x-for="notif in notifications" :key="notif.id">
                                        <a :href="notif.link"
                                           x-on:click="markRead(notif.id)"
                                           class="block px-4 py-4 rounded-xl transition-colors border relative cursor-pointer"
                                           x-bind:class="notif.isRead 
                                                         ? 'bg-surface-950/20 border-surface-850/40 opacity-60 hover:bg-surface-950/40' 
                                                         : 'bg-surface-950/60 border-primary-500/20 shadow-glow-sm hover:bg-surface-950/80'">
                                            <div class="flex items-start gap-3">
                                                <span class="mt-1.5 w-2 h-2 rounded-full shrink-0"
                                                      x-bind:class="notif.isRead ? 'bg-transparent' : 'bg-primary-500 animate-pulse'"></span>
                                                <div class="flex-1 min-w-0">
                                                    <p class="text-sm text-gray-200 leading-snug" x-text="notif.message"></p>
                                                    <p class="text-xs text-surface-500 mt-1" x-text="timeAgo(notif.createdAt)"></p>
                                                </div>
                                            </div>
                                        </a>
                                    </template>
                                    <div x-show="notifications.length === 0" class="text-center py-8 text-sm text-surface-500 italic">
                                        All caught up!
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* ── Profile Dropdown ── *@
                        <div class="relative" x-data="{ profileOpen: false }"
                             x-on:click.away="profileOpen = false">
                            <button x-on:click="profileOpen = !profileOpen"
                                    class="flex items-center gap-2 px-2 py-1.5 rounded-xl
                                           hover:bg-white/5 transition-all duration-300"
                                    id="nav-profile-btn">
                                @if (currentUser != null && !string.IsNullOrEmpty(currentUser.AvatarUrl))
                                {
                                    <img src="@currentUser.AvatarUrl" class="w-8 h-8 rounded-full object-cover ring-2 ring-surface-700 hover:ring-primary-500/50 transition-all duration-300" alt="" />
                                }
                                else
                                {
                                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-primary-500 to-accent-500
                                                flex items-center justify-center text-xs font-bold text-white
                                                ring-2 ring-surface-700 hover:ring-primary-500/50 transition-all duration-300">
                                        @((currentUser?.DisplayName ?? User.Identity?.Name ?? "R").Substring(0, 1).ToUpper())
                                    </div>
                                }
                                <svg class="w-4 h-4 text-surface-400 transition-transform duration-300"
                                     x-bind:class="profileOpen ? 'rotate-180' : ''"
                                     fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                                </svg>
                            </button>

                            @* ── Dropdown Panel ── *@
                            <div x-show="profileOpen" x-cloak
                                 x-transition:enter="transition ease-out duration-200"
                                 x-transition:enter-start="opacity-0 scale-95 -translate-y-2"
                                 x-transition:enter-end="opacity-100 scale-100 translate-y-0"
                                 x-transition:leave="transition ease-in duration-150"
                                 x-transition:leave-start="opacity-100 scale-100"
                                 x-transition:leave-end="opacity-0 scale-95 -translate-y-2"
                                 class="absolute right-0 top-full mt-2 w-64 card-glass p-2 z-50"
                                 id="nav-profile-dropdown">

                                @* ── User Info ── *@
                                <div class="px-3 py-3 mb-1 flex items-center gap-3">
                                    @if (currentUser != null && !string.IsNullOrEmpty(currentUser.AvatarUrl))
                                    {
                                        <img src="@currentUser.AvatarUrl" class="w-10 h-10 rounded-full object-cover border border-surface-750 flex-shrink-0" alt="" />
                                    }
                                    else
                                    {
                                        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center text-sm font-bold text-white flex-shrink-0">
                                            @((currentUser?.DisplayName ?? User.Identity?.Name ?? "R").Substring(0, 1).ToUpper())
                                        </div>
                                    }
                                    <div class="min-w-0">
                                        <p class="text-sm font-semibold text-white truncate">@(currentUser?.DisplayName ?? User.Identity?.Name)</p>
                                        <p class="text-xs text-surface-500">Car Enthusiast</p>
                                    </div>
                                </div>
                                <div class="h-px bg-surface-700/50 mx-2 mb-1"></div>

                                @* ── Links ── *@
                                <a asp-controller="Dashboard" asp-action="Index"
                                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-surface-300
                                          hover:text-white hover:bg-white/5 transition-all duration-300">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z" />
                                    </svg>
                                    Dashboard
                                </a>
                                <a asp-controller="Dashboard" asp-action="SavedCars"
                                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-surface-300
                                          hover:text-white hover:bg-white/5 transition-all duration-300">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                                    </svg>
                                    Saved Cars
                                </a>
                                <a asp-controller="Dashboard" asp-action="Messages"
                                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-surface-300
                                          hover:text-white hover:bg-white/5 transition-all duration-300">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
                                    </svg>
                                    My Inquiries
                                </a>
                                <a asp-controller="Account" asp-action="Profile"
                                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-surface-300
                                          hover:text-white hover:bg-white/5 transition-all duration-300">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                                    </svg>
                                    Profile
                                </a>

                                @* ── Seller Section ── *@
                                <p class="px-3 pt-1 pb-0.5 text-[10px] font-semibold text-surface-600 uppercase tracking-widest">Sell</p>
                                <a asp-controller="Seller" asp-action="MyListings"
                                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-surface-300
                                          hover:text-white hover:bg-white/5 transition-all duration-300">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
                                    </svg>
                                    My Listings
                                </a>
                                <a asp-controller="Seller" asp-action="Create"
                                   class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-primary-400
                                          hover:text-primary-300 hover:bg-primary-500/10 transition-all duration-300">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                                    </svg>
                                    Post a Car
                                </a>

                                <div class="h-px bg-surface-700/50 mx-2 my-1"></div>

                                <form asp-controller="Account" asp-action="Logout" method="post" id="logout-desktop-form">
                                    <button type="button"
                                            @@click="$dispatch('confirm-action', { message: 'Are you sure you want to sign out?', action: () => { document.getElementById('logout-desktop-form').submit(); } })"
                                            class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm w-full
                                                   text-red-400 hover:text-red-300 hover:bg-red-500/10 transition-all duration-300">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                                        </svg>
                                        Sign Out
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a href="/Account/Register" 
                           class="@(isRegisterActive ? "btn-ghost btn-sm text-pink-500 bg-pink-500/10 border border-pink-500/20" : "btn-ghost btn-sm")"
                           title="Join Free / Save to Favorites">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                            </svg>
                        </a>
                        <a asp-controller="Account" asp-action="Login" 
                           class="@(isLoginActive ? "btn-primary btn-sm" : (isRegisterActive ? "btn-outline btn-sm" : "btn-primary btn-sm"))" 
                           id="nav-signin-btn">
                            Sign In
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                            </svg>
                        </a>
                    }
                </div>

                @* ── Mobile Menu Button ── *@
                <button class="md:hidden relative w-10 h-10 flex items-center justify-center
                               rounded-xl hover:bg-white/10 transition-colors duration-300"
                        x-on:click="mobileMenuOpen = !mobileMenuOpen"
                        id="nav-mobile-toggle"
                        aria-label="Toggle mobile menu">
                    <div class="w-6 flex flex-col gap-1.5">
                        <span class="block h-0.5 bg-white rounded-full transition-all duration-500 origin-center"
                              x-bind:class="mobileMenuOpen ? 'rotate-45 translate-y-2' : ''"></span>
                        <span class="block h-0.5 bg-white rounded-full transition-all duration-300"
                              x-bind:class="mobileMenuOpen ? 'opacity-0 scale-x-0' : ''"></span>
                        <span class="block h-0.5 bg-white rounded-full transition-all duration-500 origin-center"
                              x-bind:class="mobileMenuOpen ? '-rotate-45 -translate-y-2' : ''"></span>
                    </div>
                </button>
            </div>
        </nav>

        @* ── Mobile Menu Panel ── *@
        <div class="md:hidden overflow-hidden transition-all duration-500 ease-out"
             x-show="mobileMenuOpen"
