    @* ── Reusable Premium Alpine.js Toast Notification System ── *@
    <div x-data="{
             toasts: [],
             addToast(message, type = 'success') {
                 const id = Date.now() + Math.random().toString(36).substr(2, 9);
                 const newToast = { id, message, type, visible: false };
                 this.toasts.push(newToast);
                 
                 this.$nextTick(() => {
                     const t = this.toasts.find(item => item.id === id);
                     if (t) t.visible = true;
                 });

                 setTimeout(() => {
                     this.removeToast(id);
                 }, 3000);
             },
             removeToast(id) {
                 const t = this.toasts.find(item => item.id === id);
                 if (t) {
                     t.visible = false;
                     setTimeout(() => {
                         this.toasts = this.toasts.filter(item => item.id !== id);
                     }, 300);
                 }
             }
         }"
         @@toast.window="addToast($event.detail.message, $event.detail.type)"
         class="fixed bottom-6 right-6 z-[9999] flex flex-col gap-3 max-w-sm w-full pointer-events-none"
         x-cloak>
         
         <template x-for="t in toasts" :key="t.id">
             <div x-show="t.visible"
                  x-transition:enter="transition ease-out duration-300 transform"
                  x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:translate-x-4 scale-95"
                  x-transition:enter-end="opacity-100 translate-y-0 sm:translate-x-0 scale-100"
                  x-transition:leave="transition ease-in duration-200 transform"
                  x-transition:leave-start="opacity-100 scale-100"
                  x-transition:leave-end="opacity-0 scale-95 translate-y-2"
                  class="pointer-events-auto w-full card-glass border bg-surface-900/95 p-4 rounded-xl shadow-elevated flex items-center gap-3 transition-all duration-300"
                  :class="t.type === 'error' ? 'border-red-500/30 hover:border-red-500/50 shadow-red-500/5' : 'border-surface-800 hover:border-primary-500/30 shadow-primary-500/5'">
                  
                  <div class="shrink-0 flex items-center justify-center w-8 h-8 rounded-lg"
                       :class="t.type === 'error' ? 'bg-red-500/10 text-red-500' : 'bg-green-500/10 text-green-500'">
                      <template x-if="t.type !== 'error'">
                          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                          </svg>
                      </template>
                      <template x-if="t.type === 'error'">
                          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                          </svg>
                      </template>
                  </div>
                  
                  <div class="flex-grow min-w-0">
                       <p class="text-xs font-semibold text-white leading-relaxed" x-text="t.message"></p>
                  </div>

                  <button type="button" 
                          class="shrink-0 w-6 h-6 rounded-md flex items-center justify-center text-surface-500 hover:text-white hover:bg-white/5 transition-all"
                          @@click="removeToast(t.id)">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                      </svg>
                  </button>
             </div>
         </template>
     </div>

    <style>
        /* Alpine.js cloak — hide elements until Alpine initializes */
        [x-cloak] { display: none !important; }
    </style>
    <script>
    function notifDropdown() {
        return {
            open: false,
            notifications: [],
            unreadCount: 0,

            async init() {
                await this.fetchNotifs();

                // SignalR real-time listener
                const connection = new signalR.HubConnectionBuilder()
                    .withUrl("/notificationHub")
                    .withAutomaticReconnect()
                    .build();

                connection.on("ReceiveNotification", (notif) => {
                    if (!this.notifications.some(n => n.id === notif.id)) {
                        this.notifications.unshift(notif);
                        this.unreadCount++;
                        this.$dispatch('toast', { 
                            message: notif.message, 
                            type: 'info' 
                        });
                    }
                });

                try {
                    await connection.start();
                    window.notificationConnection = connection;
                } catch (err) {
                    console.error("SignalR connection failed: ", err);
                }
            },

            toggle() {
                this.open = !this.open;
            },

            async fetchNotifs() {
                try {
                    const res = await fetch('/Notifications/GetAll');
                    if (res.ok) {
                        const data = await res.json();
                        this.notifications = data;
                        this.unreadCount = data.filter(n => !n.isRead).length;
                    }
                } catch (err) {
                    console.error("Error fetching notifications: ", err);
                }
            },

            async markRead(id) {
                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    await fetch(`/Notifications/MarkRead/${id}`, { 
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token || ''
                        }
                    });
                    const notif = this.notifications.find(n => n.id === id);
                    if (notif) { notif.isRead = true; }
                    this.unreadCount = this.notifications.filter(n => !n.isRead).length;
                } catch (err) {
                    console.error("Error marking notification as read: ", err);
                }
            },

            async markAllRead() {
                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    await fetch('/Notifications/MarkAllRead', { 
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token || ''
                        }
                    });
                    this.notifications.forEach(n => n.isRead = true);
                    this.unreadCount = 0;
                } catch (err) {
                    console.error("Error marking all as read: ", err);
                }
            },

            timeAgo(dateStr) {
                const diff = Math.floor((new Date() - new Date(dateStr)) / 1000);
                if (diff < 60) return `${diff}s ago`;
                if (diff < 3600) return `${Math.floor(diff/60)}m ago`;
                if (diff < 86400) return `${Math.floor(diff/3600)}h ago`;
                return `${Math.floor(diff/86400)}d ago`;
            }
        }
    }
    </script>

    @* Anti-Forgery token container *@
    <div class="hidden">
        @Html.AntiForgeryToken()
    </div>

    <script>
        // Automatically inject anti-forgery tokens into all HTMX AJAX requests
        document.body.addEventListener('htmx:configRequest', function (event) {
            const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
            if (tokenElement) {
                event.detail.headers['RequestVerificationToken'] = tokenElement.value;
            }
        });
    </script>
</body>
</html>
