    <script>
        window.showToast = (message, type = 'success') => {
            window.dispatchEvent(new CustomEvent('toast', {
                detail: { message: message, type: type }
            }));
        };
        window.showConfirm = (title, message, confirmCallback, confirmText = 'Confirm', cancelText = 'Cancel') => {
            window.dispatchEvent(new CustomEvent('confirm-action', {
                detail: {
                    message: message,
                    action: confirmCallback
                }
            }));
        };

        // ── Custom HTMX Confirmation Bridge ──
        document.addEventListener('htmx:confirm', function(evt) {
            // Only prompt if a confirmation message (hx-confirm) is specified
            if (!evt.detail.question) {
                return;
            }
            evt.preventDefault();
            window.dispatchEvent(new CustomEvent('confirm-action', {
                detail: {
                    message: evt.detail.question,
                    action: () => {
                        evt.detail.issueRequest(true);
                    }
                }
            }));
        });
    </script>

