@* ============================================================
   RevvUp — Dashboard Layout
   Sidebar navigation with fun icons and smooth animations
   Inherits from _Layout for navbar/footer
   ============================================================ *@
@{
    Layout = "_Layout";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Dashboard";
    var userName = ViewData["UserName"]?.ToString() ?? "Racer";
}

<div class="pt-20 min-h-screen" x-data="{ sidebarOpen: false }">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex gap-8">

            @* ── Sidebar (Desktop) ── *@
            <aside class="hidden lg:block w-64 flex-shrink-0">
                <div class="sticky top-24">
                    <nav class="card p-4 space-y-1">
                        @* ── User greeting ── *@
                        <div class="px-3 py-3 mb-2">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-500 to-accent-500
                                            flex items-center justify-center text-sm font-bold text-white shadow-glow-sm">
                                    @(userName.Length > 0 ? userName[0].ToString().ToUpper() : "R")
                                </div>
                                <div>
                                    <p class="text-sm font-semibold text-white truncate">@userName</p>
                                    <p class="text-xs text-surface-500">Dashboard</p>
                                </div>
                            </div>
                        </div>

                        <div class="divider mb-2"></div>

                        @* ── Nav Items ── *@
                        <a asp-controller="Dashboard" asp-action="Index"
                           class="sidebar-link @(currentAction == "Index" && currentController == "Dashboard" ? "sidebar-link-active" : "")">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z" />
                            </svg>
                            <span>Overview</span>
                        </a>

                        <a asp-controller="Dashboard" asp-action="MyListings"
                           class="sidebar-link @(currentAction == "MyListings" ? "sidebar-link-active" : "")">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
                            </svg>
                            <span>My Listings</span>
                            <span class="ml-auto badge-primary text-xs py-0.5 px-2">3</span>
                        </a>

                        <a asp-controller="Dashboard" asp-action="SavedCars"
                           class="sidebar-link @(currentAction == "SavedCars" ? "sidebar-link-active" : "")">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                            </svg>
                            <span>Saved Cars</span>
                            <span x-show="favoritesCount > 0" x-text="favoritesCount" class="ml-auto badge-primary text-xs py-0.5 px-2"></span>
                        </a>

                        <a asp-controller="Dashboard" asp-action="Selling"
                           class="sidebar-link @(currentAction == "Selling" ? "sidebar-link-active" : "")">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
                            </svg>
                            <span>Selling</span>
                        </a>

                        <div class="divider my-2"></div>

                        <a asp-controller="Account" asp-action="Profile"
                           class="sidebar-link @(currentController == "Account" && currentAction == "Profile" ? "sidebar-link-active" : "")">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                            </svg>
                            <span>Profile</span>
                        </a>

                        <form asp-controller="Account" asp-action="Logout" method="post" class="mt-2">
                            <button type="submit" class="sidebar-link w-full text-red-400 hover:text-red-300 hover:bg-red-500/10">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                                </svg>
                                <span>Sign Out</span>
                            </button>
                        </form>
                    </nav>
                </div>
            </aside>

            @* ── Mobile Sidebar Toggle ── *@
            <button x-on:click="sidebarOpen = !sidebarOpen"
                    class="lg:hidden fixed bottom-6 right-6 z-40 w-14 h-14 rounded-2xl
                           bg-primary-600 text-white shadow-glow flex items-center justify-center
                           hover:bg-primary-500 active:scale-95 transition-all duration-300">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
            </button>

            @* ── Mobile Sidebar Overlay ── *@
            <div x-show="sidebarOpen" x-cloak
                 class="lg:hidden fixed inset-0 z-30 bg-black/50 backdrop-blur-sm"
                 x-on:click="sidebarOpen = false"
                 x-transition:enter="transition ease-out duration-300"
                 x-transition:enter-start="opacity-0"
                 x-transition:enter-end="opacity-100"
                 x-transition:leave="transition ease-in duration-200"
                 x-transition:leave-start="opacity-100"
                 x-transition:leave-end="opacity-0">
            </div>

            @* ── Mobile Sidebar Panel ── *@
            <div x-show="sidebarOpen" x-cloak
                 class="lg:hidden fixed left-0 top-0 bottom-0 z-40 w-72 bg-surface-950 border-r border-surface-800/50 pt-20 p-4 overflow-y-auto"
                 x-transition:enter="transition ease-out duration-300"
                 x-transition:enter-start="-translate-x-full"
                 x-transition:enter-end="translate-x-0"
                 x-transition:leave="transition ease-in duration-200"
                 x-transition:leave-start="translate-x-0"
                 x-transition:leave-end="-translate-x-full">
                <nav class="space-y-1">
                    <div class="px-3 py-3 mb-2">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-500 to-accent-500
                                        flex items-center justify-center text-sm font-bold text-white">
                                @(userName.Length > 0 ? userName[0].ToString().ToUpper() : "R")
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-white">@userName</p>
                                <p class="text-xs text-surface-500">Dashboard</p>
                            </div>
                        </div>
                    </div>
                    <div class="divider mb-2"></div>
                    <a asp-controller="Dashboard" asp-action="Index" x-on:click="sidebarOpen = false"
                       class="sidebar-link @(currentAction == "Index" && currentController == "Dashboard" ? "sidebar-link-active" : "")">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z" />
                        </svg>
                        <span>Overview</span>
                    </a>
                    <a asp-controller="Dashboard" asp-action="MyListings" x-on:click="sidebarOpen = false"
                       class="sidebar-link @(currentAction == "MyListings" ? "sidebar-link-active" : "")">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
                        </svg>
                        <span>My Listings</span>
                    </a>
                    <a asp-controller="Dashboard" asp-action="SavedCars" x-on:click="sidebarOpen = false"
                       class="sidebar-link @(currentAction == "SavedCars" ? "sidebar-link-active" : "")">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                        </svg>
                        <span>Saved Cars</span>
                    </a>
                    <a asp-controller="Dashboard" asp-action="Selling" x-on:click="sidebarOpen = false"
                       class="sidebar-link @(currentAction == "Selling" ? "sidebar-link-active" : "")">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
                        </svg>
                        <span>Selling</span>
                    </a>
                    <div class="divider my-2"></div>
                    <a asp-controller="Account" asp-action="Profile" x-on:click="sidebarOpen = false"
                       class="sidebar-link @(currentController == "Account" && currentAction == "Profile" ? "sidebar-link-active" : "")">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                        </svg>
                        <span>Profile</span>
                    </a>
                </nav>
            </div>

            @* ── Main Content ── *@
            <div class="flex-1 min-w-0">
                @RenderBody()
            </div>
        </div>
    </div>
</div>
