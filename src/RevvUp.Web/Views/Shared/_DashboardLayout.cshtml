@* ============================================================
   RevvUp — Dashboard Layout
   Sidebar-less, fills viewport height, aligns with main nav
   ============================================================ *@
@{
    Layout = "_Layout";
}

<div class="@(ViewData["FitToScreen"] as bool? == true ? "lg:h-full lg:min-h-0 lg:pt-20 lg:pb-4 min-h-[calc(100vh-72px)] pt-24 pb-16" : "min-h-[calc(100vh-72px)] pt-24 pb-16") flex flex-col relative overflow-hidden flex-1">
    @* ── Background Glow Effects ── *@
    <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute top-1/4 -left-32 w-[400px] h-[400px] bg-primary-500/5 rounded-full blur-[100px] animate-float"></div>
        <div class="absolute bottom-1/4 -right-32 w-[350px] h-[350px] bg-accent-500/5 rounded-full blur-[90px] animate-float delay-300"></div>
    </div>

    @* ── Main Content Area ── *@
    <main class="relative z-10 flex-1 @(ViewData["FitToScreen"] as bool? == true ? "lg:overflow-hidden lg:flex lg:flex-col lg:min-h-0" : "")">
        <div class="premium-container @(ViewData["FitToScreen"] as bool? == true ? "lg:h-full lg:flex lg:flex-col lg:overflow-hidden lg:min-h-0" : "")">
            @RenderBody()
        </div>
    </main>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
