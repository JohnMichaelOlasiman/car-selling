@{
    ViewData["Title"] = "404 — Wrong Route!";
}

<section class="min-h-screen flex items-center justify-center px-4 relative overflow-hidden bg-surface-950">
    @* Glowing background elements *@
    <div class="absolute top-10 left-10 w-96 h-96 bg-primary-500/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-accent-500/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="text-center max-w-xl relative z-10 space-y-6">
        @* Animated Car Illustration *@
        <div class="relative w-72 h-44 mx-auto mb-8 animate-float">
            <div class="absolute inset-0 bg-gradient-to-tr from-primary-500/25 to-accent-500/25 rounded-3xl blur-2xl opacity-50"></div>
            @* Fun visual car design *@
            <svg viewBox="0 0 200 100" class="w-full h-full text-primary-400 drop-shadow-glow">
                <path d="M20,60 L40,30 L120,30 L150,60 L180,60 C185,60 190,65 190,70 L190,80 C190,82 188,84 185,84 L170,84 C170,74 150,74 150,84 L50,84 C50,74 30,74 30,84 L15,84 C12,84 10,82 10,80 L10,70 C10,65 15,60 20,60 Z" fill="currentColor" opacity="0.85" />
                <path d="M45,35 L75,35 L75,55 L35,55 Z" fill="#1e293b" />
                <path d="M82,35 L115,35 L110,55 L82,55 Z" fill="#1e293b" />
                <circle cx="40" cy="84" r="14" fill="#0f172a" stroke="currentColor" stroke-width="3" />
                <circle cx="160" cy="84" r="14" fill="#0f172a" stroke="currentColor" stroke-width="3" />
            </svg>
            <div class="absolute -bottom-2 left-12 w-8 h-1 bg-surface-500 rounded-full animate-pulse"></div>
            <div class="absolute -bottom-2 right-12 w-8 h-1 bg-surface-500 rounded-full animate-pulse"></div>
        </div>

        <h1 class="text-6xl font-display font-black text-white tracking-tight">404</h1>
        <h2 class="text-2xl sm:text-3xl font-display font-bold text-gradient">Wrong Turn! Lost in the Dust?</h2>
        
        <p class="text-surface-400 text-base leading-relaxed max-w-md mx-auto">
            You've drifted off course! The vehicle configuration or race route you are looking for has been moved or retired from the marketplace.
        </p>

        <div class="pt-4 flex flex-col sm:flex-row items-center justify-center gap-3">
            <a href="/" class="btn-primary w-full sm:w-auto justify-center">
                🏠 Back to Pit Lane
            </a>
            <a href="/Cars/Browse" class="btn-outline w-full sm:w-auto justify-center">
                🏎️ Explore Inventory
            </a>
        </div>
    </div>
</section>
