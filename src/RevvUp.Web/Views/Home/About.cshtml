@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', () => {
    // ── Snappy Flick Scroll Manager ──
    const sectionIds = ['about-hero', 'mission-vision', 'how-it-works', 'why-revvup', 'meet-the-team', 'about-footer'];
    let currentIdx = 0;
    let isLocked = false;
    const cooldown = 900;

    function snapTo(index) {
        if (index < 0 || index >= sectionIds.length) return;
        const el = document.getElementById(sectionIds[index]);
        if (el) {
            isLocked = true;
            currentIdx = index;
            el.scrollIntoView({ behavior: 'smooth' });
            setTimeout(() => { isLocked = false; }, cooldown);
        }
    }

    const syncObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting && entry.intersectionRatio >= 0.4) {
                const idx = sectionIds.indexOf(entry.target.id);
                if (idx !== -1 && !isLocked) {
                    currentIdx = idx;
                }
            }
        });
    }, { threshold: [0.1, 0.4, 0.7], rootMargin: '-10% 0px -10% 0px' });

    sectionIds.forEach(id => {
        const el = document.getElementById(id);
        if (el) syncObserver.observe(el);
    });

    // Capture Wheel Gestures
    window.addEventListener('wheel', (e) => {
        if (window.innerWidth < 1024 || window.innerHeight < 800) return;
        e.preventDefault();
        if (isLocked) return;
        
        if (e.deltaY > 15) {
            if (currentIdx < sectionIds.length - 1) snapTo(currentIdx + 1);
        } else if (e.deltaY < -15) {
            if (currentIdx > 0) snapTo(currentIdx - 1);
        }
    }, { passive: false });

    // Capture Keyboard
    window.addEventListener('keydown', (e) => {
        if (window.innerWidth < 1024 || window.innerHeight < 800) return;
        
        if (['ArrowDown', 'PageDown'].includes(e.key)) {
            e.preventDefault();
            if (currentIdx < sectionIds.length - 1) snapTo(currentIdx + 1);
        } else if (['ArrowUp', 'PageUp'].includes(e.key)) {
            e.preventDefault();
            if (currentIdx > 0) snapTo(currentIdx - 1);
        } else if (e.key === 'Home') {
            e.preventDefault();
            snapTo(0);
        } else if (e.key === 'End') {
            e.preventDefault();
            snapTo(sectionIds.length - 1);
        }
    });

    // Capture Touch Swipes
    let startY = 0;
    window.addEventListener('touchstart', (e) => {
        if (window.innerWidth < 1024 || window.innerHeight < 800) return;
        startY = e.touches[0].clientY;
    }, { passive: true });

    window.addEventListener('touchmove', (e) => {
        if (window.innerWidth < 1024 || window.innerHeight < 800) return;
        if (isLocked) return;
        
        const endY = e.touches[0].clientY;
        const diff = startY - endY;
        
        if (Math.abs(diff) > 60) {
            if (diff > 0) {
                if (currentIdx < sectionIds.length - 1) snapTo(currentIdx + 1);
            } else {
                if (currentIdx > 0) snapTo(currentIdx - 1);
            }
        }
    }, { passive: true });
});
</script>
}
