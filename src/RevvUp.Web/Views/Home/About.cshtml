@{
    ViewData["Title"] = "About RevvUp";
    ViewData["HideFooter"] = true;
}

@* ── Vertical Dot Navigator ── *@
<div x-data="{
         activeSection: 'about-hero',
         sections: [
             { id: 'about-hero', label: 'About RevvUp' },
             { id: 'mission-vision', label: 'Mission & Vision' },
             { id: 'how-it-works', label: 'How It Works' },
             { id: 'why-revvup', label: 'Why RevvUp' },
             { id: 'meet-the-team', label: 'Meet the Team' },
             { id: 'about-footer', label: 'Connect' }
         ],
         init() {
             const observer = new IntersectionObserver((entries) => {
                 entries.forEach(entry => {
                     if (entry.isIntersecting && entry.intersectionRatio >= 0.4) {
                         this.activeSection = entry.target.id;
                     }
                 });
             }, { threshold: [0.1, 0.4, 0.7], rootMargin: '-10% 0px -10% 0px' });
             
             this.sections.forEach(s => {
                 const el = document.getElementById(s.id);
                 if (el) observer.observe(el);
             });
         },
         scrollTo(id) {
             const el = document.getElementById(id);
             if (el) {
                 el.scrollIntoView({ behavior: 'smooth' });
             }
         }
     }"
     class="fixed right-8 top-1/2 -translate-y-1/2 z-40 hidden xl:flex flex-col gap-5 p-3.5 rounded-full bg-surface-950/40 backdrop-blur-md border border-surface-800/40 shadow-elevated"
     x-cloak>
    
    <template x-for="section in sections" :key="section.id">
        <button x-on:click="scrollTo(section.id)"
                class="group relative flex items-center justify-end w-4 h-4 rounded-full transition-all duration-300"
                aria-label="Navigate to section">
            
            @* Tooltip hover text *@
            <span class="absolute right-8 px-3 py-1.5 rounded-lg text-xs font-semibold text-white bg-surface-900 border border-surface-800/60 shadow-elevated opacity-0 translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 pointer-events-none whitespace-nowrap">
                <span x-text="section.label"></span>
            </span>

            @* Dot circle *@
            <span class="w-2.5 h-2.5 rounded-full transition-all duration-300"
                  x-bind:class="activeSection === section.id 
                      ? 'bg-primary-500 scale-125 shadow-glow-sm' 
                      : 'bg-surface-600 group-hover:bg-primary-400/80 group-hover:scale-110'"></span>
        </button>
    </template>
</div>

