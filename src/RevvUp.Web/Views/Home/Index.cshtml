@* ── TESTIMONIALS SECTION ── *@
<section class="relative min-h-screen flex flex-col justify-center py-12 md:py-16 xl:py-20 bg-surface-900 border-t border-surface-850 snap-section" id="testimonials-section">
    <div class="premium-container">
        @* Section Header *@
        <div class="text-center mb-10 lg:mb-14">
