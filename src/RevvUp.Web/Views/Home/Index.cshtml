@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', () => {
    // ── Car Card Reveal Animation ──
    const cardObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry, i) => {
            if (entry.isIntersecting) {
                entry.target.style.transitionDelay = `${(i % 4) * 50}ms`;
                entry.target.classList.remove('opacity-0', 'translate-y-8');
                entry.target.classList.add('opacity-100', 'translate-y-0');
                cardObserver.unobserve(entry.target);
            }
        });
    }, { threshold: 0.05 });

    document.querySelectorAll('.car-card').forEach(card => cardObserver.observe(card));

    // ── Snappy Flick Scroll Manager ──
    const sectionIds = ['hero-section', 'featured-section', 'recent-section', 'testimonials-section', 'cta-section'];
    let currentIdx = 0;
    let isLocked = false;
    const cooldown = 900; // ms transition lock

    // Helper to snap to section by index
    function snapTo(index) {
        if (index < 0 || index >= sectionIds.length) return;
        const el = document.getElementById(sectionIds[index]);
        if (el) {
            isLocked = true;
            currentIdx = index;
            el.scrollIntoView({ behavior: 'smooth' });
            setTimeout(() => { isLocked = false; }, cooldown);
        }
    }

    // Sync section index with window scrolling (e.g. from dot clicks or manual scroll)
    const syncObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting && entry.intersectionRatio >= 0.4) {
                const idx = sectionIds.indexOf(entry.target.id);
                if (idx !== -1 && !isLocked) {
                    currentIdx = idx;
                }
            }
        });
    }, { threshold: [0.1, 0.4, 0.7], rootMargin: '-10% 0px -10% 0px' });

    sectionIds.forEach(id => {
        const el = document.getElementById(id);
        if (el) syncObserver.observe(el);
    });

    // Capture Wheel Gestures
    window.addEventListener('wheel', (e) => {
        // Only active on desktop/large viewport sizes
        if (window.innerWidth < 1024 || window.innerHeight < 800) return;
        
        // Prevent default browser continuous scroll jumpiness
        e.preventDefault();
        
        if (isLocked) return;
        
        if (e.deltaY > 15) {
            // Flick down
            if (currentIdx < sectionIds.length - 1) {
                snapTo(currentIdx + 1);
            }
        } else if (e.deltaY < -15) {
            // Flick up
            if (currentIdx > 0) {
                snapTo(currentIdx - 1);
            }
        }
    }, { passive: false });

    // Capture Keyboard Clicks
    window.addEventListener('keydown', (e) => {
        if (window.innerWidth < 1024 || window.innerHeight < 800) return;
        
        if (['ArrowDown', 'PageDown'].includes(e.key)) {
            e.preventDefault();
            if (currentIdx < sectionIds.length - 1) snapTo(currentIdx + 1);
        } else if (['ArrowUp', 'PageUp'].includes(e.key)) {
            e.preventDefault();
            if (currentIdx > 0) snapTo(currentIdx - 1);
        } else if (e.key === 'Home') {
            e.preventDefault();
            snapTo(0);
        } else if (e.key === 'End') {
            e.preventDefault();
            snapTo(sectionIds.length - 1);
        }
    });

    // Capture Swipes for touch laptops/tablets
    let startY = 0;
    window.addEventListener('touchstart', (e) => {
        if (window.innerWidth < 1024 || window.innerHeight < 800) return;
        startY = e.touches[0].clientY;
    }, { passive: true });

    window.addEventListener('touchmove', (e) => {
        if (window.innerWidth < 1024 || window.innerHeight < 800) return;
        if (isLocked) return;
        
        const endY = e.touches[0].clientY;
        const diff = startY - endY;
        
        if (Math.abs(diff) > 60) {
            if (diff > 0) {
                if (currentIdx < sectionIds.length - 1) snapTo(currentIdx + 1);
            } else {
                if (currentIdx > 0) snapTo(currentIdx - 1);
            }
        }
    }, { passive: true });
});
</script>
}
