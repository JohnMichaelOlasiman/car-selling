@* ── CTA BANNER ── *@
<section class="relative py-24 border-t border-surface-850" id="cta-section">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="relative card p-12 sm:p-16 text-center overflow-hidden">
            <div class="absolute top-0 left-1/4 w-80 h-80 bg-primary-500/5 rounded-full blur-3xl"></div>
            <div class="relative z-10">
                <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-white mb-4">
                    Ready to Find Your <span class="text-gradient">Next Masterpiece?</span>
                </h2>
                <p class="text-surface-400 text-base max-w-lg mx-auto mb-8 leading-relaxed">
                    Join thousands of high-performance car owners and collectors who utilize RevvUp daily to buy and sell premium automotive assets.
                </p>
                <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                    <a href="/Cars/Browse" class="btn-primary w-full sm:w-auto justify-center">
                        Start Browsing
                    </a>
                    <a href="/Dashboard/CreateListing" class="btn-outline w-full sm:w-auto justify-center">
                        List Your Vehicle
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry, i) => {
            if (entry.isIntersecting) {
                entry.target.style.transitionDelay = `${(i % 4) * 50}ms`;
                entry.target.classList.remove('opacity-0', 'translate-y-8');
                entry.target.classList.add('opacity-100', 'translate-y-0');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.05 });

    document.querySelectorAll('.car-card').forEach(card => observer.observe(card));
});
</script>
}
