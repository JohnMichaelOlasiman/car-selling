@using RevvUp.Web.Models
@{
    ViewData["Title"] = "Premium Automotive Marketplace";
    ViewData["HideFooter"] = true;
}

@* ── Vertical Dot Navigator ── *@
<div x-data="{
         activeSection: 'hero-section',
         sections: [
             { id: 'hero-section', label: 'Discover' },
             { id: 'featured-section', label: 'Featured Collections' },
             { id: 'recent-section', label: 'Recent Inventory' },
             { id: 'testimonials-section', label: 'Client Reviews' },
             { id: 'cta-section', label: 'Get Started' }
         ],
         init() {
             const observer = new IntersectionObserver((entries) => {
                 entries.forEach(entry => {
                     if (entry.isIntersecting && entry.intersectionRatio >= 0.4) {
                         this.activeSection = entry.target.id;
                     }
                 });
             }, { threshold: [0.1, 0.4, 0.7], rootMargin: '-10% 0px -10% 0px' });
             
             this.sections.forEach(s => {
                 const el = document.getElementById(s.id);
                 if (el) observer.observe(el);
             });
         },
         scrollTo(id) {
             const el = document.getElementById(id);
             if (el) {
                 el.scrollIntoView({ behavior: 'smooth' });
             }
         }
     }"
     class="fixed right-8 top-1/2 -translate-y-1/2 z-40 hidden xl:flex flex-col gap-5 p-3.5 rounded-full bg-surface-950/40 backdrop-blur-md border border-surface-800/40 shadow-elevated"
     x-cloak>
    
    <template x-for="section in sections" :key="section.id">
        <button x-on:click="scrollTo(section.id)"
                class="group relative flex items-center justify-end w-4 h-4 rounded-full transition-all duration-300"
                aria-label="Navigate to section">
            
            @* Tooltip hover text *@
            <span class="absolute right-8 px-3 py-1.5 rounded-lg text-xs font-semibold text-white bg-surface-900 border border-surface-800/60 shadow-elevated opacity-0 translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 pointer-events-none whitespace-nowrap">
                <span x-text="section.label"></span>
            </span>

            @* Dot circle *@
            <span class="w-2.5 h-2.5 rounded-full transition-all duration-300"
                  x-bind:class="activeSection === section.id 
                      ? 'bg-primary-500 scale-125 shadow-glow-sm' 
                      : 'bg-surface-600 group-hover:bg-primary-400/80 group-hover:scale-110'"></span>
        </button>
    </template>
</div>

@* ── HERO SECTION ── *@
<section class="relative min-h-screen flex items-center justify-center overflow-hidden py-16 md:py-24 xl:py-32 snap-section" id="hero-section">
    @* Background Image Layer *@
    <div class="absolute inset-0 z-0">
        <img src="/images/hero-bg.png"
             alt="Premium sports car showcase"
             class="w-full h-full object-cover object-center scale-105"
             loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-b from-surface-950/80 via-surface-950/60 to-surface-950"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-surface-950/90 via-transparent to-surface-950/90"></div>
    </div>

    @* Subtle Glow Orbs *@
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
        <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-primary-500/5 rounded-full blur-[120px] animate-float"></div>
    </div>

    @* Hero Content *@
    <div class="relative z-10 premium-container text-center pt-8 md:pt-12">
        @* Announcement Badge *@
        <div class="animate-fade-in-down mb-6 lg:mb-8">
            <span class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-primary-500/10 border border-primary-500/25 text-primary-400 text-xs sm:text-sm font-extrabold uppercase tracking-[0.18em]">
                <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-primary-500"></span>
                </span>
                The Next Generation Automotive Marketplace
            </span>
        </div>

        @* Headline *@
        <div class="animate-fade-in-up">
            <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-[6rem] xl:text-[7.5rem] 2xl:text-[8.5rem] font-display font-black leading-[0.98] tracking-tight mb-6 lg:mb-8">
                <span class="block text-white">Discover Extraordinary</span>
                <span class="block text-gradient mt-2">Performance Machines</span>
            </h1>
        </div>

        @* Subheadline *@
        <p class="animate-fade-in-up delay-100 opacity-0 text-lg sm:text-xl md:text-2xl text-surface-200 max-w-4xl mx-auto mb-8 lg:mb-12 leading-relaxed font-medium">
            Experience an elite digital showroom engineered for automotive purists. Explore verified high-performance vehicles, muscle classics, and modern supercars.
        </p>

        @* Search Bar *@
        <div class="animate-fade-in-up delay-200 opacity-0 max-w-3xl mx-auto mb-10 lg:mb-14">
            <div class="bg-surface-900 border border-surface-800 p-3.5 rounded-2xl shadow-elevated" x-data="{ focused: false }">
                <div class="flex flex-col sm:flex-row gap-3">
                    <div class="relative flex-1">
                        <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-6 h-6 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                        </svg>
                        <input type="text"
                               placeholder="Search brand, model, or keyword..."
                               class="w-full pl-14 pr-4 py-5 bg-transparent border-0 text-white placeholder-surface-500 text-xl focus:ring-0 focus:outline-none font-medium"
                               id="hero-search-input" />
                    </div>
                    <button onclick="window.location.href='/Cars/Browse?search='+document.getElementById('hero-search-input').value"
                            class="btn-primary whitespace-nowrap px-12 py-5 text-xl font-extrabold" id="hero-search-btn">
                        Search Inventory
                    </button>
                </div>
            </div>
        </div>

        @* Trust Metrics *@
        <div class="animate-fade-in-up delay-300 opacity-0">
            <div class="flex flex-wrap items-center justify-center gap-10 sm:gap-20">
                <div class="text-center">
                    <div class="text-5xl sm:text-6xl lg:text-7xl font-display font-black text-white">50+</div>
                    <div class="text-base sm:text-lg text-surface-400 uppercase tracking-[0.2em] mt-3 font-extrabold">Cars Available</div>
                </div>
                <div class="w-[1.5px] h-16 bg-surface-800 hidden sm:block"></div>
                <div class="text-center">
                    <div class="text-5xl sm:text-6xl lg:text-7xl font-display font-black text-white">15+</div>
                    <div class="text-base sm:text-lg text-surface-400 uppercase tracking-[0.2em] mt-3 font-extrabold">Curated Brands</div>
                </div>
                <div class="w-[1.5px] h-16 bg-surface-800 hidden sm:block"></div>
                <div class="text-center">
                    <div class="text-5xl sm:text-6xl lg:text-7xl font-display font-black text-white">1,000+</div>
                    <div class="text-base sm:text-lg text-surface-400 uppercase tracking-[0.2em] mt-3 font-extrabold">Happy Buyers</div>
                </div>
            </div>
        </div>
    </div>
</section>


@* ── FEATURED CARS SECTION ── *@
<section class="relative min-h-screen flex flex-col justify-center py-12 md:py-16 xl:py-20 bg-surface-900 border-t border-b border-surface-850 snap-section" id="featured-section">
    <div class="premium-container">
        @* Header *@
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 lg:mb-14">
            <div>
                <span class="text-primary-400 text-xs sm:text-sm font-extrabold uppercase tracking-[0.2em] block mb-2">Handpicked Collection</span>
                <h2 class="text-4xl sm:text-5xl font-display font-black text-white leading-tight">
                    Featured <span class="text-gradient">Masterpieces</span>
                </h2>
            </div>
            <a href="/Cars/Browse?sortBy=newest" class="text-base font-bold text-primary-400 hover:text-primary-300 transition-colors flex items-center gap-2 mt-4 md:mt-0 group">
                View All Featured
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
            </a>
        </div>

        @* Featured Grid *@
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 lg:gap-8">
            @if (ViewBag.FeaturedCars != null)
            {
                foreach (var car in (List<CarCardViewModel>)ViewBag.FeaturedCars)
                {
                    var isOwner = User.FindFirstValue(ClaimTypes.NameIdentifier) == car.SellerId;
                    <div class="car-card opacity-0 transform translate-y-8 transition-all duration-500 ease-out group" x-data="{
                        faved: @car.IsFavoritedByCurrentUser.ToString().ToLower(),
                        id: '@car.Id',
                        async toggleFavorite() {
                            @if (User.Identity?.IsAuthenticated != true)
                            {
                                <text>
                                window.location.href = '/Account/Register';
                                return;
                                </text>
                            }
                            else
                            {
                                <text>
                                // Optimistic UI toggle
                                this.faved = !this.faved;
                                
                                // Dispatch toast immediately
                                const msg = this.faved ? 'Added to Saved Cars' : 'Removed from Saved Cars';
                                window.showToast(msg, 'success');

                                // Sync with localStorage for dashboard/other pages sync
                                let list = JSON.parse(localStorage.getItem('likedCars') || '[]');
                                if (this.faved) {
                                    if (!list.includes(this.id)) list.push(this.id);
                                } else {
                                    list = list.filter(item => item !== this.id);
                                }
                                localStorage.setItem('likedCars', JSON.stringify(list));
                                window.dispatchEvent(new Event('storage'));

                                try {
                                    const token = document.querySelector('input[name=__RequestVerificationToken]')?.value;
                                    const response = await fetch(`/Cars/ToggleFavorite/${this.id}`, { 
                                        method: 'POST',
                                        headers: { 'RequestVerificationToken': token || '' }
                                    });
                                    if (response.status === 401) {
                                        // Revert state
                                        this.faved = !this.faved;
                                        window.showToast('Please log in to save cars.', 'error');
                                        
                                        // Revert localStorage
                                        let currentList = JSON.parse(localStorage.getItem('likedCars') || '[]');
                                        currentList = currentList.filter(item => item !== this.id);
                                        localStorage.setItem('likedCars', JSON.stringify(currentList));
                                        window.dispatchEvent(new Event('storage'));

                                        setTimeout(() => {
                                            window.location.href = '/Account/Register';
                                        }, 1000);
                                    } else if (!response.ok) {
                                        // Revert state
                                        this.faved = !this.faved;
                                        window.showToast('Failed to save. Please try again.', 'error');

                                        // Revert localStorage
                                        let currentList = JSON.parse(localStorage.getItem('likedCars') || '[]');
                                        if (this.faved) {
                                            if (!currentList.includes(this.id)) currentList.push(this.id);
                                        } else {
                                            currentList = currentList.filter(item => item !== this.id);
                                        }
                                        localStorage.setItem('likedCars', JSON.stringify(currentList));
                                        window.dispatchEvent(new Event('storage'));
                                    }
                                } catch (err) {
                                    // Revert state
                                    this.faved = !this.faved;
                                    window.showToast('A network error occurred.', 'error');

                                    // Revert localStorage
                                    let currentList = JSON.parse(localStorage.getItem('likedCars') || '[]');
                                    if (this.faved) {
                                        if (!currentList.includes(this.id)) currentList.push(this.id);
                                    } else {
                                        currentList = currentList.filter(item => item !== this.id);
                                    }
                                    localStorage.setItem('likedCars', JSON.stringify(currentList));
                                    window.dispatchEvent(new Event('storage'));
                                }
                                </text>
                            }
                        }
                    }">
                        <div class="card-interactive overflow-hidden">
                            @* Image *@
                            <a href="/Cars/Details/@car.Id" class="block relative h-48 sm:h-52 xl:h-56 overflow-hidden bg-surface-850">
                                <img src="@car.PrimaryImageUrl" alt="@car.FullName" loading="lazy" onerror="this.onerror=null;this.src='https://placehold.co/800x600/1a1f2e/3b82f6?text=No+Image'" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                                <div class="absolute inset-0 bg-gradient-to-t from-surface-950/80 via-transparent to-transparent"></div>
                                @if (car.IsSold)
                                {
                                    <div class="absolute inset-0 bg-black/60 rounded-xl flex items-center justify-center z-10">
                                        <span class="bg-red-600 text-white text-lg font-black px-6 py-2 rounded-full uppercase tracking-widest rotate-[-15deg]">
                                            SOLD
                                        </span>
                                    </div>
                                }
                                @if (isOwner)
                                {
                                    <div class="absolute top-2 left-2 bg-blue-600 text-white text-xs font-bold px-2 py-1 rounded-full uppercase tracking-wide z-10">
                                        Your Listing
                                    </div>
                                }
                                <div class="absolute @(isOwner ? "top-11" : "top-3.5") left-3.5 bg-primary-600 text-white text-xs px-3 py-1 rounded font-extrabold uppercase tracking-wider">Featured</div>
                                <div class="absolute bottom-3.5 left-3.5">
                                    <p class="text-2xl sm:text-3xl font-display font-black text-white drop-shadow-md">@car.FormattedPrice</p>
                                </div>
                            </a>
                            @* Content *@
                            <div class="p-7">
                                <div class="flex items-start justify-between gap-2 mb-3">
                                    <a href="/Cars/Details/@car.Id" class="text-lg sm:text-xl font-display font-bold text-white truncate group-hover:text-primary-400 transition-colors">@car.FullName</a>
                                    @if (!isOwner)
                                    {
                                        <button x-on:click.stop.prevent="toggleFavorite()" class="flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center transition-colors bg-surface-850 hover:text-red-500"
                                                x-bind:class="faved ? 'bg-red-500/10' : ''">
                                            <svg class="w-4.5 h-4.5 transition-all duration-300" x-bind:class="faved ? 'fill-red-500 text-red-500' : 'fill-none text-gray-400'" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                                            </svg>
                                        </button>
                                    }
                                </div>
                                <div class="flex items-center gap-2 text-xs sm:text-sm text-surface-400 mb-4 font-semibold">
                                    <span>@car.FormattedMileage</span>
                                    <span class="text-surface-700">•</span>
                                    <span>@car.Transmission</span>
                                    <span class="text-surface-700">•</span>
                                    <span>@car.FuelType</span>
                                </div>
                                <div class="text-base text-surface-300 line-clamp-2 leading-relaxed">@car.Description</div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

