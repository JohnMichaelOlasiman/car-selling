@using RevvUp.Web.Models
@{
    ViewData["Title"] = "Premium Automotive Marketplace";
}

@* ── HERO SECTION ── *@
<section class="relative min-h-screen flex items-center justify-center overflow-hidden py-32" id="hero-section">
    @* Background Image Layer *@
    <div class="absolute inset-0 z-0">
        <img src="/images/hero-bg.png"
             alt="Premium sports car showcase"
             class="w-full h-full object-cover object-center scale-105"
             loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-b from-surface-950/80 via-surface-950/60 to-surface-950"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-surface-950/90 via-transparent to-surface-950/90"></div>
    </div>

    @* Subtle Glow Orbs *@
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
        <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-primary-500/5 rounded-full blur-[120px] animate-float"></div>
    </div>

    @* Hero Content *@
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 text-center pt-16">
        @* Announcement Badge *@
        <div class="animate-fade-in-down mb-8">
            <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary-500/10 border border-primary-500/25 text-primary-400 text-xs font-semibold uppercase tracking-wider">
                <span class="relative flex h-1.5 w-1.5">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-primary-500"></span>
                </span>
                The Next Generation Automotive Marketplace
            </span>
        </div>

        @* Headline *@
        <div class="animate-fade-in-up">
            <h1 class="text-4xl sm:text-6xl lg:text-7xl font-display font-black leading-[1.05] tracking-tight mb-6">
                <span class="block text-white">Discover Extraordinary</span>
                <span class="block text-gradient mt-1">Performance Machines</span>
            </h1>
        </div>

        @* Subheadline *@
        <p class="animate-fade-in-up delay-100 opacity-0 text-base sm:text-lg text-surface-400 max-w-2xl mx-auto mb-10 leading-relaxed">
            Experience an elite digital showroom engineered for automotive purists. Explore verified high-performance vehicles, muscle classics, and modern supercars.
        </p>

        @* Search Bar *@
        <div class="animate-fade-in-up delay-200 opacity-0 max-w-2xl mx-auto mb-12">
            <div class="bg-surface-900 border border-surface-800 p-2 rounded-xl shadow-elevated" x-data="{ focused: false }">
                <div class="flex flex-col sm:flex-row gap-2">
                    <div class="relative flex-1">
                        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-surface-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                        </svg>
                        <input type="text"
                               placeholder="Search brand, model, or keyword..."
                               class="w-full pl-11 pr-4 py-3 bg-transparent border-0 text-white placeholder-surface-500 text-base focus:ring-0 focus:outline-none"
                               id="hero-search-input" />
                    </div>
                    <button onclick="window.location.href='/Cars/Browse?search='+document.getElementById('hero-search-input').value"
                            class="btn-primary whitespace-nowrap" id="hero-search-btn">
                        Search Inventory
                    </button>
                </div>
            </div>
        </div>

        @* Trust Metrics *@
        <div class="animate-fade-in-up delay-300 opacity-0">
            <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-16">
                <div class="text-center">
                    <div class="text-2xl sm:text-3xl font-display font-black text-white">50K+</div>
                    <div class="text-xs text-surface-400 uppercase tracking-widest mt-1">Cars Listed</div>
                </div>
                <div class="w-px h-8 bg-surface-800/80 hidden sm:block"></div>
                <div class="text-center">
                    <div class="text-2xl sm:text-3xl font-display font-black text-white">12K+</div>
                    <div class="text-xs text-surface-400 uppercase tracking-widest mt-1">Happy Buyers</div>
                </div>
                <div class="w-px h-8 bg-surface-800/80 hidden sm:block"></div>
                <div class="text-center">
                    <div class="text-2xl sm:text-3xl font-display font-black text-white">4.9★</div>
                    <div class="text-xs text-surface-400 uppercase tracking-widest mt-1">User Rating</div>
                </div>
                <div class="w-px h-8 bg-surface-800/80 hidden sm:block"></div>
                <div class="text-center">
                    <div class="text-2xl sm:text-3xl font-display font-black text-white">24hr</div>
                    <div class="text-xs text-surface-400 uppercase tracking-widest mt-1">Avg. Sell Time</div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ── FEATURES PREVIEW SECTION ── *@
<section class="relative py-24 sm:py-32 border-t border-surface-850" id="features-section">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        @* Section Header *@
        <div class="text-center mb-16">
            <span class="text-primary-400 text-xs font-bold uppercase tracking-widest">Architected for Quality</span>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-white mt-2 mb-4">
                Redefining the <span class="text-gradient">Automotive Exchange</span>
            </h2>
            <p class="text-surface-400 text-base max-w-xl mx-auto">
                RevvUp introduces state-of-the-art interactive digital assets and tools built to bridge elite car collectors and sellers.
            </p>
        </div>

        @* Grid *@
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
            <div class="card p-8 space-y-4">
                <div class="w-12 h-12 rounded-lg bg-primary-500/10 border border-primary-500/20 flex items-center justify-center">
                    <span class="text-2xl">⚡</span>
                </div>
                <h3 class="text-lg font-bold text-white">Dynamic 3D Customizer</h3>
                <p class="text-surface-400 text-sm leading-relaxed">
                    Render hue rotations and dynamic custom car paints directly inside the detail dashboard gallery simulation.
                </p>
            </div>
            <div class="card p-8 space-y-4">
                <div class="w-12 h-12 rounded-lg bg-primary-500/10 border border-primary-500/20 flex items-center justify-center">
                    <span class="text-2xl">⚖️</span>
                </div>
                <h3 class="text-lg font-bold text-white">Multi-Slot Comparison</h3>
                <p class="text-surface-400 text-sm leading-relaxed">
                    Instantly load up to 4 sports car models side-by-side inside our responsive Technical comparison dashboard.
                </p>
            </div>
            <div class="card p-8 space-y-4">
                <div class="w-12 h-12 rounded-lg bg-primary-500/10 border border-primary-500/20 flex items-center justify-center">
                    <span class="text-2xl">🏁</span>
                </div>
                <h3 class="text-lg font-bold text-white">Interactive Sells Wizard</h3>
                <p class="text-surface-400 text-sm leading-relaxed">
                    Launch premium vehicle listings through an extremely fluid multi-step creation flow with reactive visual photo previews.
                </p>
            </div>
        </div>
    </div>
</section>

@* ── FEATURED CARS SECTION ── *@
<section class="relative py-24 bg-surface-900 border-t border-b border-surface-850" id="featured-section">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        @* Header *@
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-12">
            <div>
                <span class="text-primary-400 text-xs font-bold uppercase tracking-widest">Handpicked Collection</span>
                <h2 class="text-3xl sm:text-4xl font-display font-bold text-white mt-2">
                    Featured <span class="text-gradient">Masterpieces</span>
                </h2>
            </div>
            <a href="/Cars/Browse?sortBy=newest" class="text-sm font-semibold text-primary-400 hover:text-primary-300 transition-colors flex items-center gap-1 mt-4 md:mt-0 group">
                View All Featured
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
            </a>
        </div>

        @* Featured Grid *@
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            @if (ViewBag.FeaturedCars != null)
            {
                foreach (var car in (List<CarCardViewModel>)ViewBag.FeaturedCars)
                {
                    <div class="car-card opacity-0 transform translate-y-8 transition-all duration-500 ease-out" x-data="{ liked: false }">
                        <div class="card-interactive overflow-hidden group">
                            @* Image *@
                            <a href="/Cars/Details/@car.Id" class="block relative h-48 overflow-hidden bg-surface-850">
                                <img src="@car.ImageUrl" alt="@car.FullName" loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                                <div class="absolute inset-0 bg-gradient-to-t from-surface-950/80 via-transparent to-transparent"></div>
                                <div class="absolute top-3 left-3 bg-primary-600 text-white text-[10px] px-2 py-0.5 rounded font-bold uppercase tracking-wider">Featured</div>
                                <div class="absolute bottom-3 left-3">
                                    <p class="text-lg font-display font-bold text-white drop-shadow-md">@car.FormattedPrice</p>
                                </div>
                            </a>
                            @* Content *@
                            <div class="p-5">
                                <div class="flex items-start justify-between gap-2 mb-2">
                                    <a href="/Cars/Details/@car.Id" class="text-sm font-display font-bold text-white truncate group-hover:text-primary-400 transition-colors">@car.FullName</a>
                                    <button x-on:click="liked = !liked" class="flex-shrink-0 w-7 h-7 rounded-full flex items-center justify-center transition-colors bg-surface-850 text-surface-500 hover:text-pink-500"
                                            x-bind:class="liked ? 'text-pink-500 bg-pink-500/10' : ''">
                                        <svg class="w-3.5 h-3.5" x-bind:fill="liked ? 'currentColor' : 'none'" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                                        </svg>
                                    </button>
                                </div>
                                <div class="flex items-center gap-1.5 text-[11px] text-surface-400 mb-3">
                                    <span>@car.FormattedMileage</span>
                                    <span>•</span>
                                    <span>@car.Transmission</span>
                                    <span>•</span>
                                    <span>@car.FuelType</span>
                                </div>
                                <div class="text-xs text-surface-500 line-clamp-2 leading-relaxed">@car.Description</div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

