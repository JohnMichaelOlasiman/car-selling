@* ── FEATURED CARS SECTION ── *@
<section class="relative py-24 bg-surface-900 border-t border-b border-surface-850" id="featured-section">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        @* Header *@
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-12">
            <div>
                <span class="text-primary-400 text-xs font-bold uppercase tracking-widest">Handpicked Collection</span>
                <h2 class="text-3xl sm:text-4xl font-display font-bold text-white mt-2">
                    Featured <span class="text-gradient">Masterpieces</span>
                </h2>
            </div>
            <a href="/Cars/Browse?sortBy=newest" class="text-sm font-semibold text-primary-400 hover:text-primary-300 transition-colors flex items-center gap-1 mt-4 md:mt-0 group">
                View All Featured
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
            </a>
        </div>

        @* Featured Grid *@
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            @if (ViewBag.FeaturedCars != null)
            {
                foreach (var car in (List<CarCardViewModel>)ViewBag.FeaturedCars)
                {
                    <div class="car-card opacity-0 transform translate-y-8 transition-all duration-500 ease-out group" x-data="{
                        id: '@car.Id',
                        get liked() {
                            return JSON.parse(localStorage.getItem('likedCars') || '[]').includes(this.id);
                        },
                        toggleLike() {
                            @if (User.Identity?.IsAuthenticated != true)
                            {
                                <text>
                                window.location.href = '/Account/Login';
                                return;
                                </text>
                            }
                            else
                            {
                                <text>
                                fetch(`/Cars/ToggleFavorite/${this.id}`, { method: 'POST' })
                                    .then(res => {
                                        if (res.status === 401) {
                                            window.location.href = '/Account/Login';
                                            return;
                                        }
                                        return res.json();
                                    })
                                    .then(data => {
                                        if (data && typeof data.favorited !== 'undefined') {
                                            let list = JSON.parse(localStorage.getItem('likedCars') || '[]');
                                            if (data.favorited) {
                                                if (!list.includes(this.id)) list.push(this.id);
                                            } else {
                                                list = list.filter(item => item !== this.id);
                                            }
                                            localStorage.setItem('likedCars', JSON.stringify(list));
                                            window.dispatchEvent(new Event('storage'));
                                        }
                                    })
                                    .catch(err => console.error(err));
                                </text>
                            }
                        }
                    }">
                        <div class="card-interactive overflow-hidden">
                            @* Image *@
                            <a href="/Cars/Details/@car.Id" class="block relative h-48 overflow-hidden bg-surface-850">
                                <img src="@car.PrimaryImageUrl" alt="@car.FullName" loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                                <div class="absolute inset-0 bg-gradient-to-t from-surface-950/80 via-transparent to-transparent"></div>
                                <div class="absolute top-3 left-3 bg-primary-600 text-white text-[10px] px-2 py-0.5 rounded font-bold uppercase tracking-wider">Featured</div>
                                <div class="absolute bottom-3 left-3">
                                    <p class="text-lg font-display font-bold text-white drop-shadow-md">@car.FormattedPrice</p>
                                </div>
                            </a>
                            @* Content *@
                            <div class="p-5">
                                <div class="flex items-start justify-between gap-2 mb-2">
                                    <a href="/Cars/Details/@car.Id" class="text-sm font-display font-bold text-white truncate group-hover:text-primary-400 transition-colors">@car.FullName</a>
                                    <button x-on:click.stop.prevent="toggleLike()" class="flex-shrink-0 w-7 h-7 rounded-full flex items-center justify-center transition-colors bg-surface-850 text-surface-500 hover:text-pink-500"
                                            x-bind:class="liked ? 'text-pink-500 bg-pink-500/10' : ''">
                                        <svg class="w-3.5 h-3.5" x-bind:fill="liked ? 'currentColor' : 'none'" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                                        </svg>
                                    </button>
                                </div>
                                <div class="flex items-center gap-1.5 text-[11px] text-surface-400 mb-3">
                                    <span>@car.FormattedMileage</span>
                                    <span>•</span>
                                    <span>@car.Transmission</span>
                                    <span>•</span>
                                    <span>@car.FuelType</span>
                                </div>
                                <div class="text-xs text-surface-500 line-clamp-2 leading-relaxed">@car.Description</div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

