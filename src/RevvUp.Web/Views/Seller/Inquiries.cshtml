@model List<RevvUp.Core.Entities.Inquiry>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Buyer Inquiries — RevvUp";
    var carName  = ViewBag.CarName as string ?? "Your Listing";
    var carId    = (Guid)(ViewBag.CarId ?? Guid.Empty);
}

<div class="py-8 space-y-6 max-w-4xl mx-auto">

    @* ── Header ── *@
    <div class="flex items-center gap-4">
        <a href="/Seller/MyListings" class="p-2 rounded-xl border border-dark-700 text-dark-400 hover:text-white hover:border-dark-600 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-white">Buyer Inquiries</h1>
            <p class="text-dark-400 text-sm">@carName — @Model.Count inquiry thread(s)</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="glass-card rounded-2xl p-16 flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-full bg-dark-700/50 flex items-center justify-center mb-4">
                <svg class="w-8 h-8 text-dark-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
            </div>
            <h2 class="text-lg font-semibold text-white mb-2">No inquiries yet</h2>
            <p class="text-dark-400 text-sm">Buyers will appear here once they message you about this listing.</p>
        </div>
    }
    else
    {
        <div class="space-y-4" id="inquiries-list">
            @foreach (var inquiry in Model)
            {
                <div class="glass-card rounded-2xl overflow-hidden" id="inquiry-@inquiry.Id">
                    @* Inquiry header *@
                    <div class="flex items-center justify-between p-5 border-b border-dark-700/50 cursor-pointer"
                         onclick="toggleThread('@inquiry.Id')">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-500/30 to-accent-500/30 flex items-center justify-center text-white font-bold text-sm shrink-0">
                                @inquiry.Name.Substring(0, Math.Min(1, inquiry.Name.Length)).ToUpper()
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-white">@inquiry.Name</p>
                                <p class="text-xs text-dark-400">@inquiry.Email · @inquiry.Phone</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="text-right hidden sm:block">
                                <p class="text-xs text-dark-500">@inquiry.InquiryDate.ToLocalTime().ToString("MMM d, yyyy")</p>
                                <span class="text-xs px-2 py-0.5 rounded-full @(inquiry.Status == "Pending" ? "bg-yellow-500/20 text-yellow-300" : inquiry.Status == "Resolved" ? "bg-green-500/20 text-green-300" : "bg-blue-500/20 text-blue-300")">@inquiry.Status</span>
                            </div>
                            <svg class="w-4 h-4 text-dark-400 transition-transform thread-chevron-@inquiry.Id" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </div>
                    </div>

                    @* Thread body (collapsed by default) *@
                    <div class="thread-body hidden" id="thread-body-@inquiry.Id">
                        @* Initial inquiry message *@
                        <div class="px-5 py-4 border-b border-dark-700/30">
                            <p class="text-xs text-dark-400 mb-1">Initial message</p>
                            <p class="text-sm text-dark-300 bg-dark-800/50 rounded-xl px-4 py-3">@inquiry.Message</p>
                        </div>

                        @* Chat thread (populated via AJAX) *@
                        <div class="px-5 py-4 space-y-3 max-h-80 overflow-y-auto seller-chat-scroll"
                             id="chat-area-@inquiry.Id"
                             data-inquiry-id="@inquiry.Id">
                            <p class="text-xs text-dark-500 text-center" id="chat-loading-@inquiry.Id">Loading messages...</p>
                        </div>

                        @* Reply form *@
                        <div class="px-5 pb-5">
                            <div class="flex gap-3">
                                <textarea id="reply-input-@inquiry.Id"
                                          class="flex-1 bg-dark-800 border border-dark-600 rounded-xl px-4 py-2.5 text-sm text-white placeholder-dark-500 focus:border-primary-500 focus:ring-1 focus:ring-primary-500/30 outline-none resize-none"
                                          rows="2" placeholder="Write a reply to @inquiry.Name..."></textarea>
                                <button onclick="sendReply('@inquiry.Id')"
                                        class="px-4 py-2 bg-primary-500 hover:bg-primary-400 text-white rounded-xl text-sm font-semibold transition-colors shrink-0 self-end">
                                    Send
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>

@section Scripts {
<script>
const loadedThreads = new Set();

function toggleThread(inquiryId) {
    const body    = document.getElementById('thread-body-' + inquiryId);
    const chevron = document.querySelector('.thread-chevron-' + inquiryId);
    if (!body) return;

    const isOpen = !body.classList.contains('hidden');
    body.classList.toggle('hidden', isOpen);
    chevron?.classList.toggle('rotate-180', !isOpen);

    if (!isOpen && !loadedThreads.has(inquiryId)) {
        loadedThreads.add(inquiryId);
        loadChatHistory(inquiryId);
    }
}

async function loadChatHistory(inquiryId) {
    const area    = document.getElementById('chat-area-' + inquiryId);
    const loading = document.getElementById('chat-loading-' + inquiryId);
    try {
        const res  = await fetch('/Dashboard/GetChatHistory?inquiryId=' + inquiryId);
        const msgs = await res.json();
        if (loading) loading.remove();

        // Skip index 0 (initial inquiry message shown above)
        msgs.slice(1).forEach(m => appendMessage(area, m));

        if (!msgs.slice(1).length) {
            area.innerHTML = '<p class="text-xs text-dark-500 text-center py-2">No replies yet. Send the first reply below.</p>';
        }
    } catch {
        if (loading) loading.textContent = 'Failed to load messages.';
    }
}

function appendMessage(area, msg) {
    if (!area) return;
    const isSeller = !msg.isCurrentUser;
    const div = document.createElement('div');
    div.className = 'flex ' + (isSeller ? 'justify-end' : 'justify-start');
    div.innerHTML = `
        <div class="max-w-xs ${isSeller ? 'bg-primary-500/20 border border-primary-500/30' : 'bg-dark-800'} rounded-xl px-4 py-2.5">
            <p class="text-xs font-semibold ${isSeller ? 'text-primary-300' : 'text-accent-300'} mb-1">${msg.senderName}</p>
            <p class="text-sm text-white">${msg.messageText}</p>
            <p class="text-xs text-dark-500 mt-1">${new Date(msg.createdAt).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}</p>
        </div>`;
    area.appendChild(div);
    area.scrollTop = area.scrollHeight;
}

async function sendReply(inquiryId) {
    const input = document.getElementById('reply-input-' + inquiryId);
    const text  = input?.value.trim();
    if (!text) return;

    const token = document.querySelector("input[name='__RequestVerificationToken']")?.value;
    const res = await fetch('/Seller/ReplyToInquiry', {
        method: 'POST',
        headers: { 
            'Content-Type': 'application/json',
            'RequestVerificationToken': token || ''
        },
        body: JSON.stringify({ inquiryId, messageText: text })
    });

    if (res.ok) {
        const msg  = await res.json();
        const area = document.getElementById('chat-area-' + inquiryId);
        // Clear "no replies" placeholder if present
        const placeholder = area.querySelector('p.text-dark-500');
        if (placeholder) placeholder.remove();
        appendMessage(area, { ...msg, isCurrentUser: false }); // treat seller as "right"
        input.value = '';
    }
}
</script>
}
