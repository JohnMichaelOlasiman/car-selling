@model SellerCarFormViewModel
@{
    var isEdit  = Model.Id != Guid.Empty;
    Layout      = "_DashboardLayout";
    ViewData["Title"] = (isEdit ? "Edit Listing" : "Post a Car") + " — RevvUp";
}

<div class="py-8 max-w-4xl mx-auto space-y-6">

    @* ── Page Header ── *@
    <div class="flex items-center gap-4">
        <a href="/Seller/MyListings" class="p-2 rounded-xl border border-dark-700 text-dark-400 hover:text-white hover:border-dark-600 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-white">@(isEdit ? "Edit Listing" : "Post a New Car")</h1>
            <p class="text-dark-400 text-sm">@(isEdit ? "Update your vehicle details below." : "Fill in your vehicle details to list it on RevvUp.")</p>
        </div>
    </div>

    @* ── Validation Summary ── *@
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="bg-red-500/10 border border-red-500/30 rounded-xl px-5 py-4 text-red-300 text-sm">
            <ul class="list-disc list-inside space-y-1">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form method="post"
          action="@(isEdit ? $"/Seller/Edit/{Model.Id}" : "/Seller/Create")"
          enctype="multipart/form-data"
          class="space-y-6">

        @Html.AntiForgeryToken()
        @if (isEdit)
        {
            <input type="hidden" name="Id" value="@Model.Id" />
        }

        @* ── Section: Basic Info ── *@
        <div class="glass-card rounded-2xl p-6 space-y-5">
            <h2 class="text-sm font-semibold text-dark-400 uppercase tracking-widest border-b border-dark-700 pb-3">Vehicle Info</h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                    <label class="block text-xs font-medium text-dark-400 mb-1.5">Brand <span class="text-red-400">*</span></label>
                    <input type="text" name="Brand" value="@Model.Brand" required placeholder="e.g. Toyota"
                           class="w-full bg-dark-800 border border-dark-600 rounded-xl px-4 py-2.5 text-sm text-white placeholder-dark-500 focus:border-primary-500 focus:ring-1 focus:ring-primary-500/30 outline-none transition-colors"/>
                </div>
                <div>
                    <label class="block text-xs font-medium text-dark-400 mb-1.5">Model <span class="text-red-400">*</span></label>
                    <input type="text" name="Model" value="@Model.Model" required placeholder="e.g. Camry"
                           class="w-full bg-dark-800 border border-dark-600 rounded-xl px-4 py-2.5 text-sm text-white placeholder-dark-500 focus:border-primary-500 focus:ring-1 focus:ring-primary-500/30 outline-none transition-colors"/>
                </div>
                <div>
                    <label class="block text-xs font-medium text-dark-400 mb-1.5">Year <span class="text-red-400">*</span></label>
                    <input type="number" name="Year" value="@Model.Year" min="1980" max="@(DateTime.Now.Year + 1)" required
                           class="w-full bg-dark-800 border border-dark-600 rounded-xl px-4 py-2.5 text-sm text-white focus:border-primary-500 focus:ring-1 focus:ring-primary-500/30 outline-none transition-colors"/>
                </div>
                <div x-data="{ price: '@Model.Price' }">
                    <label class="text-sm text-gray-400 font-medium">Selling Price (₱)</label>
                    <div class="relative mt-1">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 font-semibold">₱</span>
                        <input
                            type="number"
                            x-model="price"
                            name="Price"
                            placeholder="e.g. 850000"
                            class="w-full pl-8 pr-4 py-2.5 bg-gray-800 border border-gray-600 rounded-lg text-white focus:border-blue-500 focus:outline-none"
                            min="0" />
                    </div>

                    <div x-show="price > 0 && price < 10000" x-transition
                         class="mt-2 flex items-center gap-2 text-yellow-400 bg-yellow-900/30 border border-yellow-600 rounded-lg px-3 py-2 text-sm" x-cloak>
                        ⚠ Double-check your price. This seems unusually low for a vehicle.
                    </div>

                    <div x-show="price > 50000000" x-transition
                         class="mt-2 flex items-center gap-2 text-red-400 bg-red-900/30 border border-red-600 rounded-lg px-3 py-2 text-sm" x-cloak>
                        ⚠ This price looks unusually high. Please verify before submitting.
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-medium text-dark-400 mb-1.5">Mileage (km) <span class="text-red-400">*</span></label>
                    <input type="number" name="Mileage" value="@Model.Mileage" min="0" required
                           class="w-full bg-dark-800 border border-dark-600 rounded-xl px-4 py-2.5 text-sm text-white focus:border-primary-500 focus:ring-1 focus:ring-primary-500/30 outline-none transition-colors"/>
                </div>
                <div>
                    <label class="block text-xs font-medium text-dark-400 mb-1.5">Color <span class="text-red-400">*</span></label>
                    <input type="text" name="Color" value="@Model.Color" required placeholder="e.g. Midnight Black"
                           class="w-full bg-dark-800 border border-dark-600 rounded-xl px-4 py-2.5 text-sm text-white placeholder-dark-500 focus:border-primary-500 focus:ring-1 focus:ring-primary-500/30 outline-none transition-colors"/>
                </div>
            </div>

            <div>
                <label class="block text-xs font-medium text-dark-400 mb-1.5">Engine / Powertrain</label>
                <input type="text" name="Engine" value="@Model.Engine" placeholder="e.g. 2.0L Turbocharged Inline-4"
                       class="w-full bg-dark-800 border border-dark-600 rounded-xl px-4 py-2.5 text-sm text-white placeholder-dark-500 focus:border-primary-500 focus:ring-1 focus:ring-primary-500/30 outline-none transition-colors"/>
            </div>
        </div>

        @* ── Section: Specs ── *@
        <div class="glass-card rounded-2xl p-6 space-y-5">
            <h2 class="text-sm font-semibold text-dark-400 uppercase tracking-widest border-b border-dark-700 pb-3">Specifications</h2>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-5">
                @{
                    var selectClass = "w-full bg-dark-800 border border-dark-600 rounded-xl px-4 py-2.5 text-sm text-white focus:border-primary-500 focus:ring-1 focus:ring-primary-500/30 outline-none transition-colors";
                }
                <div>
                    <label class="block text-xs font-medium text-dark-400 mb-1.5">Body Type <span class="text-red-400">*</span></label>
                    <select name="BodyType" class="@selectClass">
                        @foreach (var opt in SellerCarFormViewModel.BodyTypeOptions)
                        {
                            if (Model.BodyType == opt) { <option value="@opt" selected>@opt</option> }
                            else { <option value="@opt">@opt</option> }
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-medium text-dark-400 mb-1.5">Fuel Type <span class="text-red-400">*</span></label>
                    <select name="FuelType" class="@selectClass">
                        @foreach (var opt in SellerCarFormViewModel.FuelTypeOptions)
                        {
                            if (Model.FuelType == opt) { <option value="@opt" selected>@opt</option> }
                            else { <option value="@opt">@opt</option> }
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-medium text-dark-400 mb-1.5">Transmission <span class="text-red-400">*</span></label>
                    <select name="Transmission" class="@selectClass">
                        @foreach (var opt in SellerCarFormViewModel.TransmissionOptions)
                        {
                            if (Model.Transmission == opt) { <option value="@opt" selected>@opt</option> }
                            else { <option value="@opt">@opt</option> }
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-medium text-dark-400 mb-1.5">Condition <span class="text-red-400">*</span></label>
                    <select name="Condition" class="@selectClass">
                        @foreach (var opt in SellerCarFormViewModel.ConditionOptions)
                        {
                            if (Model.Condition == opt) { <option value="@opt" selected>@opt</option> }
                            else { <option value="@opt">@opt</option> }
                        }
                    </select>
                </div>
            </div>
            @if (isEdit)
            {
                <div>
                    <label class="block text-xs font-medium text-dark-400 mb-1.5">Listing Status</label>
                    <select name="Status" class="@selectClass max-w-xs">
                        @foreach (var opt in SellerCarFormViewModel.StatusOptions)
                        {
                            if (Model.Status == opt) { <option value="@opt" selected>@opt</option> }
                            else { <option value="@opt">@opt</option> }
                        }
                    </select>
                </div>
            }
        </div>

        @* ── Section: Description & Features ── *@
        <div class="glass-card rounded-2xl p-6 space-y-5">
            <h2 class="text-sm font-semibold text-dark-400 uppercase tracking-widest border-b border-dark-700 pb-3">Details</h2>
            <div>
                <label class="block text-xs font-medium text-dark-400 mb-1.5">Description <span class="text-red-400">*</span></label>
                <textarea name="Description" rows="5" required maxlength="2000"
                          placeholder="Describe your vehicle's history, condition, highlights..."
                          class="w-full bg-dark-800 border border-dark-600 rounded-xl px-4 py-3 text-sm text-white placeholder-dark-500 focus:border-primary-500 focus:ring-1 focus:ring-primary-500/30 outline-none transition-colors resize-none">@Model.Description</textarea>
            </div>
            <div>
                <label class="block text-xs font-medium text-dark-400 mb-1.5">Features</label>
                <input type="text" name="Features" value="@Model.Features"
                       placeholder="e.g. Leather Seats, Sunroof, Backup Camera (comma-separated)"
                       class="w-full bg-dark-800 border border-dark-600 rounded-xl px-4 py-2.5 text-sm text-white placeholder-dark-500 focus:border-primary-500 focus:ring-1 focus:ring-primary-500/30 outline-none transition-colors"/>
            </div>
        </div>

        @* ── Section: Images ── *@
        <div class="glass-card rounded-2xl p-6 space-y-5">
            <h2 class="text-sm font-semibold text-dark-400 uppercase tracking-widest border-b border-dark-700 pb-3">Photos</h2>

            @* Upload from device *@
            <div>
                <label class="block text-xs font-medium text-dark-400 mb-1.5">Upload Images (max 6, JPG/PNG/WebP, 10 MB each)</label>
                <label class="relative flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-dark-600 rounded-xl cursor-pointer hover:border-primary-500/50 transition-colors group">
                    <svg class="w-8 h-8 text-dark-500 group-hover:text-primary-400 transition-colors mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <span class="text-xs text-dark-400 group-hover:text-dark-300">Click to upload or drag & drop</span>
                    <input type="file" name="ImageFiles" accept="image/*" multiple class="absolute inset-0 opacity-0 cursor-pointer" id="imageUploadInput"/>
                </label>
                <p id="imageFileNames" class="text-xs text-dark-500 mt-1.5"></p>
            </div>

            @* Divider *@
            <div class="flex items-center gap-3">
                <div class="h-px flex-1 bg-dark-700"></div>
                <span class="text-xs text-dark-500">or paste URLs</span>
                <div class="h-px flex-1 bg-dark-700"></div>
            </div>

            @* URL input *@
            <div>
                <label class="block text-xs font-medium text-dark-400 mb-1.5">Image URLs (one per line or semicolon-separated)</label>
                <textarea name="ImageUrlsRaw" rows="4"
                          placeholder="https://example.com/car-photo.jpg&#10;https://example.com/car-photo-2.jpg"
                          class="w-full bg-dark-800 border border-dark-600 rounded-xl px-4 py-3 text-sm text-white placeholder-dark-500 focus:border-primary-500 focus:ring-1 focus:ring-primary-500/30 outline-none transition-colors resize-none font-mono text-xs">@Model.ImageUrlsRaw</textarea>
            </div>
        </div>

        @* ── Submit Buttons ── *@
        <div class="flex items-center gap-4 pt-2">
            <button type="submit"
                    class="px-8 py-3 bg-gradient-to-r from-primary-500 to-accent-500 text-white rounded-xl font-semibold hover:shadow-lg hover:shadow-primary-500/25 transition-all duration-300 hover:-translate-y-0.5">
                @(isEdit ? "Save Changes" : "Publish Listing")
            </button>
            <a href="/Seller/MyListings" class="px-6 py-3 text-dark-400 hover:text-white border border-dark-700 rounded-xl font-medium transition-colors">
                Cancel
            </a>
        </div>

    </form>
</div>

@section Scripts {
<script>
    // Show selected file names
    document.getElementById('imageUploadInput')?.addEventListener('change', function () {
        const names = Array.from(this.files).map(f => f.name).join(', ');
        document.getElementById('imageFileNames').textContent = names || '';
    });
</script>
}
