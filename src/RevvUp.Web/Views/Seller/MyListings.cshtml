@model List<SellerListingViewModel>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "My Listings — RevvUp Seller";
    ViewData["FitToScreen"] = true;
    ViewData["UseCompactFooter"] = true;

    int currentPage = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int maxDisplayedPages = 5;
    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, startPage + maxDisplayedPages - 1);
    if (endPage - startPage + 1 < maxDisplayedPages)
    {
        startPage = Math.Max(1, endPage - maxDisplayedPages + 1);
    }
}

@* ── Success/Error Banner ── *@
@if (TempData["Success"] != null)
{
    <div id="seller-toast" class="fixed top-6 right-6 z-50 flex items-center gap-3 bg-green-500/20 border border-green-500/40 text-green-300 px-5 py-3 rounded-xl backdrop-blur-md shadow-xl animate-fade-in">
        <svg class="w-5 h-5 text-green-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <span class="text-sm font-medium">@TempData["Success"]</span>
    </div>
    <script>setTimeout(()=>{ const t=document.getElementById('seller-toast'); if(t) t.style.opacity='0'; }, 3000);</script>
}

<style>
    /* 1. Rigid container height relative to the viewport */
    .listings-container {
        height: calc(100vh - 180px) !important;
        max-height: calc(100vh - 180px) !important;
        min-height: 450px !important;
        overflow: hidden !important;
    }
    @@media (min-width: 1024px) {
        .listings-container {
            height: calc(100vh - 145px) !important;
            max-height: calc(100vh - 145px) !important;
        }
    }

    /* 2. Visible scrollbar rules for panels */
    .custom-scrollbar {
        overflow-y: auto !important;
        scrollbar-width: thin !important; /* Firefox compatibility */
        scrollbar-color: rgba(59, 130, 246, 0.45) rgba(15, 23, 42, 0.15) !important;
    }
    .custom-scrollbar::-webkit-scrollbar {
        width: 8px !important;
        height: 8px !important;
        display: block !important;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: rgba(15, 23, 42, 0.2) !important;
        border-radius: 9999px !important;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(59, 130, 246, 0.45) !important;
        border-radius: 9999px !important;
        border: 2px solid rgba(10, 14, 20, 0.8) !important;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(59, 130, 246, 0.75) !important;
    }
</style>

@* ── Page-level Alpine wrapper with shared modal state ── *@
<div x-data="{
    showModal: false,
    modalTitle: '',
    modalMessage: '',
    modalAction: '',
    modalToken: '',
    modalConfirmText: 'Confirm',
    modalConfirmClass: 'bg-red-600 hover:bg-red-700',
    openModal(title, message, action, token, confirmText, confirmClass) {
        this.modalTitle = title;
        this.modalMessage = message;
        this.modalAction = action;
        this.modalToken = token;
        this.modalConfirmText = confirmText || 'Confirm';
        this.modalConfirmClass = confirmClass || 'bg-red-600 hover:bg-red-700';
        this.showModal = true;
    }
}" class="py-2 animate-fade-in-up flex-grow flex flex-col listings-container overflow-hidden">
    <div class="h-full flex flex-col overflow-y-auto pr-1 custom-scrollbar space-y-8 py-6">

    @* ── Page Header ── *@
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-white tracking-tight">My Listings</h1>
            <p class="text-dark-400 text-sm mt-1">Manage all your posted vehicle listings</p>
        </div>
        <a href="/Seller/Create"
           class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-primary-500 to-accent-500 text-white rounded-xl font-semibold text-sm hover:shadow-lg hover:shadow-primary-500/25 transition-all duration-300 hover:-translate-y-0.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Post a Listing
        </a>
    </div>

    @* ── Stats Row ── *@
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        @{
            var stats = new[] {
                new { Label = "Total Listings", Value = ViewBag.TotalListings?.ToString() ?? "0", Icon = "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10", Color = "from-primary-500/20 to-primary-600/10 border-primary-500/20 text-primary-300" },
                new { Label = "Active", Value = ViewBag.ActiveListings?.ToString() ?? "0", Icon = "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", Color = "from-green-500/20 to-green-600/10 border-green-500/20 text-green-300" },
                new { Label = "Sold", Value = ViewBag.SoldListings?.ToString() ?? "0", Icon = "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2", Color = "from-accent-500/20 to-accent-600/10 border-accent-500/20 text-accent-300" },
                new { Label = "Total Inquiries", Value = ViewBag.TotalInquiries?.ToString() ?? "0", Icon = "M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z", Color = "from-purple-500/20 to-purple-600/10 border-purple-500/20 text-purple-300" }
            };
        }
        @foreach (var stat in stats)
        {
            <div class="bg-gradient-to-br @stat.Color border rounded-2xl p-5">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-xs font-medium text-dark-400 uppercase tracking-widest">@stat.Label</span>
                    <svg class="w-5 h-5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="@stat.Icon"/></svg>
                </div>
                <p class="text-3xl font-bold text-white">@stat.Value</p>
            </div>
        }
    </div>

    @* ── Listings Grid ── *@
    @if (!Model.Any())
    {
        <div class="flex flex-col items-center justify-center py-24 text-center">
            <div class="w-20 h-20 rounded-full bg-dark-700/50 flex items-center justify-center mb-5">
                <svg class="w-10 h-10 text-dark-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
            </div>
            <h2 class="text-xl font-semibold text-white mb-2">No listings yet</h2>
            <p class="text-dark-400 mb-6 max-w-sm">Start selling by posting your first vehicle listing. It only takes a few minutes.</p>
            <a href="/Seller/Create" class="px-6 py-3 bg-primary-500 text-white rounded-xl font-semibold hover:bg-primary-400 transition-colors">Post Your First Car</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
            @foreach (var listing in Model)
            {
                var statusClass = listing.Status switch {
                    "Sold"    => "bg-red-500/20 text-red-300 border border-red-500/30",
                    "Pending" => "bg-yellow-500/20 text-yellow-300 border border-yellow-500/30",
                    _         => "bg-green-500/20 text-green-300 border border-green-500/30"
                };

                @* Generate anti-forgery tokens for each listing *@
                var soldToken = Html.AntiForgeryToken().ToString() ?? "";
                var deleteToken = Html.AntiForgeryToken().ToString() ?? "";

                <div class="group car-card animate-fade-in-up">
                    <div class="card-interactive overflow-hidden">
                        @* ── Image Container ── *@
                        <a href="/Cars/Details/@listing.Id"
                           class="block relative h-52 overflow-hidden bg-surface-850">
                            @if (!string.IsNullOrEmpty(listing.ImageUrl))
                            {
                                <img src="@listing.ImageUrl" alt="@listing.Brand @listing.Model" loading="lazy"
                                     class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                                     onerror="this.src='/images/placeholder-car.svg'"/>
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center">
                                    <svg class="w-16 h-16 text-surface-650" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                </div>
                            }
                            @* Gradient overlay *@
                            <div class="absolute inset-0 bg-gradient-to-t from-surface-950/80 via-transparent to-transparent"></div>

                            @* Status Badge *@
                            <span class="absolute top-3 left-3 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider rounded-full backdrop-blur-sm @statusClass">@listing.Status</span>

                            @* Price overlay *@
                            <div class="absolute bottom-3 left-3">
                                <p class="text-xl font-display font-bold text-white drop-shadow-md">@listing.FormattedPrice</p>
                            </div>

                            @* Body type pill *@
                            @if (!string.IsNullOrEmpty(listing.BodyType))
                            {
                                <div class="absolute bottom-3 right-3 px-2 py-1 rounded bg-white/10 backdrop-blur-sm text-[10px] text-white font-medium">
                                    @listing.BodyType
                                </div>
                            }
                        </a>

                        @* ── Card Body ── *@
                        <div class="p-5">
                            <div class="flex items-start justify-between gap-2 mb-2">
                                <a href="/Cars/Details/@listing.Id"
                                   class="text-base font-display font-bold text-white truncate group-hover:text-primary-400 transition-colors">
                                     @listing.FullName
                                </a>
                            </div>

                            @* ── Specs Row ── *@
                            <div class="flex items-center gap-1.5 text-[11px] text-surface-400 mb-3">
                                <span>@listing.FormattedMileage</span>
                                <span>•</span>
                                <span>@listing.FuelType</span>
                                <span>•</span>
                                <span>@listing.Transmission</span>
                            </div>

                            @* ── Seller Stats Row ── *@
                            <div class="flex items-center gap-3 text-xs text-surface-400 mt-2">
                                <span class="flex items-center gap-1" title="Inquiries">
                                    <svg class="w-3.5 h-3.5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                                    @listing.InquiryCount inqu.
                                </span>
                                <span>•</span>
                                <span class="flex items-center gap-1" title="Favorites">
                                    <svg class="w-3.5 h-3.5 text-pink-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
                                    @listing.FavoriteCount saves
                                </span>
                                <span>•</span>
                                <span class="flex items-center gap-1" title="Views">
                                    <svg class="w-3.5 h-3.5 text-surface-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                    @listing.ViewCount views
                                </span>
                            </div>

                            @* ── Divider ── *@
                            <div class="h-px bg-surface-800/80 my-4"></div>

                            @* ── Action Buttons ── *@
                            <div class="flex items-center gap-2">
                                <a href="/Cars/Details/@listing.Id"
                                   class="flex-1 text-center py-2 text-xs font-semibold text-surface-300 hover:text-white border border-surface-700/50 hover:border-surface-600 rounded-lg transition-colors">
                                    View
                                </a>
                                @if (listing.InquiryCount > 0)
                                {
                                    <a href="/Dashboard/Messages?tab=seller&carId=@listing.Id"
                                       class="flex-1 text-center py-2 text-xs font-semibold text-accent-400 hover:text-white border border-accent-500/20 hover:border-accent-500/50 rounded-lg transition-colors">
                                        Inquiries (@listing.InquiryCount)
                                    </a>
                                }
                                <a href="/Seller/Edit/@listing.Id"
                                   class="flex-1 text-center py-2 text-xs font-semibold text-primary-400 hover:text-white border border-primary-500/20 hover:border-primary-500/50 rounded-lg transition-colors">
                                    Edit
                                </a>
                                @if (listing.Status != "Sold")
                                {
                                    <button type="button"
                                            @@click="openModal('Mark as Sold', 'Are you sure you want to mark this car as sold? This will change its status to Sold.', '/Seller/MarkSold/@listing.Id', '', 'Mark Sold', 'bg-green-600 hover:bg-green-700')"
                                            class="flex-1 py-2 text-xs font-semibold text-green-400 hover:text-white border border-green-500/20 hover:border-green-500/50 rounded-lg transition-colors">
                                        Mark Sold
                                    </button>
                                }
                                <button type="button"
                                        @@click="openModal('Delete Listing', 'Are you sure you want to delete this listing? This cannot be undone.', '/Seller/Delete/@listing.Id', '', 'Delete', 'bg-red-600 hover:bg-red-700')"
                                        class="p-2 text-red-400 hover:text-red-300 border border-red-500/20 hover:border-red-500/40 rounded-lg transition-colors"
                                        title="Delete">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Premium Pagination ── *@

        @if (totalPages > 1)
        {
            <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mt-12 pt-6 border-t border-surface-800/50 animate-fade-in-up">
                @* Pagination Info *@
                <p class="text-sm text-surface-400">
                    Showing Page <span class="text-white font-semibold">@currentPage</span> of <span class="text-white font-semibold">@totalPages</span>
                </p>

                @* Pagination Links *@
                <nav class="flex items-center gap-1.5" aria-label="Pagination">
                    @* First Page / Prev Page *@
                    @if (currentPage > 1)
                    {
                        <a href="@Url.Action("MyListings", new { page = 1 })"
                           class="w-10 h-10 rounded-xl bg-surface-800/80 text-surface-400 border border-surface-700/50 flex items-center justify-center transition-all duration-300 hover:border-primary-500/30 hover:text-white hover:bg-primary-500/5"
                           title="First Page">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m18.75 5.25-7.5 7.5 7.5 7.5m-6-15-7.5 7.5 7.5 7.5" />
                            </svg>
                        </a>
                        <a href="@Url.Action("MyListings", new { page = currentPage - 1 })"
                           class="w-10 h-10 rounded-xl bg-surface-800/80 text-surface-400 border border-surface-700/50 flex items-center justify-center transition-all duration-300 hover:border-primary-500/30 hover:text-white hover:bg-primary-500/5"
                           title="Previous Page">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                            </svg>
                        </a>
                    }
                    else
                    {
                        <span class="w-10 h-10 rounded-xl bg-surface-850 text-surface-600 border border-surface-800/30 flex items-center justify-center cursor-not-allowed">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                            </svg>
                        </span>
                    }

                    @* Ellipsis before startPage *@
                    @if (startPage > 1)
                    {
                        <span class="w-8 text-center text-surface-500">...</span>
                    }

                    @* Page Number Pills *@
                    @for (int p = startPage; p <= endPage; p++)
                    {
                        var isCurrent = (p == currentPage);
                        <a href="@Url.Action("MyListings", new { page = p })"
                           class="w-10 h-10 rounded-xl flex items-center justify-center font-display font-medium text-sm transition-all duration-300
                                  @(isCurrent ? "bg-primary-500 text-white shadow-glow-sm border border-primary-500" : "bg-surface-800/80 text-surface-400 border border-surface-700/50 hover:border-primary-500/30 hover:text-white hover:bg-primary-500/5")">
                            @p
                        </a>
                    }

                    @* Ellipsis after endPage *@
                    @if (endPage < totalPages)
                    {
                        <span class="w-8 text-center text-surface-500">...</span>
                    }

                    @* Next Page / Last Page *@
                    @if (currentPage < totalPages)
                    {
                        <a href="@Url.Action("MyListings", new { page = currentPage + 1 })"
                           class="w-10 h-10 rounded-xl bg-surface-800/80 text-surface-400 border border-surface-700/50 flex items-center justify-center transition-all duration-300 hover:border-primary-500/30 hover:text-white hover:bg-primary-500/5"
                           title="Next Page">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                            </svg>
                        </a>
                        <a href="@Url.Action("MyListings", new { page = totalPages })"
                           class="w-10 h-10 rounded-xl bg-surface-800/80 text-surface-400 border border-surface-700/50 flex items-center justify-center transition-all duration-300 hover:border-primary-500/30 hover:text-white hover:bg-primary-500/5"
                           title="Last Page">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m5.25 5.25 7.5 7.5-7.5 7.5m6-15 7.5 7.5-7.5 7.5" />
                            </svg>
                        </a>
                    }
                    else
                    {
                        <span class="w-10 h-10 rounded-xl bg-surface-850 text-surface-600 border border-surface-800/30 flex items-center justify-center cursor-not-allowed">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                            </svg>
                        </span>
                    }
                </nav>
            </div>
        }
    }

    </div>

    @* ══════════════════════════════════════════════════════════════ *@
    @* ── SINGLE SHARED MODAL — outside all cards, at page root ── *@
    @* ══════════════════════════════════════════════════════════════ *@

    @* Backdrop overlay *@
    <div x-show="showModal"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         @@click="showModal = false"
         class="fixed inset-0 bg-black/70 backdrop-blur-sm z-[9998]"
         x-cloak>
    </div>

    @* Modal dialog *@
    <div x-show="showModal"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 scale-95"
         x-transition:enter-end="opacity-100 scale-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100 scale-100"
         x-transition:leave-end="opacity-0 scale-95"
         class="fixed inset-0 z-[9999] flex items-center justify-center p-4 pointer-events-none"
         x-cloak>
        <div class="bg-gray-900 border border-gray-700 rounded-2xl p-6 w-full max-w-sm shadow-2xl pointer-events-auto"
             @@click.outside="showModal = false">
            <h2 class="text-white font-bold text-lg mb-2" x-text="modalTitle"></h2>
            <p class="text-gray-400 text-sm mb-6" x-text="modalMessage"></p>
            <div class="flex gap-3">
                <button type="button"
                        @@click="showModal = false"
                        class="flex-1 py-2.5 rounded-lg border border-gray-600 text-gray-300 hover:text-white hover:border-gray-400 transition text-sm">
                    Cancel
                </button>
                <form x-ref="modalForm" method="post" :action="modalAction" class="flex-1">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="w-full py-2.5 rounded-lg text-white font-semibold transition text-sm"
                            :class="modalConfirmClass"
                            x-text="modalConfirmText">
                    </button>
                </form>
            </div>
        </div>
    </div>

</div>
