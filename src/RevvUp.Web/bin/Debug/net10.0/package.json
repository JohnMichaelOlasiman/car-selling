{
  "name": "revvup.web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "css:build": "npx tailwindcss -i ./Styles/app.css -o ./wwwroot/css/site.css --minify",
    "css:watch": "npx tailwindcss -i ./Styles/app.css -o ./wwwroot/css/site.css --watch",
    "build": "npm run css:build",
    "dev": "npm run css:watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17"
  }
}
